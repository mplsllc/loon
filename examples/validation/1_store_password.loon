// Validation Program 1: Store a password securely
// The happy path must compile without friction.
// The commented lines must be compile errors when uncommented.
module auth;

fn store_password(pw: Sensitive<String>) [IO, Crypto] -> Hashed<String> {
    hash_password(pw)
}

fn main() [IO, Crypto] -> Unit {
    let pw: Sensitive<String> = "hunter2";
    let hash: Hashed<String> = store_password(pw);
    // do print(pw);     ← COMPILE ERROR: cannot log Sensitive value
    // do print(hash);   ← COMPILE ERROR: cannot log Hashed value
    do print("password stored");
    do exit(0);
}
