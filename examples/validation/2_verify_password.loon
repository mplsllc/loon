// Validation Program 2: Verify a password
// verify_password takes Sensitive + Hashed, returns Bool.
// The Bool result is safe to use in control flow.
module auth;

fn check_login(pw: Sensitive<String>, stored: Hashed<String>) [] -> Bool {
    verify_password(pw, stored)
}

fn main() [IO, Crypto] -> Unit {
    let pw: Sensitive<String> = "hunter2";
    let hash: Hashed<String> = hash_password(pw);
    let ok: Bool = check_login(pw, hash);
    do exit(match ok { true -> 0, false -> 1 });
}
