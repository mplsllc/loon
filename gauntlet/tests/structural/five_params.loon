// TEST: five_params
// EXPECT: COMPILES OK, exit 15
// CATEGORY: structural
module test;
fn sum5(a: Array<Int>, b: Array<Int>, c: Array<Int>, d: Array<Int>, e: Array<Int>) [] -> Int {
    a[0] + b[0] + c[0] + d[0] + e[0]
}
fn main() [IO] -> Unit {
    let a: Array<Int> = Array(1); a[0] = 1;
    let b: Array<Int> = Array(1); b[0] = 2;
    let c: Array<Int> = Array(1); c[0] = 3;
    let d: Array<Int> = Array(1); d[0] = 4;
    let e: Array<Int> = Array(1); e[0] = 5;
    do exit(sum5(a, b, c, d, e));
}
