// TEST: array_loop
// EXPECT: COMPILES OK, exit 10
// CATEGORY: structural
module test;
fn main() [IO] -> Unit {
    let arr: Array<Int> = Array(5);
    for i in range(0, 5) {
        arr[i] = i;
    };
    let sum: Array<Int> = Array(1);
    sum[0] = 0;
    for i in range(0, 5) {
        sum[0] = sum[0] + arr[i];
    };
    do exit(sum[0]);
}
