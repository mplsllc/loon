// TEST: four_params
// EXPECT: COMPILES OK, exit 100
// CATEGORY: structural
module test;
fn sum4(a: Array<Int>, b: Array<Int>, c: Array<Int>, d: Array<Int>) [] -> Int {
    a[0] + b[0] + c[0] + d[0]
}
fn main() [IO] -> Unit {
    let a: Array<Int> = Array(1); a[0] = 10;
    let b: Array<Int> = Array(1); b[0] = 20;
    let c: Array<Int> = Array(1); c[0] = 30;
    let d: Array<Int> = Array(1); d[0] = 40;
    do exit(sum4(a, b, c, d));
}
