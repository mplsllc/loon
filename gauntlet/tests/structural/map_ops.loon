// TEST: map_ops
// EXPECT: COMPILES OK, exit 148
// CATEGORY: structural
module test;
type Option<T> { Some(value: Int), None }
fn map_new(cap: Int) [] -> Array<Int> { let m: Array<Int> = Array(cap*2+1); m[0]=0; m }
fn map_set(m: Array<Int>, key: Int, val: Int) [] -> Unit {
    let c: Int = m[0]; let f: Array<Int> = Array(1); f[0]=0-1;
    for i in range(0,c) { match m[1+i*2]==key { true -> { f[0]=i; }, false -> { } }; };
    match f[0]>=0 { true -> { m[1+f[0]*2+1]=val; }, false -> { m[1+c*2]=key; m[1+c*2+1]=val; m[0]=c+1; } };
}
fn map_get(m: Array<Int>, key: Int) [] -> Option {
    let c: Int = m[0]; let f: Array<Int> = Array(1); f[0]=0-1;
    for i in range(0,c) { match m[1+i*2]==key { true -> { f[0]=i; }, false -> { } }; };
    match f[0]>=0 { true -> Some(m[1+f[0]*2+1]), false -> None }
}
fn main() [IO] -> Unit {
    let m: Array<Int> = map_new(16);
    do map_set(m, 100, 42); do map_set(m, 200, 99); do map_set(m, 300, 7);
    let v1: Int = match map_get(m, 100) { Some(v) -> v, None -> 0 };
    let v2: Int = match map_get(m, 200) { Some(v) -> v, None -> 0 };
    let v3: Int = match map_get(m, 300) { Some(v) -> v, None -> 0 };
    let v4: Int = match map_get(m, 999) { Some(v) -> v, None -> 0 };
    do exit(v1 + v2 + v3 + v4);
}
