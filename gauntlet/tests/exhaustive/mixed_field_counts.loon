// TEST: mixed_field_counts
// EXPECT: COMPILES OK, exit 10
// CATEGORY: exhaustive
module test;
type Thing { Empty, One(x: Int), Two(a: Int, b: Int) }
fn val(t: Thing) [] -> Int {
    match t {
        Empty -> 0,
        One(x) -> x,
        Two(a, b) -> a + b,
    }
}
fn main() [IO] -> Unit {
    let a: Thing = Empty;
    let b: Thing = One(3);
    let c: Thing = Two(3, 4);
    do exit(val(a) + val(b) + val(c));
}
