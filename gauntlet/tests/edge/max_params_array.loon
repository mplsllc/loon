// TEST: max_params_array
// EXPECT: COMPILES OK, exit 6
// CATEGORY: edge
// Maximum 3 Array params per function (6 registers used)
module test;
fn sum3(a: Array<Int>, b: Array<Int>, c: Array<Int>) [] -> Int {
    a[0] + b[0] + c[0]
}
fn main() [IO] -> Unit {
    let a: Array<Int> = Array(1); a[0] = 1;
    let b: Array<Int> = Array(1); b[0] = 2;
    let c: Array<Int> = Array(1); c[0] = 3;
    do exit(sum3(a, b, c));
}
