// PROMPT: "Write a Loon function that handles a session token"
// SIMULATED AI OUTPUT — using Sensitive but logging the token
module session;

fn create_session(user_id: Int) [IO] -> Sensitive<String> {
    let token: Sensitive<String> = "sess_" + int_to_string(user_id) + "_token";
    do print("Created session: " + token);
    token
}

fn validate_session(token: Sensitive<String>) [IO] -> Bool {
    do print("Validating: " + token);
    match string_length(token) > 5 {
        true -> true,
        false -> false,
    }
}

fn main() [IO] -> Unit {
    let tok: Sensitive<String> = create_session(42);
    let valid: Bool = validate_session(tok);
    do exit(match valid { true -> 1, false -> 0 });
}
