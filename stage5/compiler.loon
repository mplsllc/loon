// stage2/compiler.loon — The Loon compiler, written in Loon-0
// Build: ./stage0/lexer stage2/compiler.loon | ./stage1/compiler > /tmp/stage2.asm
//        nasm -f elf64 -o /tmp/stage2.o /tmp/stage2.asm && ld -o stage2/compiler /tmp/stage2.o
//
// g[] slot allocation map — update when adding new regions
// Collisions between these regions cause silent bugs (see commit 307df8b).
//
// [0..14]      Lexer state: src_len, pos, line, col, tok_count, str_pos, etc.
// [15..19]     Parser scratch: pf_parse, mkbin helpers
// [20..28]     Parser child linking: pb_parse(20-22), pic_parse(23-25), pm_parse(26-28)
// [30..31]     Codegen: current fn node(30), current expr node(31)
// [32]         Label counter / LLVM SSA temp counter
// [33]         Stack offset accumulator (walker) / has_return flag (codegen)
// [34..39]     Walker + codegen scratch: node index(34), offset(35), temps(36-39)
// [40..42]     Name comparison: offset_a(40), offset_b(41), length(42)
// [46]         Call depth counter
// [47..49]     Module/import scratch
// [50]         Variable table entry count
// [51..849]    Variable table: entries at [51+i*4] = (name_off, name_len, offset, type)
//              Max ~200 entries. DO NOT use slots 51-849 for other purposes.
// [850..855]   Match codegen state (was g[115..120] — moved to fix var table collision)
// [856..857]   Match depth counter(856), save pointer(857) (was g[121..122])
// [860..920]   FREED — was match save stack (moved to g[6000+])
// [4400..5999]  Type checker undef name storage (was g[920..999] — 40 names, now 800)
// [6000..6599]  Match depth-indexed save stack (was g[860..920] — 10 levels, now 100)
// [900]        Type count (for ADTs)
// [905..911]   Type checker state: current node, error kind, expected, received, json flag, error count
// [915]        Target backend selector (0=nasm, 1=llvm)
// [920..999]   FREED — was undef name scanning (moved to g[4400+])
// [1024..2047] Type table: per-type data (64 slots × 16 types)
// [2048..4095] Walker explicit stack (iterative DFS, max 2000 entries)
//
// LLVM backend scratch (used only during --target llvm):
// [700..709]   ll_amatch: discriminant(700), adt_ptr(701), tag(702), match_id(703), arm_count(704), cursor(705-706)
// [710..749]   ll_amatch: arm result temps (g[710+i] = result of arm i)
// [750..755]   ll_builtin/ll_stmt scratch (exit trunc, ret/let temps)
module compiler;

// State: g[0]=src_len [1]=pos [2]=line [3]=col [4]=tok_count [5]=str_pos
//        [6]=mode [7]=emit_line [8]=emit_col [9]=str_off [10]=str_len
//        [12]=node_count [13]=tok_pos [15..17]=parse scratch

// ===== Character classification =====
fn is_lower(c: Int) [] -> Bool { match c >= 97 { true -> match c <= 122 { true -> true, false -> false }, false -> false } }
// is_upper — check if character is uppercase A-Z
fn is_upper(c: Int) [] -> Bool { match c >= 65 { true -> match c <= 90 { true -> true, false -> false }, false -> false } }
// is_alpha — check if character is a letter or underscore
fn is_alpha(c: Int) [] -> Bool { match is_lower(c) { true -> true, false -> match is_upper(c) { true -> true, false -> match c == 95 { true -> true, false -> false } } } }
// is_digit — check if character is 0-9
fn is_digit(c: Int) [] -> Bool { match c >= 48 { true -> match c <= 57 { true -> true, false -> false }, false -> false } }
// is_alnum — check if character is letter, digit, or underscore
fn is_alnum(c: Int) [] -> Bool { match is_alpha(c) { true -> true, false -> is_digit(c) } }
// is_ws — check if character is whitespace (space, tab, newline, CR)
fn is_ws(c: Int) [] -> Bool { match c == 32 { true -> true, false -> match c == 9 { true -> true, false -> match c == 10 { true -> true, false -> match c == 13 { true -> true, false -> false } } } } }

// ===== Lexer primitives =====
fn xpeek(xg: Array<Int>, xs: Array<Int>) [] -> Int { xs[xg[1]] }
// xend — check if source position is past end of input
fn xend(xg: Array<Int>) [] -> Bool { match xg[1] >= xg[0] { true -> true, false -> false } }
// xadv — advance source position by one byte, track line/col
fn xadv(xg: Array<Int>, xs: Array<Int>) [] -> Int {
    let xc: Int = xs[xg[1]]; xg[1] = xg[1] + 1;
    match xc == 10 { true -> { xg[2] = xg[2] + 1; xg[3] = 1; xc }, false -> { xg[3] = xg[3] + 1; xc } }
}
// xemit — emit a token with no string value (keywords, punctuation)
fn xemit(xg: Array<Int>, xtk: Array<Int>, xt: Int) [] -> Unit {
    let xb: Int = xg[4] * 5; xtk[xb] = xt; xtk[xb+1] = 0; xtk[xb+2] = 0; xtk[xb+3] = xg[7]; xtk[xb+4] = xg[8]; xg[4] = xg[4] + 1;
}
// xemitv — emit a token with string value (identifiers, literals)
fn xemitv(xg: Array<Int>, xtk: Array<Int>, xt: Int) [] -> Unit {
    let xb: Int = xg[4] * 5; xtk[xb] = xt; xtk[xb+1] = xg[9]; xtk[xb+2] = xg[10]; xtk[xb+3] = xg[7]; xtk[xb+4] = xg[8]; xg[4] = xg[4] + 1;
}

// ===== Keyword detection =====
// kw2 — match 2-char keywords: fn, in, do
fn kw2(kg: Array<Int>, ks: Array<Int>) [] -> Int { let ko: Int = kg[9]; match ks[ko]==102 { true -> match ks[ko+1]==110 { true -> 0, false -> 0-1 }, false -> match ks[ko]==105 { true -> match ks[ko+1]==110 { true -> 5, false -> 0-1 }, false -> match ks[ko]==100 { true -> match ks[ko+1]==111 { true -> 6, false -> 0-1 }, false -> 0-1 } } } }
// kw3 — match 3-char keywords: let, for
fn kw3(kg: Array<Int>, ks: Array<Int>) [] -> Int { let ko: Int = kg[9]; match ks[ko]==108 { true -> match ks[ko+1]==101 { true -> match ks[ko+2]==116 { true -> 1, false -> 0-1 }, false -> 0-1 }, false -> match ks[ko]==102 { true -> match ks[ko+1]==111 { true -> match ks[ko+2]==114 { true -> 4, false -> 0-1 }, false -> 0-1 }, false -> 0-1 } } }
// kw4 — match 4-char keywords: type, true
fn kw4(kg: Array<Int>, ks: Array<Int>) [] -> Int { let ko: Int = kg[9]; match ks[ko]==116 { true -> match ks[ko+1]==121 { true -> match ks[ko+2]==112 { true -> match ks[ko+3]==101 { true -> 2, false -> 0-1 }, false -> 0-1 }, false -> match ks[ko+1]==114 { true -> match ks[ko+2]==117 { true -> match ks[ko+3]==101 { true -> 11, false -> 0-1 }, false -> 0-1 }, false -> 0-1 } }, false -> 0-1 } }
// kw5 — match 5-char keywords: match, false
fn kw5(kg: Array<Int>, ks: Array<Int>) [] -> Int { let ko: Int = kg[9]; match ks[ko]==109 { true -> match ks[ko+1]==97 { true -> match ks[ko+2]==116 { true -> match ks[ko+3]==99 { true -> match ks[ko+4]==104 { true -> 3, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> match ks[ko]==102 { true -> match ks[ko+1]==97 { true -> match ks[ko+2]==108 { true -> match ks[ko+3]==115 { true -> match ks[ko+4]==101 { true -> 12, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> 0-1 } } }
// kw6 — match 6-char keyword: module
fn kw6(kg: Array<Int>, ks: Array<Int>) [] -> Int { let ko: Int = kg[9]; match ks[ko]==109 { true -> match ks[ko+1]==111 { true -> match ks[ko+2]==100 { true -> match ks[ko+3]==117 { true -> match ks[ko+4]==108 { true -> match ks[ko+5]==101 { true -> 7, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> 0-1 } }
// kw7 — match 7-char keywords: imports, exports
fn kw7(kg: Array<Int>, ks: Array<Int>) [] -> Int { let ko: Int = kg[9]; match ks[ko]==105 { true -> match ks[ko+1]==109 { true -> match ks[ko+2]==112 { true -> match ks[ko+3]==111 { true -> match ks[ko+4]==114 { true -> match ks[ko+5]==116 { true -> match ks[ko+6]==115 { true -> 8, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> match ks[ko]==101 { true -> match ks[ko+1]==120 { true -> match ks[ko+2]==112 { true -> match ks[ko+3]==111 { true -> match ks[ko+4]==114 { true -> match ks[ko+5]==116 { true -> match ks[ko+6]==115 { true -> 9, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> 0-1 }, false -> 0-1 } } }
// kwtype — dispatch keyword check by identifier length
fn kwtype(kg: Array<Int>, ks: Array<Int>) [] -> Int { match kg[10] { 2 -> kw2(kg, ks), 3 -> kw3(kg, ks), 4 -> kw4(kg, ks), 5 -> kw5(kg, ks), 6 -> kw6(kg, ks), 7 -> kw7(kg, ks), _ -> 0-1 } }

// ===== Lexer readers =====
fn lex_word(lg: Array<Int>, lt: Array<Int>, ls: Array<Int>) [] -> Unit { lg[9] = lg[5]; for _id in range(0, 256) { match xend(lg) { true -> { }, false -> match is_alnum(xpeek(lg, ls)) { true -> { ls[lg[5]] = xadv(lg, ls); lg[5] = lg[5] + 1; }, false -> { } } }; }; lg[10] = lg[5] - lg[9]; let lkt: Int = kwtype(lg, ls); match lkt >= 0 { true -> do xemit(lg, lt, lkt), false -> do xemitv(lg, lt, 13) }; }
// lex_num — lex integer or float literal (detects decimal point)
fn lex_num(lg: Array<Int>, lt: Array<Int>, ls: Array<Int>) [] -> Unit { lg[9] = lg[5]; let lisf: Array<Int> = Array(1); lisf[0] = 0; for _ni in range(0, 256) { match xend(lg) { true -> { }, false -> { let lnc: Int = xpeek(lg, ls); match is_digit(lnc) { true -> { ls[lg[5]] = xadv(lg, ls); lg[5] = lg[5] + 1; }, false -> match lnc == 46 { true -> match lisf[0] == 0 { true -> { lisf[0] = 1; ls[lg[5]] = xadv(lg, ls); lg[5] = lg[5] + 1; }, false -> { } }, false -> { } } }; } }; }; lg[10] = lg[5] - lg[9]; match lisf[0] { 0 -> do xemitv(lg, lt, 14), _ -> do xemitv(lg, lt, 15) }; }
// lex_str — lex string literal with escape sequences
fn lex_str(lg: Array<Int>, lt: Array<Int>, ls: Array<Int>) [] -> Unit { let _lq: Int = xadv(lg, ls); lg[9] = lg[5]; for _si in range(0, 65536) { match xend(lg) { true -> { }, false -> { let lsc: Int = xpeek(lg, ls); match lsc == 34 { true -> { }, false -> match lsc == 92 { true -> { let _lbs: Int = xadv(lg, ls); match xend(lg) { true -> { }, false -> { let lec: Int = xadv(lg, ls); match lec { 110 -> { ls[lg[5]] = 10; lg[5] = lg[5] + 1; }, 116 -> { ls[lg[5]] = 9; lg[5] = lg[5] + 1; }, 92 -> { ls[lg[5]] = 92; lg[5] = lg[5] + 1; }, 34 -> { ls[lg[5]] = 34; lg[5] = lg[5] + 1; }, _ -> { ls[lg[5]] = lec; lg[5] = lg[5] + 1; } }; } }; }, false -> { ls[lg[5]] = xadv(lg, ls); lg[5] = lg[5] + 1; } } }; } }; }; lg[10] = lg[5] - lg[9]; match xend(lg) { true -> { }, false -> match xpeek(lg, ls) == 34 { true -> { let _lcq: Int = xadv(lg, ls); }, false -> { } } }; do xemitv(lg, lt, 16); }
// lex_sym — lex operators and punctuation (single/double char)
fn lex_sym(lg: Array<Int>, lt: Array<Int>, ls: Array<Int>) [IO] -> Unit { let lc: Int = xadv(lg, ls); match lc { 123 -> do xemit(lg, lt, 17), 125 -> do xemit(lg, lt, 18), 40 -> do xemit(lg, lt, 19), 41 -> do xemit(lg, lt, 20), 91 -> do xemit(lg, lt, 21), 93 -> do xemit(lg, lt, 22), 43 -> do xemit(lg, lt, 24), 42 -> do xemit(lg, lt, 26), 47 -> do xemit(lg, lt, 27), 37 -> do xemit(lg, lt, 28), 58 -> do xemit(lg, lt, 40), 59 -> do xemit(lg, lt, 41), 44 -> do xemit(lg, lt, 42), 46 -> do xemit(lg, lt, 43), 45 -> match xend(lg) { true -> do xemit(lg, lt, 25), false -> match xpeek(lg, ls) == 62 { true -> { let _lgt: Int = xadv(lg, ls); do xemit(lg, lt, 38); }, false -> do xemit(lg, lt, 25) } }, 61 -> match xend(lg) { true -> do xemit(lg, lt, 23), false -> match xpeek(lg, ls) == 61 { true -> { let _le: Int = xadv(lg, ls); do xemit(lg, lt, 29); }, false -> do xemit(lg, lt, 23) } }, 33 -> match xend(lg) { true -> do xemit(lg, lt, 37), false -> match xpeek(lg, ls) == 61 { true -> { let _le: Int = xadv(lg, ls); do xemit(lg, lt, 30); }, false -> do xemit(lg, lt, 37) } }, 60 -> match xend(lg) { true -> do xemit(lg, lt, 31), false -> match xpeek(lg, ls) == 61 { true -> { let _le: Int = xadv(lg, ls); do xemit(lg, lt, 33); }, false -> do xemit(lg, lt, 31) } }, 62 -> match xend(lg) { true -> do xemit(lg, lt, 32), false -> match xpeek(lg, ls) == 61 { true -> { let _le: Int = xadv(lg, ls); do xemit(lg, lt, 34); }, false -> do xemit(lg, lt, 32) } }, 38 -> match xend(lg) { true -> { }, false -> match xpeek(lg, ls) == 38 { true -> { let _la: Int = xadv(lg, ls); do xemit(lg, lt, 35); }, false -> { } } }, 124 -> match xend(lg) { true -> { }, false -> match xpeek(lg, ls) == 124 { true -> { let _lo: Int = xadv(lg, ls); do xemit(lg, lt, 36); }, false -> match xpeek(lg, ls) == 62 { true -> { let _lp: Int = xadv(lg, ls); do xemit(lg, lt, 39); }, false -> { } } } }, _ -> { do print_raw("error: unexpected character '"); do print_byte(lc); do print_raw("' ("); do print_raw(int_to_string(lc)); do print_raw(") at line "); do print_raw(int_to_string(lg[2])); do print_raw(":"); do print(int_to_string(lg[3])); do exit(1); } }; }
// lex_dispatch — route to word/num/str/sym lexer based on first char
fn lex_dispatch(lg: Array<Int>, lt: Array<Int>, ls: Array<Int>) [IO] -> Unit { lg[7] = lg[2]; lg[8] = lg[3]; let lc: Int = xpeek(lg, ls); match lc == 47 { true -> match lg[1] + 1 < lg[0] { true -> match ls[lg[1] + 1] == 47 { true -> { let _ls1: Int = xadv(lg, ls); let _ls2: Int = xadv(lg, ls); lg[6] = 1; }, false -> do lex_sym(lg, lt, ls) }, false -> do lex_sym(lg, lt, ls) }, false -> match lc == 34 { true -> do lex_str(lg, lt, ls), false -> match is_alpha(lc) { true -> do lex_word(lg, lt, ls), false -> match is_digit(lc) { true -> do lex_num(lg, lt, ls), false -> do lex_sym(lg, lt, ls) } } } }; }
// lex_all — tokenize entire source, skip whitespace and comments
fn lex_all(lg: Array<Int>, lt: Array<Int>, ls: Array<Int>) [IO] -> Unit { lg[1] = 0; lg[2] = 1; lg[3] = 1; lg[4] = 0; lg[5] = 300000; lg[6] = 0; for _li in range(0, 999999) { match xend(lg) { true -> { }, false -> { let lc: Int = xpeek(lg, ls); match lg[6] == 1 { true -> match lc == 10 { true -> { lg[6] = 0; let _ln: Int = xadv(lg, ls); }, false -> { let _lcc: Int = xadv(lg, ls); } }, false -> match is_ws(lc) { true -> { let _lw: Int = xadv(lg, ls); }, false -> do lex_dispatch(lg, lt, ls) } }; } }; }; lg[7] = lg[2]; lg[8] = lg[3]; do xemit(lg, lt, 44); }

// ===== Token access =====
fn tcur(_g: Array<Int>, _t: Array<Int>) [] -> Int { _t[_g[13] * 5] }
// teat — consume current token (advance position)
fn teat(_g: Array<Int>) [] -> Unit { _g[13] = _g[13] + 1; }
// tsoff — get current token's string offset
fn tsoff(_g: Array<Int>, _t: Array<Int>) [] -> Int { _t[_g[13] * 5 + 1] }
// tslen — get current token's string length
fn tslen(_g: Array<Int>, _t: Array<Int>) [] -> Int { _t[_g[13] * 5 + 2] }

// ===== Privacy type detection =====
// Check if type name is a privacy wrapper. Uses g[136]=length, g[137]=offset.
// Reads source bytes from n[200000+offset] (parser's source copy).
// Returns privacy_level (1-5) or -1 if not a privacy type.
fn chk_priv(cp_g: Array<Int>, cp_n: Array<Int>) [] -> Int {
    // Match by length + first 2 chars from source copy at n[200000+offset]
    // Public(6,'P'=80,'u'=117)→1, Sensitive(9,'S'=83,'e'=101)→2,
    // Hashed(6,'H'=72,'a'=97)→4, Encrypted(9,'E'=69,'n'=110)→5
    let cp_len: Int = cp_g[136]; let cp_fc: Int = cp_n[200000 + cp_g[137]];
    let cp_sc: Int = cp_n[200000 + cp_g[137] + 1];
    match cp_len == 9 { true -> match cp_fc == 83 { true -> match cp_sc == 101 { true -> 2, false -> 0 - 1 }, false -> match cp_fc == 69 { true -> match cp_sc == 110 { true -> 5, false -> 0 - 1 }, false -> 0 - 1 } },
    false -> match cp_len == 6 { true -> match cp_fc == 80 { true -> match cp_sc == 117 { true -> 1, false -> 0 - 1 }, false -> match cp_fc == 72 { true -> match cp_sc == 97 { true -> 4, false -> 0 - 1 }, false -> 0 - 1 } },
    false -> 0 - 1 } }
}

// ===== Node helpers =====
fn nalloc(_g: Array<Int>, _n: Array<Int>) [] -> Int {
    let _i: Int = _g[12]; let _b: Int = _i * 10;
    _n[_b]=0; _n[_b+1]=0; _n[_b+2]=0; _n[_b+3]=0; _n[_b+4]=0;
    _n[_b+5]=0-1; _n[_b+6]=0-1; _n[_b+7]=0; _n[_b+8]=0; _n[_b+9]=0;
    _g[12] = _g[12] + 1; _i
}
// blink — placeholder (dead code, historical)
fn blink(_n: Array<Int>, _fc: Array<Int>, _lc: Array<Int>, _cc: Array<Int>) [] -> Unit {
// blink — placeholder function (dead code, historical)
    // Uses _g[18] as the node to link (set before calling)
    // This avoids >3 params
    0 - 1 // placeholder — need different approach
}

// ===== String-to-int conversion =====
// Reads digits from source buffer at g[40]=offset, g[41]=length
fn str2int(si_g: Array<Int>, si_s: Array<Int>) [] -> Int {
    let si_o: Int = si_g[40]; let si_l: Int = si_g[41];
    let si_v: Array<Int> = Array(1); si_v[0] = 0;
    for si_i in range(0, si_l) {
        si_v[0] = si_v[0] * 10 + si_s[si_o + si_i] - 48;
    };
    si_v[0]
}

// ===== Builtin detection =====
// Check if name at g[40]=offset, g[41]=length matches a builtin.
// Returns: builtin sub_type (0=none, 1=print, ..., 9=get_arg, 10=print_byte)
// Builtin detection: uses g[40]=offset, g[41]=length. Returns builtin ID.
// Full string comparison for builtin name lookup. No more character sampling.
// g[40]=name offset, g[41]=name length. s=source buffer.
fn str_eq(se_g: Array<Int>, se_s: Array<Int>, se_target: String) [] -> Bool {
    match se_g[41] == string_length(se_target) { false -> false, true -> {
        let se_ok: Array<Int> = Array(1); se_ok[0] = 1;
        for se_i in range(0, se_g[41]) {
            match se_s[se_g[40] + se_i] == string_char_at(se_target, se_i) { true -> { }, false -> { se_ok[0] = 0; } };
        };
        match se_ok[0] == 1 { true -> true, false -> false }
    } }
}

// chk_bi — check if name is a builtin, return ID or 0
fn chk_bi(bi_g: Array<Int>, bi_s: Array<Int>) [] -> Int {
// chk_bi — check if name is a builtin, return builtin ID or 0
    match str_eq(bi_g, bi_s, "print") { true -> 1,
    false -> match str_eq(bi_g, bi_s, "print_raw") { true -> 2,
    false -> match str_eq(bi_g, bi_s, "int_to_string") { true -> 3,
    false -> match str_eq(bi_g, bi_s, "string_length") { true -> 4,
    false -> do chk_bi2(bi_g, bi_s) } } } }
}
// chk_bi2 — check builtins with longer names
// chk_bi3 — second half of builtin lookup chain (13-20)
fn chk_bi3(b3_g: Array<Int>, b3_s: Array<Int>) [] -> Int {
    match str_eq(b3_g, b3_s, "string_equals") { true -> 13,
    false -> match str_eq(b3_g, b3_s, "float_to_string") { true -> 14,
    false -> match str_eq(b3_g, b3_s, "expose") { true -> 15,
    false -> match str_eq(b3_g, b3_s, "substring") { true -> 16,
    false -> match str_eq(b3_g, b3_s, "string_starts_with") { true -> 17,
    false -> match str_eq(b3_g, b3_s, "string_index_of") { true -> 18,
    false -> match str_eq(b3_g, b3_s, "string_contains") { true -> 19,
    false -> match str_eq(b3_g, b3_s, "string_trim") { true -> 20,
    false -> 0 } } } } } } } }
}
fn chk_bi2(b2_g: Array<Int>, b2_s: Array<Int>) [] -> Int {
    match str_eq(b2_g, b2_s, "string_char_at") { true -> 6,
    false -> match str_eq(b2_g, b2_s, "read_file") { true -> 7,
    false -> match str_eq(b2_g, b2_s, "exit") { true -> 8,
    false -> match str_eq(b2_g, b2_s, "get_arg") { true -> 9,
    false -> match str_eq(b2_g, b2_s, "print_byte") { true -> 10,
    false -> match str_eq(b2_g, b2_s, "Array") { true -> 11,
    false -> match str_eq(b2_g, b2_s, "range") { true -> 12,
    false -> match str_eq(b2_g, b2_s, "string_concat") { true -> 5,
    false -> chk_bi3(b2_g, b2_s)
    } } } } } } } }
}

// ===== Parser =====
// All parser functions use prefixed param names to avoid Stage 1 scoping bug #12

// pp_parse — two-pass program parser: collect fns, then parse bodies
fn pp_parse(pp_g: Array<Int>, pp_t: Array<Int>, pp_n: Array<Int>) [IO] -> Unit {
    pp_g[12] = 0; pp_g[13] = 0;
    match tcur(pp_g, pp_t) == 7 { true -> { do teat(pp_g); }, false -> { } };
    let pp_mi: Int = nalloc(pp_g, pp_n);
    pp_n[pp_mi * 10] = 0;
    pp_n[pp_mi * 10 + 2] = tsoff(pp_g, pp_t);
    pp_n[pp_mi * 10 + 3] = tslen(pp_g, pp_t);
    do teat(pp_g); do teat(pp_g);
    for _ppf in range(0, 256) {
        match tcur(pp_g, pp_t) == 44 { true -> { }, false -> match tcur(pp_g, pp_t) == 0 {
            true -> do pf_parse(pp_g, pp_t, pp_n),
            false -> match tcur(pp_g, pp_t) == 2 {
                true -> do pt_parse(pp_g, pp_t, pp_n),
                false -> match tcur(pp_g, pp_t) == 13 {
                    // Check for "extern" keyword (IDENT with text "extern")
                    true -> {
                        pp_g[40] = tsoff(pp_g, pp_t); pp_g[41] = tslen(pp_g, pp_t);
                        match pp_g[41] == 6 { true -> match pp_n[200000 + pp_g[40]] == 101 { true -> {
                            // "extern" — eat it, set extern flag, parse fn
                            do teat(pp_g);
                            pp_g[4310] = 1; // extern flag
                            do pf_parse(pp_g, pp_t, pp_n);
                            pp_g[4310] = 0; // reset
                        }, false -> { do teat(pp_g); } }, false -> { do teat(pp_g); } };
                    },
                    false -> { do teat(pp_g); },
                },
            },
        } };
    };
}

// Type declaration parser: type Name { Variant(...), ... }
fn pt_parse(pt_g: Array<Int>, pt_t: Array<Int>, pt_n: Array<Int>) [IO] -> Unit {
    do teat(pt_g); // KW_TYPE
    let pt_ti: Int = nalloc(pt_g, pt_n);
    pt_n[pt_ti * 10] = 22; // NODE_TYPE_DECL
    pt_n[pt_ti * 10 + 2] = tsoff(pt_g, pt_t);
    pt_n[pt_ti * 10 + 3] = tslen(pt_g, pt_t);
    // Register type in type table: gs[1024 + type_index * 64]
    let pt_idx: Int = pt_g[900];
    let pt_base: Int = 1024 + pt_idx * 64;
    pt_g[pt_base] = tsoff(pt_g, pt_t);
    pt_g[pt_base + 1] = tslen(pt_g, pt_t);
    pt_n[pt_ti * 10 + 8] = pt_idx; // extra = type table index
    do teat(pt_g); // eat type name
    // Check for generic type parameters: <T> or <T, E>
    // Store param count at gs[type_base + 20], param names at gs[type_base + 21..29]
    pt_g[pt_base + 20] = 0; // generic param count (0 = not generic)
    match tcur(pt_g, pt_t) == 31 { true -> { // LT = <
        do teat(pt_g); // eat <
        for _gp in range(0, 4) {
            match tcur(pt_g, pt_t) == 32 { true -> { }, false -> { // not >
                pt_g[pt_base + 21 + pt_g[pt_base + 20] * 2] = tsoff(pt_g, pt_t); // param name off
                pt_g[pt_base + 21 + pt_g[pt_base + 20] * 2 + 1] = tslen(pt_g, pt_t); // param name len
                pt_g[pt_base + 20] = pt_g[pt_base + 20] + 1;
                do teat(pt_g); // eat param name
                match tcur(pt_g, pt_t) == 42 { true -> { do teat(pt_g); }, false -> { } }; // eat comma
            } };
        };
        match tcur(pt_g, pt_t) == 32 { true -> { do teat(pt_g); }, false -> { } }; // eat >
    }, false -> { } };
    do teat(pt_g); // eat LBRACE
    // Parse variants
    let pt_vc: Array<Int> = Array(1); pt_vc[0] = 0;
    let pt_fv: Array<Int> = Array(1); pt_fv[0] = 0 - 1;
    let pt_lv: Array<Int> = Array(1); pt_lv[0] = 0 - 1;
    for _ptv in range(0, 64) { match tcur(pt_g, pt_t) == 18 { true -> { }, false -> {
        let pt_vi: Int = nalloc(pt_g, pt_n);
        pt_n[pt_vi * 10] = 23; // NODE_VARIANT
        pt_n[pt_vi * 10 + 2] = tsoff(pt_g, pt_t);
        pt_n[pt_vi * 10 + 3] = tslen(pt_g, pt_t);
        pt_n[pt_vi * 10 + 1] = pt_vc[0]; // sub_type = tag
        pt_n[pt_vi * 10 + 8] = pt_idx; // extra = parent type index
        // Register variant in type table
        let pt_vb: Int = pt_base + 3 + pt_vc[0] * 3;
        pt_g[pt_vb] = tsoff(pt_g, pt_t);
        pt_g[pt_vb + 1] = tslen(pt_g, pt_t);
        do teat(pt_g); // eat variant name
        // Parse optional fields: (name: Type, ...)
        let pt_fc: Array<Int> = Array(1); pt_fc[0] = 0;
        match tcur(pt_g, pt_t) == 19 { true -> {
            do teat(pt_g); // eat LPAREN
            for _ptf in range(0, 32) { match tcur(pt_g, pt_t) == 20 { true -> { }, false -> {
                do teat(pt_g); // eat field name
                do teat(pt_g); // eat COLON
                do teat(pt_g); // eat type name
                match tcur(pt_g, pt_t) == 31 { true -> { do teat(pt_g); do teat(pt_g); do teat(pt_g); }, false -> { } }; // eat <Type> if present
                pt_fc[0] = pt_fc[0] + 1;
                match tcur(pt_g, pt_t) == 42 { true -> { do teat(pt_g); }, false -> { } };
            } }; };
            do teat(pt_g); // eat RPAREN
        }, false -> { } };
        pt_n[pt_vi * 10 + 4] = pt_fc[0]; // child_count = field count
        pt_g[pt_vb + 2] = pt_fc[0]; // field count in type table
        // Link variants as siblings
        match pt_fv[0] == 0 - 1 { true -> { pt_fv[0] = pt_vi; pt_lv[0] = pt_vi; }, false -> { pt_n[pt_lv[0] * 10 + 6] = pt_vi; pt_lv[0] = pt_vi; } };
        pt_vc[0] = pt_vc[0] + 1;
        match tcur(pt_g, pt_t) == 42 { true -> { do teat(pt_g); }, false -> { } };
    } }; };
    do teat(pt_g); // eat RBRACE
    pt_n[pt_ti * 10 + 4] = pt_vc[0]; // child_count = variant count
    pt_n[pt_ti * 10 + 5] = pt_fv[0]; // first_child = first variant
    pt_g[pt_base + 2] = pt_vc[0]; // variant count in type table
    pt_g[900] = pt_idx + 1;
}

// Check if name at g[40]/g[41] matches a known variant. Returns type_index*256+tag or -1
// Source bytes are at n[200000+offset] (copied there before parsing)
fn chk_vari(cv_g: Array<Int>, cv_n: Array<Int>) [] -> Int {
    let cv_res: Array<Int> = Array(1); cv_res[0] = 0 - 1;
    for cv_ti in range(0, cv_g[900]) {
        let cv_base: Int = 1024 + cv_ti * 64;
        let cv_vc: Int = cv_g[cv_base + 2];
        for cv_vi in range(0, cv_vc) {
            let cv_vb: Int = cv_base + 3 + cv_vi * 3;
            match cv_g[cv_vb + 1] == cv_g[41] { true -> {
                // Length matches — compare characters via gn[200000+offset]
                cv_g[136] = 1;
                for cv_ci in range(0, cv_g[41]) {
                    match cv_n[200000 + cv_g[cv_vb] + cv_ci] == cv_n[200000 + cv_g[40] + cv_ci] { true -> { }, false -> { cv_g[136] = 0; } };
                };
                match cv_g[136] == 1 { true -> { cv_res[0] = cv_ti * 256 + cv_vi; }, false -> { } };
            }, false -> { } };
        };
    };
    cv_res[0]
}

// pf_parse — parse function declaration (params, effects, return type, body)
fn pf_parse(pf_g: Array<Int>, pf_t: Array<Int>, pf_n: Array<Int>) [IO] -> Unit {
    do teat(pf_g); // KW_FN
    let pf_fi: Int = nalloc(pf_g, pf_n);
    pf_n[pf_fi * 10] = 1;
    pf_n[pf_fi * 10 + 2] = tsoff(pf_g, pf_t);
    pf_n[pf_fi * 10 + 3] = tslen(pf_g, pf_t);
    do teat(pf_g); // fn name
    // Params
    do teat(pf_g); // LPAREN
    pf_g[15] = 0; pf_g[16] = 0 - 1; pf_g[17] = 0 - 1;
    for _pfp in range(0, 32) {
        match tcur(pf_g, pf_t) == 20 { true -> { }, false -> {
            let pf_pi: Int = nalloc(pf_g, pf_n);
            pf_n[pf_pi * 10] = 2;
            pf_n[pf_pi * 10 + 2] = tsoff(pf_g, pf_t);
            pf_n[pf_pi * 10 + 3] = tslen(pf_g, pf_t);
            do teat(pf_g); do teat(pf_g); // eat name, colon
            pf_g[136] = pf_t[pf_g[13] * 5 + 2]; pf_g[137] = pf_t[pf_g[13] * 5 + 1]; // type name len and offset
            do teat(pf_g); // eat type name
            // Type resolution: check for Array<T>, privacy wrappers, or plain types
            pf_g[40] = pf_g[137]; pf_g[41] = pf_g[136]; // set up name for chk_priv
            pf_g[4300] = chk_priv(pf_g, pf_n); // check if privacy wrapper (-1 if not)
            match tcur(pf_g, pf_t) == 31 { true -> match pf_g[4300] >= 0 {
                // Privacy wrapper: Sensitive<String>, Public<Int>, etc.
                true -> {
                    do teat(pf_g); // eat <
                    // Resolve inner base type
                    pf_g[4301] = pf_t[pf_g[13] * 5 + 2]; pf_g[4302] = pf_t[pf_g[13] * 5 + 1]; // inner type len, offset
                    do teat(pf_g); // eat inner type name
                    pf_g[4303] = match pf_g[4301] == 6 { true -> 2, false -> match pf_g[4301] == 5 { true -> match pf_n[200000 + pf_g[4302]] == 70 { true -> 7, false -> 0 }, false -> match pf_g[4301] == 4 { true -> match pf_n[200000 + pf_g[4302]] == 66 { true -> 1, false -> 0 }, false -> 0 } } }; // base type
                    // Check for , ZeroOnDrop before >
                    match tcur(pf_g, pf_t) == 42 { true -> { do teat(pf_g); do teat(pf_g); pf_g[4300] = 3; }, false -> { } }; // comma + ZeroOnDrop → level 3
                    do teat(pf_g); // eat >
                    pf_n[pf_pi * 10 + 7] = pf_g[4300] * 16 + pf_g[4303]; // compound encoding
                },
                // Check: is it a generic ADT (Option<Int>) or Array<T>?
                false -> { pf_g[40]=pf_g[137]; pf_g[41]=pf_g[136]; pf_g[4600] = chk_vari_type(pf_g, pf_n); match pf_g[4600] >= 0 { true -> match pf_g[1024 + pf_g[4600] * 64 + 20] > 0 {
                    // Generic ADT: monomorphize
                    true -> { do teat(pf_g); do teat(pf_g); match tcur(pf_g, pf_t) == 42 { true -> { do teat(pf_g); do teat(pf_g); }, false -> { } }; do teat(pf_g); let _mr: Int = monomorphize(pf_g, pf_n); pf_n[pf_pi * 10 + 7] = 6; },
                    // Array<T>
                    false -> { do teat(pf_g); do teat(pf_g); do teat(pf_g); pf_n[pf_pi * 10 + 7] = 4; }
                }, false -> { do teat(pf_g); do teat(pf_g); do teat(pf_g); pf_n[pf_pi * 10 + 7] = 4; } } }
            }, false -> { pf_n[pf_pi * 10 + 7] = match pf_g[136] == 6 { true -> 2, false -> match pf_g[136] == 5 { true -> match pf_n[200000 + pf_g[137]] == 70 { true -> 7, false -> { pf_g[40]=pf_g[137]; pf_g[41]=pf_g[136]; match chk_vari_type(pf_g, pf_n) >= 0 { true -> 6, false -> 0 } } }, false -> match pf_g[136] == 4 { true -> match pf_n[200000 + pf_g[137]] == 66 { true -> 1, false -> { pf_g[40]=pf_g[137]; pf_g[41]=pf_g[136]; match chk_vari_type(pf_g, pf_n) >= 0 { true -> 6, false -> 0 } } }, false -> { pf_g[40]=pf_g[137]; pf_g[41]=pf_g[136]; match chk_vari_type(pf_g, pf_n) >= 0 { true -> 6, false -> 0 } } } } }; } };
            match pf_g[16] == 0 - 1 { true -> { pf_g[16] = pf_pi; pf_g[17] = pf_pi; }, false -> { pf_n[pf_g[17] * 10 + 6] = pf_pi; pf_g[17] = pf_pi; } };
            pf_g[15] = pf_g[15] + 1;
            match tcur(pf_g, pf_t) == 42 { true -> { do teat(pf_g); }, false -> { } };
        } };
    };
    do teat(pf_g);
    pf_n[pf_fi * 10 + 4] = pf_g[15];
    pf_n[pf_fi * 10 + 5] = pf_g[16];
    // Effects: store bitmask in field 9 (0=pure, 1=IO)
    do teat(pf_g); // eat LBRACKET
    pf_n[pf_fi * 10 + 9] = 0;
    for _pfe in range(0, 16) { match tcur(pf_g, pf_t) == 22 { true -> { }, false -> {
        match tcur(pf_g, pf_t) == 13 { true -> {
            match tslen(pf_g, pf_t) == 2 { true -> { pf_n[pf_fi * 10 + 9] = pf_n[pf_fi * 10 + 9] + 1; }, false -> { } }; // IO = +1
            match tslen(pf_g, pf_t) == 5 { true -> { pf_n[pf_fi * 10 + 9] = pf_n[pf_fi * 10 + 9] + 2; }, false -> { } }; // Audit = +2
        }, false -> { } };
        do teat(pf_g);
    } }; };
    do teat(pf_g); // eat RBRACKET
    // Return type: store in field 7
    do teat(pf_g); // eat ARROW
    pf_g[136] = pf_t[pf_g[13] * 5 + 2]; pf_g[137] = pf_t[pf_g[13] * 5 + 1];
    do teat(pf_g); // eat return type name
    // Return type resolution (same pattern as param types)
    pf_g[40] = pf_g[137]; pf_g[41] = pf_g[136];
    pf_g[4300] = chk_priv(pf_g, pf_n);
    match tcur(pf_g, pf_t) == 31 { true -> match pf_g[4300] >= 0 {
        true -> {
            do teat(pf_g);
            pf_g[4301] = pf_t[pf_g[13] * 5 + 2]; pf_g[4302] = pf_t[pf_g[13] * 5 + 1];
            do teat(pf_g);
            pf_g[4303] = match pf_g[4301] == 6 { true -> 2, false -> match pf_g[4301] == 5 { true -> match pf_n[200000 + pf_g[4302]] == 70 { true -> 7, false -> 0 }, false -> match pf_g[4301] == 4 { true -> match pf_n[200000 + pf_g[4302]] == 66 { true -> 1, false -> 0 }, false -> 0 } } };
            match tcur(pf_g, pf_t) == 42 { true -> { do teat(pf_g); do teat(pf_g); pf_g[4300] = 3; }, false -> { } };
            do teat(pf_g);
            pf_n[pf_fi * 10 + 7] = pf_g[4300] * 16 + pf_g[4303];
        },
        false -> { pf_g[40]=pf_g[137]; pf_g[41]=pf_g[136]; pf_g[4600] = chk_vari_type(pf_g, pf_n); match pf_g[4600] >= 0 { true -> match pf_g[1024 + pf_g[4600] * 64 + 20] > 0 {
            true -> { do teat(pf_g); do teat(pf_g); match tcur(pf_g, pf_t) == 42 { true -> { do teat(pf_g); do teat(pf_g); }, false -> { } }; do teat(pf_g); let _mr2: Int = monomorphize(pf_g, pf_n); pf_n[pf_fi * 10 + 7] = 6; },
            false -> { do teat(pf_g); do teat(pf_g); do teat(pf_g); pf_n[pf_fi * 10 + 7] = 4; }
        }, false -> { do teat(pf_g); do teat(pf_g); do teat(pf_g); pf_n[pf_fi * 10 + 7] = 4; } } }
    }, false -> { pf_n[pf_fi * 10 + 7] = match pf_g[136] == 6 { true -> 2, false -> match pf_g[136] == 5 { true -> match pf_n[200000 + pf_g[137]] == 70 { true -> 7, false -> { pf_g[40]=pf_g[137]; pf_g[41]=pf_g[136]; match chk_vari_type(pf_g, pf_n) >= 0 { true -> 6, false -> 0 } } }, false -> match pf_g[136] == 4 { true -> match pf_n[200000 + pf_g[137]] == 66 { true -> 1, false -> { pf_g[40]=pf_g[137]; pf_g[41]=pf_g[136]; match chk_vari_type(pf_g, pf_n) >= 0 { true -> 6, false -> 0 } } }, false -> { pf_g[40]=pf_g[137]; pf_g[41]=pf_g[136]; match chk_vari_type(pf_g, pf_n) >= 0 { true -> 6, false -> 0 } } } } }; } };
    // Body — skip for extern functions
    match pf_g[4310] == 1 {
        true -> {
            // extern fn: no body, eat semicolon, set body = -1
            match tcur(pf_g, pf_t) == 41 { true -> { do teat(pf_g); }, false -> { } };
            pf_n[pf_fi * 10 + 8] = 0 - 1;
            pf_n[pf_fi * 10 + 9] = pf_n[pf_fi * 10 + 9] + 128; // mark as extern (bit 7)
        },
        false -> {
            let pf_bi: Int = pb_parse(pf_g, pf_t, pf_n);
            pf_n[pf_fi * 10 + 8] = pf_bi;
        },
    };
}

// Block parser
fn pb_parse(pb_g: Array<Int>, pb_t: Array<Int>, pb_n: Array<Int>) [IO] -> Int {
    do teat(pb_g);
    let pb_bi: Int = nalloc(pb_g, pb_n);
    pb_n[pb_bi * 10] = 3;
    pb_g[153]=pb_g[153]+1; pb_g[154]=180+pb_g[153]*3;
    pb_g[pb_g[154]]=pb_g[20]; pb_g[pb_g[154]+1]=pb_g[21]; pb_g[pb_g[154]+2]=pb_g[22];
    pb_g[20] = 0 - 1; pb_g[21] = 0 - 1; pb_g[22] = 0;
    for _pbs in range(0, 65536) {
        match tcur(pb_g, pb_t) == 18 { true -> { }, false -> match tcur(pb_g, pb_t) == 44 { true -> { }, false -> {
            match tcur(pb_g, pb_t) == 1 { true -> {
                pb_g[160]=pl_parse(pb_g, pb_t, pb_n);
                match pb_g[20]==0-1 { true -> { pb_g[20]=pb_g[160]; pb_g[21]=pb_g[160]; }, false -> { pb_n[pb_g[21]*10+6]=pb_g[160]; pb_g[21]=pb_g[160]; } };
                pb_g[22]=pb_g[22]+1;
            }, false -> match tcur(pb_g, pb_t) == 13 { true -> match pb_t[(pb_g[13]+1)*5]==21 { true -> match is_arr_set(pb_g, pb_t) { true -> {
                pb_g[160]=pas_parse(pb_g, pb_t, pb_n);
                match pb_g[20]==0-1 { true -> { pb_g[20]=pb_g[160]; pb_g[21]=pb_g[160]; }, false -> { pb_n[pb_g[21]*10+6]=pb_g[160]; pb_g[21]=pb_g[160]; } };
                pb_g[22]=pb_g[22]+1;
            }, false -> {
                pb_g[161]=pe_parse(pb_g, pb_t, pb_n);
                do pb_wrap_stmt(pb_g, pb_t, pb_n);
            } }, false -> match pb_t[(pb_g[13]+1)*5]==23 { true -> {
                // IDENT followed by ASSIGN (=) — immutable reassignment attempt
                do print("error: immutable reassignment — Loon bindings cannot be reassigned. Use Array(1) for mutable state.");
                do exit(1);
            }, false -> {
                pb_g[161]=pe_parse(pb_g, pb_t, pb_n);
                do pb_wrap_stmt(pb_g, pb_t, pb_n);
            } } }, false -> {
                pb_g[161]=pe_parse(pb_g, pb_t, pb_n);
                do pb_wrap_stmt(pb_g, pb_t, pb_n);
            } } };
        } } };
    };
    do teat(pb_g);
    pb_n[pb_bi * 10 + 4] = pb_g[22];
    pb_n[pb_bi * 10 + 5] = pb_g[20];
    pb_g[154]=180+pb_g[153]*3;
    pb_g[20]=pb_g[pb_g[154]]; pb_g[21]=pb_g[pb_g[154]+1]; pb_g[22]=pb_g[pb_g[154]+2];
    pb_g[153]=pb_g[153]-1;
    pb_bi
}

// Wrap expression as EXPR_STMT or RETURN_EXPR. g[161]=expr node. Checks for semicolon.
fn pb_wrap_stmt(pw_g: Array<Int>, pw_t: Array<Int>, pw_n: Array<Int>) [] -> Unit {
    match tcur(pw_g, pw_t) == 41 { true -> {
        do teat(pw_g); pw_g[162]=nalloc(pw_g, pw_n); pw_n[pw_g[162]*10]=5; pw_n[pw_g[162]*10+4]=1; pw_n[pw_g[162]*10+5]=pw_g[161];
        match pw_g[20]==0-1 { true -> { pw_g[20]=pw_g[162]; pw_g[21]=pw_g[162]; }, false -> { pw_n[pw_g[21]*10+6]=pw_g[162]; pw_g[21]=pw_g[162]; } };
        pw_g[22]=pw_g[22]+1;
    }, false -> {
        pw_g[162]=nalloc(pw_g, pw_n); pw_n[pw_g[162]*10]=6; pw_n[pw_g[162]*10+4]=1; pw_n[pw_g[162]*10+5]=pw_g[161];
        match pw_g[20]==0-1 { true -> { pw_g[20]=pw_g[162]; pw_g[21]=pw_g[162]; }, false -> { pw_n[pw_g[21]*10+6]=pw_g[162]; pw_g[21]=pw_g[162]; } };
        pw_g[22]=pw_g[22]+1;
    } };
}

// Let binding parser
// Check if IDENT LBRACKET ... RBRACKET ASSIGN pattern
fn is_arr_set(ia_g: Array<Int>, ia_t: Array<Int>) [] -> Bool {
    let ia_p: Array<Int> = Array(1); ia_p[0] = ia_g[13] + 2;
    let ia_d: Array<Int> = Array(1); ia_d[0] = 1;
    for _ia in range(0, 256) {
        match ia_d[0] == 0 { true -> { }, false -> {
            ia_g[136] = ia_t[ia_p[0] * 5];
            match ia_g[136] == 21 { true -> { ia_d[0] = ia_d[0] + 1; }, false -> { } };
            match ia_g[136] == 22 { true -> { ia_d[0] = ia_d[0] - 1; }, false -> { } };
            ia_p[0] = ia_p[0] + 1;
        } };
    };
    match ia_t[ia_p[0] * 5] == 23 { true -> true, false -> false }
}

// Parse ARRAY_SET: IDENT [ expr ] = expr ;
fn pas_parse(as_g: Array<Int>, as_t: Array<Int>, as_n: Array<Int>) [IO] -> Int {
    let as_ai: Int = nalloc(as_g, as_n);
    as_n[as_ai * 10] = 21;
    as_n[as_ai * 10 + 2] = tsoff(as_g, as_t);
    as_n[as_ai * 10 + 3] = tslen(as_g, as_t);
    do teat(as_g); // IDENT
    do teat(as_g); // LBRACKET
    let as_idx: Int = pe_parse(as_g, as_t, as_n);
    do teat(as_g); // RBRACKET
    do teat(as_g); // ASSIGN
    let as_val: Int = pe_parse(as_g, as_t, as_n);
    do teat(as_g); // SEMICOLON
    as_n[as_ai * 10 + 4] = 2;
    as_n[as_ai * 10 + 5] = as_idx;
    as_n[as_idx * 10 + 6] = as_val;
    as_ai
}

// pl_parse — parse let binding with type annotation and initializer
fn pl_parse(pl_g: Array<Int>, pl_t: Array<Int>, pl_n: Array<Int>) [IO] -> Int {
    do teat(pl_g);
    let pl_li: Int = nalloc(pl_g, pl_n);
    pl_n[pl_li * 10] = 4;
    pl_n[pl_li * 10 + 2] = tsoff(pl_g, pl_t);
    pl_n[pl_li * 10 + 3] = tslen(pl_g, pl_t);
    do teat(pl_g);
    match tcur(pl_g, pl_t) == 40 { true -> { do teat(pl_g); pl_g[136]=pl_t[pl_g[13]*5+2]; pl_g[137]=pl_t[pl_g[13]*5+1]; do teat(pl_g); pl_n[pl_li*10+9]=1; pl_g[40]=pl_g[137]; pl_g[41]=pl_g[136]; pl_g[4300]=chk_priv(pl_g, pl_n); match tcur(pl_g, pl_t) == 31 { true -> match pl_g[4300] >= 0 { true -> { do teat(pl_g); pl_g[4301]=pl_t[pl_g[13]*5+2]; pl_g[4302]=pl_t[pl_g[13]*5+1]; do teat(pl_g); pl_g[4303]=match pl_g[4301]==6 { true -> 2, false -> match pl_g[4301]==5 { true -> match pl_n[200000+pl_g[4302]]==70 { true -> 7, false -> 0 }, false -> match pl_g[4301]==4 { true -> match pl_n[200000+pl_g[4302]]==66 { true -> 1, false -> 0 }, false -> 0 } } }; match tcur(pl_g, pl_t)==42 { true -> { do teat(pl_g); do teat(pl_g); pl_g[4300]=3; }, false -> { } }; do teat(pl_g); pl_n[pl_li*10+7]=pl_g[4300]*16+pl_g[4303]; }, false -> { pl_g[40]=pl_g[137]; pl_g[41]=pl_g[136]; pl_g[4600]=chk_vari_type(pl_g, pl_n); match pl_g[4600] >= 0 { true -> match pl_g[1024+pl_g[4600]*64+20] > 0 { true -> { do teat(pl_g); do teat(pl_g); match tcur(pl_g,pl_t)==42 { true -> { do teat(pl_g); do teat(pl_g); }, false -> { } }; do teat(pl_g); let _plm: Int = monomorphize(pl_g, pl_n); pl_n[pl_li*10+7]=6; }, false -> { do teat(pl_g); do teat(pl_g); do teat(pl_g); pl_n[pl_li*10+7]=4; } }, false -> { do teat(pl_g); do teat(pl_g); do teat(pl_g); pl_n[pl_li*10+7]=4; } } } }, false -> { pl_n[pl_li*10+7] = match pl_g[136]==6 { true -> 2, false -> match pl_g[136]==5 { true -> match pl_n[200000+pl_g[137]]==70 { true -> 7, false -> 0 }, false -> match pl_g[136]==4 { true -> match pl_n[200000+pl_g[137]]==66 { true -> 1, false -> 0 }, false -> 0 } } }; } }; }, false -> { } };
    do teat(pl_g);
    let pl_vi: Int = pe_parse(pl_g, pl_t, pl_n);
    pl_n[pl_li * 10 + 4] = 1; pl_n[pl_li * 10 + 5] = pl_vi;
    do teat(pl_g);
    pl_li
}

// Expression entry
fn pe_parse(pe_g: Array<Int>, pe_t: Array<Int>, pe_n: Array<Int>) [IO] -> Int {
    let pe_tt: Int = tcur(pe_g, pe_t);
    match pe_tt == 3 { true -> pm_parse(pe_g, pe_t, pe_n),
    false -> match pe_tt == 4 { true -> pfor_parse(pe_g, pe_t, pe_n),
    
    false -> ppipe_parse(pe_g, pe_t, pe_n) } }
}

// Level 0: |> (pipe) — desugars a |> f to f(a)
// Parse lambda: fn(params) effects -> RetType { body }
// Lambda lifting: creates a top-level FN_DECL with generated name _lam_N
// Returns: IDENT_REF node pointing to the generated function name
fn plambda_parse(pl2_g: Array<Int>, pl2_t: Array<Int>, pl2_n: Array<Int>) [IO] -> Int {
    do teat(pl2_g); // eat KW_FN
    // Generate unique name: _lam_N in the string table
    let pl2_lam_id: Int = pl2_g[49]; pl2_g[49] = pl2_g[49] + 1;
    let pl2_name_off: Int = pl2_g[5];
    // Write "_lam_" to string table
    pl2_n[200000 + pl2_g[5]] = 95; pl2_g[5] = pl2_g[5] + 1; // _
    pl2_n[200000 + pl2_g[5]] = 108; pl2_g[5] = pl2_g[5] + 1; // l
    pl2_n[200000 + pl2_g[5]] = 97; pl2_g[5] = pl2_g[5] + 1; // a
    pl2_n[200000 + pl2_g[5]] = 109; pl2_g[5] = pl2_g[5] + 1; // m
    pl2_n[200000 + pl2_g[5]] = 95; pl2_g[5] = pl2_g[5] + 1; // _
    // Write the ID digits
    let pl2_id_str: String = int_to_string(pl2_lam_id);
    let pl2_id_len: Int = string_length(pl2_id_str);
    for pl2_di in range(0, pl2_id_len) {
        pl2_n[200000 + pl2_g[5]] = string_char_at(pl2_id_str, pl2_di);
        pl2_g[5] = pl2_g[5] + 1;
    };
    let pl2_name_len: Int = pl2_g[5] - pl2_name_off;
    // Create FN_DECL node for the lambda
    let pl2_fn_ni: Int = nalloc(pl2_g, pl2_n);
    pl2_n[pl2_fn_ni * 10] = 1; // NODE_FN_DECL
    pl2_n[pl2_fn_ni * 10 + 2] = pl2_name_off;
    pl2_n[pl2_fn_ni * 10 + 3] = pl2_name_len;
    // Parse params: (param: Type, ...)
    do teat(pl2_g); // eat (
    let pl2_pc: Array<Int> = Array(1); pl2_pc[0] = 0;
    let pl2_first_p: Array<Int> = Array(1); pl2_first_p[0] = 0 - 1;
    let pl2_last_p: Array<Int> = Array(1); pl2_last_p[0] = 0 - 1;
    for _plp in range(0, 16) {
        match tcur(pl2_g, pl2_t) == 20 { true -> { }, false -> match tcur(pl2_g, pl2_t) == 44 { true -> { }, false -> {
            // Parse one param
            let pl2_pi: Int = nalloc(pl2_g, pl2_n);
            pl2_n[pl2_pi * 10] = 2; // NODE_PARAM
            pl2_n[pl2_pi * 10 + 2] = tsoff(pl2_g, pl2_t);
            pl2_n[pl2_pi * 10 + 3] = tslen(pl2_g, pl2_t);
            do teat(pl2_g); // eat param name
            match tcur(pl2_g, pl2_t) == 40 { true -> { do teat(pl2_g); }, false -> { } }; // eat :
            // Parse type (simple: just eat the type name)
            pl2_n[pl2_pi * 10 + 7] = 0; // default Int
            match tslen(pl2_g, pl2_t) == 6 { true -> { pl2_n[pl2_pi * 10 + 7] = 2; }, false -> { } }; // String
            do teat(pl2_g); // eat type name
            match tcur(pl2_g, pl2_t) == 42 { true -> { do teat(pl2_g); }, false -> { } }; // eat ,
            match pl2_first_p[0] == 0 - 1 { true -> { pl2_first_p[0] = pl2_pi; }, false -> { pl2_n[pl2_last_p[0] * 10 + 6] = pl2_pi; } };
            pl2_last_p[0] = pl2_pi;
            pl2_pc[0] = pl2_pc[0] + 1;
        } } };
    };
    match tcur(pl2_g, pl2_t) == 20 { true -> { do teat(pl2_g); }, false -> { } }; // eat )
    pl2_n[pl2_fn_ni * 10 + 4] = pl2_pc[0];
    pl2_n[pl2_fn_ni * 10 + 5] = pl2_first_p[0];
    // Parse effects: [IO] or []
    match tcur(pl2_g, pl2_t) == 21 { true -> { do teat(pl2_g); // eat [
        match tcur(pl2_g, pl2_t) == 22 { true -> { do teat(pl2_g); }, false -> { do teat(pl2_g); do teat(pl2_g); } }; // eat effects + ]
    }, false -> { } };
    // Parse -> RetType
    match tcur(pl2_g, pl2_t) == 38 { true -> { do teat(pl2_g); // eat ->
        pl2_n[pl2_fn_ni * 10 + 7] = 0; // default Int return
        match tslen(pl2_g, pl2_t) == 6 { true -> { pl2_n[pl2_fn_ni * 10 + 7] = 2; }, false -> { } }; // String
        do teat(pl2_g); // eat return type
    }, false -> { } };
    // Parse body block
    let pl2_body: Int = pb_parse(pl2_g, pl2_t, pl2_n);
    pl2_n[pl2_fn_ni * 10 + 8] = pl2_body; // extra = body block
    // Return IDENT_REF to the generated name (function reference)
    let pl2_ref: Int = nalloc(pl2_g, pl2_n);
    pl2_n[pl2_ref * 10] = 10; // NODE_IDENT_REF
    pl2_n[pl2_ref * 10 + 2] = pl2_name_off;
    pl2_n[pl2_ref * 10 + 3] = pl2_name_len;
    pl2_ref
}

fn ppipe_parse(pp2_g: Array<Int>, pp2_t: Array<Int>, pp2_n: Array<Int>) [IO] -> Int {
    let pp2_l: Array<Int> = Array(1); pp2_l[0] = por_parse(pp2_g, pp2_t, pp2_n);
    for _pp2 in range(0, 256) { match tcur(pp2_g, pp2_t) == 39 { true -> {
        do teat(pp2_g); // eat |>
        let pp2_fn_off: Int = tsoff(pp2_g, pp2_t);
        let pp2_fn_len: Int = tslen(pp2_g, pp2_t);
        do teat(pp2_g); // eat function name
        let pp2_ci: Int = nalloc(pp2_g, pp2_n);
        pp2_n[pp2_ci * 10] = 14; pp2_n[pp2_ci * 10 + 2] = pp2_fn_off;
        pp2_n[pp2_ci * 10 + 3] = pp2_fn_len; pp2_n[pp2_ci * 10 + 4] = 1;
        pp2_n[pp2_ci * 10 + 5] = pp2_l[0];
        pp2_l[0] = pp2_ci;
    }, false -> { } }; };
    pp2_l[0]
}

// Level 1: ||
fn por_parse(po_g: Array<Int>, po_t: Array<Int>, po_n: Array<Int>) [IO] -> Int {
    let po_l: Array<Int> = Array(1); po_l[0] = pand_parse(po_g, po_t, po_n);
    for _po in range(0, 256) { match tcur(po_g, po_t) == 36 { true -> { do teat(po_g); po_g[134] = pand_parse(po_g, po_t, po_n); po_g[18] = po_l[0]; po_g[19] = po_g[134]; po_l[0] = mkbin(po_g, po_n, 12); }, false -> { } }; }; po_l[0]
}
// pand_parse — parse AND/OR boolean operators (lowest precedence)
fn pand_parse(pa_g: Array<Int>, pa_t: Array<Int>, pa_n: Array<Int>) [IO] -> Int {
    let pa_l: Array<Int> = Array(1); pa_l[0] = pcmp_parse(pa_g, pa_t, pa_n);
    for _pa in range(0, 256) { match tcur(pa_g, pa_t) == 35 { true -> { do teat(pa_g); pa_g[135] = pcmp_parse(pa_g, pa_t, pa_n); pa_g[18] = pa_l[0]; pa_g[19] = pa_g[135]; pa_l[0] = mkbin(pa_g, pa_n, 11); }, false -> { } }; }; pa_l[0]
}
// Level 3: comparison (non-chainable)
fn pcmp_parse(pc_g: Array<Int>, pc_t: Array<Int>, pc_n: Array<Int>) [IO] -> Int {
    let pc_l: Int = padd_parse(pc_g, pc_t, pc_n);
    let pc_tt: Int = tcur(pc_g, pc_t);
    match pc_tt >= 29 { true -> match pc_tt <= 34 { true -> { do teat(pc_g); let pc_r: Int = padd_parse(pc_g, pc_t, pc_n); { pc_g[18] = pc_l; pc_g[19] = pc_r; mkbin(pc_g, pc_n, pc_tt - 29 + 5) } }, false -> pc_l }, false -> pc_l }
}
// Level 4: + -
fn padd_parse(pd_g: Array<Int>, pd_t: Array<Int>, pd_n: Array<Int>) [IO] -> Int {
    let pd_l: Array<Int> = Array(1); pd_l[0] = pmul_parse(pd_g, pd_t, pd_n);
    for _pd in range(0, 256) { pd_g[130] = tcur(pd_g, pd_t); match pd_g[130] == 24 { true -> { do teat(pd_g); pd_g[131] = pmul_parse(pd_g, pd_t, pd_n); pd_g[18] = pd_l[0]; pd_g[19] = pd_g[131]; pd_l[0] = mkbin(pd_g, pd_n, 0); }, false -> match pd_g[130] == 25 { true -> { do teat(pd_g); pd_g[131] = pmul_parse(pd_g, pd_t, pd_n); pd_g[18] = pd_l[0]; pd_g[19] = pd_g[131]; pd_l[0] = mkbin(pd_g, pd_n, 1); }, false -> { } } }; }; pd_l[0]
}
// Level 5: * / %
fn pmul_parse(pm_g: Array<Int>, pm_t: Array<Int>, pm_n: Array<Int>) [IO] -> Int {
    let pm_l: Array<Int> = Array(1); pm_l[0] = pun_parse(pm_g, pm_t, pm_n);
    for _pm in range(0, 256) { pm_g[132] = tcur(pm_g, pm_t); match pm_g[132] == 26 { true -> { do teat(pm_g); pm_g[133] = pun_parse(pm_g, pm_t, pm_n); pm_g[18] = pm_l[0]; pm_g[19] = pm_g[133]; pm_l[0] = mkbin(pm_g, pm_n, 2); }, false -> match pm_g[132] == 27 { true -> { do teat(pm_g); pm_g[133] = pun_parse(pm_g, pm_t, pm_n); pm_g[18] = pm_l[0]; pm_g[19] = pm_g[133]; pm_l[0] = mkbin(pm_g, pm_n, 3); }, false -> match pm_g[132] == 28 { true -> { do teat(pm_g); pm_g[133] = pun_parse(pm_g, pm_t, pm_n); pm_g[18] = pm_l[0]; pm_g[19] = pm_g[133]; pm_l[0] = mkbin(pm_g, pm_n, 4); }, false -> { } } } }; }; pm_l[0]
}
// Level 6: unary ! - do
fn pun_parse(pu_g: Array<Int>, pu_t: Array<Int>, pu_n: Array<Int>) [IO] -> Int {
    let pu_tt: Int = tcur(pu_g, pu_t);
    match pu_tt == 37 { true -> { do teat(pu_g); let pu_c1: Int = pun_parse(pu_g, pu_t, pu_n); let pu_n1: Int = nalloc(pu_g, pu_n); pu_n[pu_n1*10]=12; pu_n[pu_n1*10+4]=1; pu_n[pu_n1*10+5]=pu_c1; pu_n1 },
    false -> match pu_tt == 25 { true -> { do teat(pu_g); let pu_c2: Int = pun_parse(pu_g, pu_t, pu_n); let pu_n2: Int = nalloc(pu_g, pu_n); pu_n[pu_n2*10]=13; pu_n[pu_n2*10+4]=1; pu_n[pu_n2*10+5]=pu_c2; pu_n2 },
    false -> match pu_tt == 6 { true -> { do teat(pu_g); let pu_c3: Int = ppf_parse(pu_g, pu_t, pu_n); let pu_n3: Int = nalloc(pu_g, pu_n); pu_n[pu_n3*10]=15; pu_n[pu_n3*10+4]=1; pu_n[pu_n3*10+5]=pu_c3; pu_n3 },
    false -> ppf_parse(pu_g, pu_t, pu_n) } } }
}
// Level 7: postfix f() arr[i]
fn ppf_parse(pf2_g: Array<Int>, pf2_t: Array<Int>, pf2_n: Array<Int>) [IO] -> Int {
    let pf2_b: Array<Int> = Array(1); pf2_b[0] = ppri_parse(pf2_g, pf2_t, pf2_n);
    for _pf2 in range(0, 256) { match tcur(pf2_g, pf2_t) == 21 { true -> { do teat(pf2_g); let pf2_idx: Int = pe_parse(pf2_g, pf2_t, pf2_n); do teat(pf2_g); let pf2_ni: Int = nalloc(pf2_g, pf2_n); pf2_n[pf2_ni*10]=20; pf2_n[pf2_ni*10+2]=pf2_n[pf2_b[0]*10+2]; pf2_n[pf2_ni*10+3]=pf2_n[pf2_b[0]*10+3]; pf2_n[pf2_ni*10+4]=1; pf2_n[pf2_ni*10+5]=pf2_idx; pf2_b[0] = pf2_ni; }, false -> { } }; }; pf2_b[0]
}
// Primary
fn ppri_parse(pr_g: Array<Int>, pr_t: Array<Int>, pr_n: Array<Int>) [IO] -> Int {
    let pr_tt: Int = tcur(pr_g, pr_t);
    match pr_tt == 14 { true -> { let pr_i1: Int = nalloc(pr_g, pr_n); pr_n[pr_i1*10]=7; pr_n[pr_i1*10+2]=tsoff(pr_g,pr_t); pr_n[pr_i1*10+3]=tslen(pr_g,pr_t); do teat(pr_g); pr_i1 },
    false -> match pr_tt == 15 { true -> { let pr_f1: Int = nalloc(pr_g, pr_n); pr_n[pr_f1*10]=7; pr_n[pr_f1*10+2]=tsoff(pr_g,pr_t); pr_n[pr_f1*10+3]=tslen(pr_g,pr_t); pr_n[pr_f1*10+7]=7; do teat(pr_g); pr_f1 },
    false -> match pr_tt == 16 { true -> { let pr_s1: Int = nalloc(pr_g, pr_n); pr_n[pr_s1*10]=8; pr_n[pr_s1*10+2]=tsoff(pr_g,pr_t); pr_n[pr_s1*10+3]=tslen(pr_g,pr_t); pr_n[pr_s1*10+7]=2; do teat(pr_g); pr_s1 },
    false -> match pr_tt == 11 { true -> { let pr_b1: Int = nalloc(pr_g, pr_n); pr_n[pr_b1*10]=9; pr_n[pr_b1*10+8]=1; do teat(pr_g); pr_b1 },
    false -> match pr_tt == 12 { true -> { let pr_b2: Int = nalloc(pr_g, pr_n); pr_n[pr_b2*10]=9; pr_n[pr_b2*10+8]=0; do teat(pr_g); pr_b2 },
    false -> match pr_tt == 19 { true -> { do teat(pr_g); let pr_ei: Int = pe_parse(pr_g, pr_t, pr_n); do teat(pr_g); pr_ei },
    false -> match pr_tt == 17 { true -> pb_parse(pr_g, pr_t, pr_n),
    false -> match pr_tt == 0 { true -> plam_parse(pr_g, pr_t, pr_n),
    false -> pic_parse(pr_g, pr_t, pr_n) } } } } } } } }
}
// Convert a CALL node to VARIANT_CONSTRUCT if name matches a variant
// Parse lambda expression: fn(params) effects -> RetType { body }
// Creates NODE_LAMBDA (28) with params as children, body in extra field
// The generated name _lam_N is stored in the string table for codegen
fn plam_parse(pl_g: Array<Int>, pl_t: Array<Int>, pl_n: Array<Int>) [IO] -> Int {
    do teat(pl_g); // eat KW_FN
    let pl_ni: Int = nalloc(pl_g, pl_n);
    pl_n[pl_ni * 10] = 28; // NODE_LAMBDA
    // Generate name: _lam_N in string table at gn[200000+]
    let pl_name_off: Int = pl_g[5];
    pl_n[200000 + pl_g[5]] = 95; pl_g[5] = pl_g[5] + 1;  // _
    pl_n[200000 + pl_g[5]] = 108; pl_g[5] = pl_g[5] + 1; // l
    pl_n[200000 + pl_g[5]] = 97; pl_g[5] = pl_g[5] + 1;  // a
    pl_n[200000 + pl_g[5]] = 109; pl_g[5] = pl_g[5] + 1; // m
    pl_n[200000 + pl_g[5]] = 95; pl_g[5] = pl_g[5] + 1;  // _
    let pl_id: Int = pl_g[49]; pl_g[49] = pl_g[49] + 1;
    let pl_ids: String = int_to_string(pl_id);
    let pl_idl: Int = string_length(pl_ids);
    for pl_di in range(0, pl_idl) { pl_n[200000 + pl_g[5]] = string_char_at(pl_ids, pl_di); pl_g[5] = pl_g[5] + 1; };
    let pl_name_len: Int = pl_g[5] - pl_name_off;
    pl_n[pl_ni * 10 + 2] = pl_name_off;
    pl_n[pl_ni * 10 + 3] = pl_name_len;
    // Parse params: (name: Type, ...)
    do teat(pl_g); // eat (
    let pl_pc: Array<Int> = Array(1); pl_pc[0] = 0;
    let pl_fp: Array<Int> = Array(1); pl_fp[0] = 0 - 1;
    let pl_lp: Array<Int> = Array(1); pl_lp[0] = 0 - 1;
    for _plp in range(0, 8) {
        match tcur(pl_g, pl_t) == 20 { true -> { }, false -> match tcur(pl_g, pl_t) == 44 { true -> { }, false -> {
            let pl_pi: Int = nalloc(pl_g, pl_n);
            pl_n[pl_pi * 10] = 2; // NODE_PARAM
            pl_n[pl_pi * 10 + 2] = tsoff(pl_g, pl_t);
            pl_n[pl_pi * 10 + 3] = tslen(pl_g, pl_t);
            do teat(pl_g); // eat param name
            match tcur(pl_g, pl_t) == 40 { true -> { do teat(pl_g); }, false -> { } }; // eat :
            // Parse type annotation
            pl_n[pl_pi * 10 + 7] = 0; // default Int
            let pl_tlen: Int = tslen(pl_g, pl_t);
            match pl_tlen == 6 { true -> { pl_n[pl_pi * 10 + 7] = 2; }, false -> { } }; // String=6 chars
            match pl_tlen == 4 { true -> match pl_n[200000 + tsoff(pl_g, pl_t)] == 66 { true -> { pl_n[pl_pi * 10 + 7] = 1; }, false -> { } }, false -> { } }; // Bool
            do teat(pl_g); // eat type name
            match tcur(pl_g, pl_t) == 42 { true -> { do teat(pl_g); }, false -> { } }; // eat ,
            match pl_fp[0] == 0 - 1 { true -> { pl_fp[0] = pl_pi; }, false -> { pl_n[pl_lp[0] * 10 + 6] = pl_pi; } };
            pl_lp[0] = pl_pi; pl_pc[0] = pl_pc[0] + 1;
        } } };
    };
    match tcur(pl_g, pl_t) == 20 { true -> { do teat(pl_g); }, false -> { } }; // eat )
    pl_n[pl_ni * 10 + 4] = pl_pc[0]; // child_count = param count
    pl_n[pl_ni * 10 + 5] = pl_fp[0]; // first_child = first param
    // Parse effects: [IO] or []
    pl_n[pl_ni * 10 + 9] = 0; // default: no effects
    match tcur(pl_g, pl_t) == 21 { true -> {
        do teat(pl_g); // eat [
        match tcur(pl_g, pl_t) == 22 { true -> { do teat(pl_g); }, // empty []
        false -> { pl_n[pl_ni * 10 + 9] = 1; do teat(pl_g); do teat(pl_g); } }; // [IO] etc
    }, false -> { } };
    // Parse -> RetType
    pl_n[pl_ni * 10 + 7] = 0; // default Int return
    match tcur(pl_g, pl_t) == 38 { true -> {
        do teat(pl_g); // eat ->
        let pl_rlen: Int = tslen(pl_g, pl_t);
        match pl_rlen == 6 { true -> { pl_n[pl_ni * 10 + 7] = 2; }, false -> { } }; // String
        do teat(pl_g); // eat return type
    }, false -> { } };
    // Parse body block
    let pl_body: Int = pb_parse(pl_g, pl_t, pl_n);
    pl_n[pl_ni * 10 + 8] = pl_body; // extra = body block
    pl_ni
}

fn pic_to_vari(pv_g: Array<Int>, pv_n: Array<Int>, pv_ci: Int) [] -> Unit {
    pv_g[40]=pv_n[pv_ci*10+2]; pv_g[41]=pv_n[pv_ci*10+3];
    let pv_vr: Int = chk_vari(pv_g, pv_n);
    match pv_vr >= 0 { true -> {
        pv_n[pv_ci*10]=24; // NODE_VARIANT_CONSTRUCT
        pv_n[pv_ci*10+1]=pv_vr - (pv_vr / 256) * 256; // sub_type = tag
        pv_n[pv_ci*10+8]=pv_vr / 256; // extra = type index
    }, false -> { } };
}

// Zero-field variant constructor (uppercase ident, no parens)
fn pic_zero_vari(pz_g: Array<Int>, pz_n: Array<Int>) [] -> Int {
    let pz_so: Int = pz_g[47]; let pz_sl: Int = pz_g[48];
    pz_g[40]=pz_so; pz_g[41]=pz_sl;
    let pz_vr: Int = chk_vari(pz_g, pz_n);
    match pz_vr >= 0 { true -> {
        let pz_vi: Int = nalloc(pz_g, pz_n);
        pz_n[pz_vi*10]=24; pz_n[pz_vi*10+2]=pz_so; pz_n[pz_vi*10+3]=pz_sl;
        pz_n[pz_vi*10+1]=pz_vr - (pz_vr / 256) * 256;
        pz_n[pz_vi*10+4]=0; pz_n[pz_vi*10+8]=pz_vr / 256;
        pz_vi
    }, false -> {
        let pz_ni: Int = nalloc(pz_g, pz_n); pz_n[pz_ni*10]=10; pz_n[pz_ni*10+2]=pz_so; pz_n[pz_ni*10+3]=pz_sl; pz_ni
    } }
}

// Combine qualified name: module.func → single name in string table
fn pic_qualify(pq_g: Array<Int>, pq_t: Array<Int>, pq_n: Array<Int>) [] -> Unit {
    // g[47]=first ident off, g[48]=first ident len, current token=second ident
    let pq_dst: Int = pq_g[5]; // write combined name at end of string table
    // Copy first part (module name)
    for pq_i in range(0, pq_g[48]) { pq_n[200000 + pq_dst + pq_i] = pq_n[200000 + pq_g[47] + pq_i]; };
    // Add dot
    pq_n[200000 + pq_dst + pq_g[48]] = 46;
    // Copy second part (function name)
    let pq_so2: Int = tsoff(pq_g, pq_t); let pq_sl2: Int = tslen(pq_g, pq_t);
    for pq_j in range(0, pq_sl2) { pq_n[200000 + pq_dst + pq_g[48] + 1 + pq_j] = pq_n[200000 + pq_so2 + pq_j]; };
    // Update g[47]/g[48] to point to combined name
    pq_g[47] = pq_dst; pq_g[48] = pq_g[48] + 1 + pq_sl2;
    pq_g[5] = pq_g[5] + pq_g[48]; // advance string table
}

// Ident or call
fn pic_parse(pi_g: Array<Int>, pi_t: Array<Int>, pi_n: Array<Int>) [IO] -> Int {
    pi_g[47] = tsoff(pi_g, pi_t); pi_g[48] = tslen(pi_g, pi_t);
    do teat(pi_g);
    // Handle qualified name: ident.ident
    match tcur(pi_g, pi_t) == 43 { true -> {
        do teat(pi_g); // eat DOT
        do pic_qualify(pi_g, pi_t, pi_n);
        do teat(pi_g); // eat second ident
    }, false -> { } };
    // Check if uppercase (variant constructor)
    let pi_fc: Int = pi_n[200000 + pi_g[47]];
    let pi_upper: Int = match pi_fc >= 65 { true -> match pi_fc <= 90 { true -> 1, false -> 0 }, false -> 0 };
    match tcur(pi_g, pi_t) == 19 { true -> {
        do teat(pi_g);
        let pi_ci: Int = nalloc(pi_g, pi_n); pi_n[pi_ci*10]=14; pi_n[pi_ci*10+2]=pi_g[47]; pi_n[pi_ci*10+3]=pi_g[48];
        pi_g[112]=pi_g[23]; pi_g[113]=pi_g[24]; pi_g[114]=pi_g[25];
        pi_g[23]=0-1; pi_g[24]=0-1; pi_g[25]=0;
        for _pia in range(0, 32) { match tcur(pi_g, pi_t) == 20 { true -> { }, false -> {
            pi_g[110]=pe_parse(pi_g, pi_t, pi_n);
            match pi_g[23]==0-1 { true -> { pi_g[23]=pi_g[110]; pi_g[24]=pi_g[110]; }, false -> { pi_n[pi_g[24]*10+6]=pi_g[110]; pi_g[24]=pi_g[110]; } };
            pi_g[25]=pi_g[25]+1;
            match tcur(pi_g, pi_t)==42 { true -> { do teat(pi_g); }, false -> { } };
        } }; };
        do teat(pi_g);
        pi_n[pi_ci*10+4]=pi_g[25]; pi_n[pi_ci*10+5]=pi_g[23];
        pi_g[23]=pi_g[112]; pi_g[24]=pi_g[113]; pi_g[25]=pi_g[114];
        match pi_upper == 1 { true -> do pic_to_vari(pi_g, pi_n, pi_ci), false -> { } };
        pi_ci
    }, false -> {
        match pi_upper == 1 { true -> pic_zero_vari(pi_g, pi_n),
        false -> { let pi_ni: Int = nalloc(pi_g, pi_n); pi_n[pi_ni*10]=10; pi_n[pi_ni*10+2]=pi_g[47]; pi_n[pi_ni*10+3]=pi_g[48]; pi_ni } }
    } }
}
// ADT match arm helper: VariantName or VariantName(binding, ...) -> expr
fn pm_adt_arm(pa_g: Array<Int>, pa_t: Array<Int>, pa_n: Array<Int>) [IO] -> Unit {
    let pa_ai: Int = nalloc(pa_g, pa_n); pa_n[pa_ai*10]=25;
    pa_n[pa_ai*10+2]=tsoff(pa_g,pa_t); pa_n[pa_ai*10+3]=tslen(pa_g,pa_t);
    pa_g[40]=tsoff(pa_g,pa_t); pa_g[41]=tslen(pa_g,pa_t);
    let pa_vr: Int = chk_vari(pa_g, pa_n);
    pa_n[pa_ai*10+1] = match pa_vr >= 0 { true -> pa_vr - (pa_vr / 256) * 256, false -> 0 };
    pa_n[pa_ai*10+7] = match pa_vr >= 0 { true -> pa_vr / 256, false -> 0 };
    let pa_fct: Int = match pa_vr >= 0 { true -> pa_g[1024 + (pa_vr / 256) * 64 + 3 + (pa_vr - (pa_vr / 256) * 256) * 3 + 2], false -> 0 };
    pa_n[pa_ai*10+8] = pa_fct;
    do teat(pa_g);
    let pa_bfc: Array<Int> = Array(1); pa_bfc[0] = 0 - 1;
    let pa_blc: Array<Int> = Array(1); pa_blc[0] = 0 - 1;
    let pa_bc: Array<Int> = Array(1); pa_bc[0] = 0;
    match tcur(pa_g, pa_t) == 19 { true -> {
        do teat(pa_g);
        for _pab in range(0, 16) { match tcur(pa_g, pa_t) == 20 { true -> { }, false -> {
            let pa_bi: Int = nalloc(pa_g, pa_n);
            pa_n[pa_bi*10]=2; pa_n[pa_bi*10+2]=tsoff(pa_g,pa_t); pa_n[pa_bi*10+3]=tslen(pa_g,pa_t);
            do teat(pa_g);
            match pa_bfc[0] == 0 - 1 { true -> { pa_bfc[0] = pa_bi; pa_blc[0] = pa_bi; }, false -> { pa_n[pa_blc[0]*10+6] = pa_bi; pa_blc[0] = pa_bi; } };
            pa_bc[0] = pa_bc[0] + 1;
            match tcur(pa_g, pa_t) == 42 { true -> { do teat(pa_g); }, false -> { } };
        } }; };
        do teat(pa_g);
    }, false -> { } };
    do teat(pa_g);
    let pa_body: Int = pe_parse(pa_g, pa_t, pa_n);
    match pa_bfc[0] == 0 - 1 { true -> {
        pa_n[pa_ai*10+4] = 1; pa_n[pa_ai*10+5] = pa_body;
    }, false -> {
        pa_n[pa_blc[0]*10+6] = pa_body;
        pa_n[pa_ai*10+4] = pa_bc[0] + 1; pa_n[pa_ai*10+5] = pa_bfc[0];
    } };
    match pa_g[26] == 0-1 { true -> { pa_g[26] = pa_ai; pa_g[27] = pa_ai; }, false -> { pa_n[pa_g[27]*10+6] = pa_ai; pa_g[27] = pa_ai; } };
    pa_g[28] = pa_g[28] + 1;
}

// Match
fn pm_parse(pm2_g: Array<Int>, pm2_t: Array<Int>, pm2_n: Array<Int>) [IO] -> Int {
    do teat(pm2_g); let pm2_disc: Int = pe_parse(pm2_g, pm2_t, pm2_n);
    let pm2_mi: Int = nalloc(pm2_g, pm2_n); pm2_n[pm2_mi*10]=16; pm2_n[pm2_mi*10+8]=pm2_disc;
    do teat(pm2_g);
    let pm2_sv26: Int = pm2_g[26]; let pm2_sv27: Int = pm2_g[27]; let pm2_sv28: Int = pm2_g[28];
    pm2_g[26] = 0-1; pm2_g[27] = 0-1; pm2_g[28] = 0;
    for _pm2a in range(0, 256) { match tcur(pm2_g, pm2_t) == 18 { true -> { }, false -> {
        let pm2_pt: Int = tcur(pm2_g, pm2_t);
        // Check if pattern is an uppercase IDENT (ADT variant)
        let pm2_is_adt: Array<Int> = Array(1); pm2_is_adt[0] = 0;
        match pm2_pt == 13 { true -> {
            let pm2_pfc: Int = pm2_n[200000 + tsoff(pm2_g, pm2_t)];
            match pm2_pfc >= 65 { true -> match pm2_pfc <= 90 { true -> { pm2_is_adt[0] = 1; }, false -> { } }, false -> { } };
        }, false -> { } };
        match pm2_is_adt[0] == 1 { true -> {
            do pm_adt_arm(pm2_g, pm2_t, pm2_n);
        }, false -> match pm2_pt == 16 { true -> {
            // String literal match arm: NODE_MATCH_ARM_STR (26)
            let pm2_ai: Int = nalloc(pm2_g, pm2_n); pm2_n[pm2_ai*10]=26;
            pm2_n[pm2_ai*10+2]=tsoff(pm2_g,pm2_t); pm2_n[pm2_ai*10+3]=tslen(pm2_g,pm2_t);
            do teat(pm2_g); do teat(pm2_g); // eat string + arrow
            let pm2_body: Int = pe_parse(pm2_g, pm2_t, pm2_n);
            pm2_n[pm2_ai*10+4]=1; pm2_n[pm2_ai*10+5]=pm2_body;
            match pm2_g[26] == 0-1 { true -> { pm2_g[26] = pm2_ai; pm2_g[27] = pm2_ai; }, false -> { pm2_n[pm2_g[27]*10+6] = pm2_ai; pm2_g[27] = pm2_ai; } };
            pm2_g[28] = pm2_g[28] + 1;
        }, false -> {
            // Original match arm: true/false/int/wildcard
            let pm2_ai: Int = nalloc(pm2_g, pm2_n); pm2_n[pm2_ai*10]=17;
            match pm2_pt == 11 { true -> { pm2_n[pm2_ai*10+8]=1; do teat(pm2_g); },
            false -> match pm2_pt == 12 { true -> { pm2_n[pm2_ai*10+8]=0; do teat(pm2_g); },
            false -> match pm2_pt == 14 { true -> { pm2_n[pm2_ai*10+2]=tsoff(pm2_g,pm2_t); pm2_n[pm2_ai*10+3]=tslen(pm2_g,pm2_t); do teat(pm2_g); },
            false -> match pm2_pt == 25 { true -> {
                do teat(pm2_g);
                pm2_n[pm2_ai*10+2]=tsoff(pm2_g,pm2_t); pm2_n[pm2_ai*10+3]=tslen(pm2_g,pm2_t);
                pm2_n[pm2_ai*10+9]=1;
                do teat(pm2_g);
            },
            false -> { pm2_n[pm2_ai*10+1]=1; do teat(pm2_g); } } } } };
            do teat(pm2_g);
            let pm2_body: Int = pe_parse(pm2_g, pm2_t, pm2_n);
            pm2_n[pm2_ai*10+4]=1; pm2_n[pm2_ai*10+5]=pm2_body;
            match pm2_g[26] == 0-1 { true -> { pm2_g[26] = pm2_ai; pm2_g[27] = pm2_ai; }, false -> { pm2_n[pm2_g[27]*10+6] = pm2_ai; pm2_g[27] = pm2_ai; } };
            pm2_g[28] = pm2_g[28] + 1;
        } } };
        match tcur(pm2_g, pm2_t) == 42 { true -> { do teat(pm2_g); }, false -> { } };
    } }; };
    do teat(pm2_g);
    pm2_n[pm2_mi*10+4]=pm2_g[28]; pm2_n[pm2_mi*10+5]=pm2_g[26];
    // Exhaustive match check for ADT arms
    do chk_exhaust(pm2_g, pm2_n);
    pm2_g[26]=pm2_sv26; pm2_g[27]=pm2_sv27; pm2_g[28]=pm2_sv28;
    pm2_mi
}

// Exhaustive match check — called after parsing match arms
// Uses g[26]=first arm, g[28]=arm count. Checks if ADT arms cover all variants.
fn chk_exhaust(ce_g: Array<Int>, ce_n: Array<Int>) [IO] -> Unit {
    // Check if any arm is ADT (type 25)
    let ce_has_adt: Array<Int> = Array(1); ce_has_adt[0] = 0;
    let ce_has_wild: Array<Int> = Array(1); ce_has_wild[0] = 0;
    let ce_type_idx: Array<Int> = Array(1); ce_type_idx[0] = 0;
    let ce_cur: Array<Int> = Array(1); ce_cur[0] = ce_g[26];
    for _cea in range(0, ce_g[28]) {
        match ce_cur[0] >= 0 { true -> {
            match ce_n[ce_cur[0]*10] == 25 { true -> { ce_has_adt[0] = 1; ce_type_idx[0] = ce_n[ce_cur[0]*10+7]; }, false -> { } };
            match ce_n[ce_cur[0]*10] == 17 { true -> match ce_n[ce_cur[0]*10+1] == 1 { true -> { ce_has_wild[0] = 1; }, false -> { } }, false -> { } };
            ce_cur[0] = ce_n[ce_cur[0]*10+6];
        }, false -> { } };
    };
    // Bool exhaustiveness: if only 1 Bool arm (true/false) and no wildcard → error
    match ce_has_adt[0] == 0 { true -> match ce_has_wild[0] == 0 { true -> match ce_g[28] == 1 { true -> {
        // Single arm, no wildcard, no ADT — check if it's a Bool arm
        let ce_arm1: Int = ce_g[26];
        match ce_arm1 >= 0 { true -> match ce_n[ce_arm1 * 10] == 17 { true -> match ce_n[ce_arm1 * 10 + 1] <= 1 { true -> {
            match ce_n[ce_arm1 * 10 + 1] == 1 { true -> do print("error: non-exhaustive match on Bool — missing 'false' arm"), false -> do print("error: non-exhaustive match on Bool — missing 'true' arm") };
            do exit(1);
        }, false -> { } }, false -> { } }, false -> { } };
    }, false -> { } }, false -> { } }, false -> { } };
    // If has ADT arms and no wildcard, check coverage
    match ce_has_adt[0] == 1 { true -> match ce_has_wild[0] == 0 { true -> {
        let ce_vc: Int = ce_g[1024 + ce_type_idx[0] * 64 + 2]; // variant count
        // Count unique tags seen
        let ce_seen: Array<Int> = Array(64);
        ce_cur[0] = ce_g[26];
        for _ceb in range(0, ce_g[28]) {
            match ce_cur[0] >= 0 { true -> {
                match ce_n[ce_cur[0]*10] == 25 { true -> { ce_seen[ce_n[ce_cur[0]*10+1]] = 1; }, false -> { } };
                ce_cur[0] = ce_n[ce_cur[0]*10+6];
            }, false -> { } };
        };
        let ce_covered: Array<Int> = Array(1); ce_covered[0] = 0;
        for ce_vi in range(0, ce_vc) { ce_covered[0] = ce_covered[0] + ce_seen[ce_vi]; };
        match ce_covered[0] == ce_vc { true -> { }, false -> {
            do print_raw("error: non-exhaustive match — missing: ");
            let ce_base: Int = 1024 + ce_type_idx[0] * 64;
            for ce_mi in range(0, ce_vc) {
                match ce_seen[ce_mi] == 0 {
                    true -> {
                        let ce_vno: Int = ce_g[ce_base + 3 + ce_mi * 3];
                        let ce_vnl: Int = ce_g[ce_base + 3 + ce_mi * 3 + 1];
                        for ce_ch in range(0, ce_vnl) { do print_byte(ce_n[200000 + ce_vno + ce_ch]); };
                        do print_raw(" ");
                    },
                    false -> { },
                };
            };
            do print("");
            do exit(1);
        } };
    }, false -> { } }, false -> { } };
}

// Check if name at g[40]/g[41] matches a known type name. Returns type_index or -1.
// Monomorphize a generic type: create concrete version with substituted params
// gs[4600] = generic type index, gs[4601..4604] = concrete type_info per param
// Returns the new concrete type's index in the type table, or -1 if not generic
fn monomorphize(mg: Array<Int>, mn: Array<Int>) [] -> Int {
    let gen_idx: Int = mg[4600];
    let gen_base: Int = 1024 + gen_idx * 64;
    let param_count: Int = mg[gen_base + 20];
    match param_count == 0 { true -> 0 - 1, // not generic
    false -> {
        // Check if this exact monomorphization already exists
        // Simple approach: create a new type entry every time
        // (Duplicate detection would require comparing concrete params)
        let new_idx: Int = mg[900];
        let new_base: Int = 1024 + new_idx * 64;
        // Copy type name and append _ConcreteType suffix
        mg[new_base] = mg[gen_base]; // name offset (same as generic)
        mg[new_base + 1] = mg[gen_base + 1]; // name length
        // Copy variant count
        mg[new_base + 2] = mg[gen_base + 2];
        // Copy variants with field types substituted
        for vi in range(0, mg[gen_base + 2]) {
            let src_vb: Int = gen_base + 3 + vi * 3;
            let dst_vb: Int = new_base + 3 + vi * 3;
            mg[dst_vb] = mg[src_vb]; // variant name offset
            mg[dst_vb + 1] = mg[src_vb + 1]; // variant name length
            mg[dst_vb + 2] = mg[src_vb + 2]; // field count
        };
        mg[new_base + 20] = 0; // concrete type, not generic
        mg[900] = mg[900] + 1;
        new_idx
    } }
}

// Resolve a type name: check for ADT (plain or generic with <...>)
// g[40]=name_offset, g[41]=name_length in source buffer
// Returns type_info value (6 for ADT, or -1 if not found)
// If generic with <Int>: creates monomorphized version, skips <...> tokens
fn resolve_type(rt_g: Array<Int>, rt_t: Array<Int>, rt_n: Array<Int>) [] -> Int {
    let rt_idx: Int = chk_vari_type(rt_g, rt_n);
    match rt_idx >= 0 {
        true -> {
            let rt_base: Int = 1024 + rt_idx * 64;
            match rt_g[rt_base + 20] > 0 { true -> match tcur(rt_g, rt_t) == 31 { true -> {
                // Generic type with <...> — monomorphize
                do teat(rt_g); // eat <
                // Read concrete type args (up to 4)
                rt_g[4601] = 0; rt_g[4602] = 0; rt_g[4603] = 0; rt_g[4604] = 0;
                for _rp in range(0, 4) {
                    match tcur(rt_g, rt_t) == 32 { true -> { }, false -> {
                        // Read the concrete type name
                        let rt_clen: Int = rt_t[rt_g[13] * 5 + 2];
                        rt_g[4601] = match rt_clen == 3 { true -> 0, false -> match rt_clen == 6 { true -> 2, false -> match rt_clen == 4 { true -> 1, false -> 0 } } }; // Int=0, String=2, Bool=1
                        do teat(rt_g); // eat concrete type
                        match tcur(rt_g, rt_t) == 42 { true -> { do teat(rt_g); }, false -> { } }; // eat comma
                    } };
                };
                match tcur(rt_g, rt_t) == 32 { true -> { do teat(rt_g); }, false -> { } }; // eat >
                // Create monomorphized version
                rt_g[4600] = rt_idx;
                let rt_new: Int = monomorphize(rt_g, rt_n);
                6 // TYPE_ADT
            }, false -> 6 }, // ADT without <...> — plain use
            false -> 6 } // non-generic ADT
        },
        false -> 0 - 1, // not found
    }
}

fn chk_vari_type(ct_g: Array<Int>, ct_n: Array<Int>) [] -> Int {
    let ct_res: Array<Int> = Array(1); ct_res[0] = 0 - 1;
    for ct_ti in range(0, ct_g[900]) {
        let ct_base: Int = 1024 + ct_ti * 64;
        match ct_g[ct_base + 1] == ct_g[41] { true -> {
            ct_g[136] = 1;
            for ct_ci in range(0, ct_g[41]) {
                match ct_n[200000 + ct_g[ct_base] + ct_ci] == ct_n[200000 + ct_g[40] + ct_ci] { true -> { }, false -> { ct_g[136] = 0; } };
            };
            match ct_g[136] == 1 { true -> { ct_res[0] = ct_ti; }, false -> { } };
        }, false -> { } };
    };
    ct_res[0]
}

// For
fn pfor_parse(pfo_g: Array<Int>, pfo_t: Array<Int>, pfo_n: Array<Int>) [IO] -> Int {
    do teat(pfo_g);
    let pfo_fi: Int = nalloc(pfo_g, pfo_n); pfo_n[pfo_fi*10]=18;
    pfo_n[pfo_fi*10+2]=tsoff(pfo_g,pfo_t); pfo_n[pfo_fi*10+3]=tslen(pfo_g,pfo_t);
    do teat(pfo_g); do teat(pfo_g); do teat(pfo_g); do teat(pfo_g);
    let pfo_start: Int = pe_parse(pfo_g, pfo_t, pfo_n);
    do teat(pfo_g);
    let pfo_end: Int = pe_parse(pfo_g, pfo_t, pfo_n);
    do teat(pfo_g);
    let pfo_body: Int = pb_parse(pfo_g, pfo_t, pfo_n);
    pfo_n[pfo_fi*10+4]=3; pfo_n[pfo_fi*10+5]=pfo_start;
    pfo_n[pfo_start*10+6]=pfo_end; pfo_n[pfo_end*10+6]=pfo_body; pfo_fi
}

// mkbin — create a BINOP node linking left and right children
fn mkbin(mb_g: Array<Int>, mb_n: Array<Int>, mb_op: Int) [] -> Int {
    // mb_g[18]=left, mb_g[19]=right (set before calling)
    let mb_ni: Int = nalloc(mb_g, mb_n);
    mb_n[mb_ni*10]=11; mb_n[mb_ni*10+1]=mb_op; mb_n[mb_ni*10+4]=2;
    mb_n[mb_ni*10+5]=mb_g[18]; mb_n[mb_g[18]*10+6]=mb_g[19];
    // Propagate type_info: Float (7) or String (2) wins if either operand has it
    mb_n[mb_ni*10+7]=mb_n[mb_g[18]*10+7];
    match mb_n[mb_g[19]*10+7] % 16 == 7 { true -> { mb_n[mb_ni*10+7] = mb_n[mb_g[19]*10+7]; }, false -> { } };
    match mb_n[mb_g[18]*10+7] % 16 == 2 { true -> { mb_n[mb_ni*10+7] = mb_n[mb_g[18]*10+7]; }, false ->
    match mb_n[mb_g[19]*10+7] % 16 == 2 { true -> { mb_n[mb_ni*10+7] = mb_n[mb_g[19]*10+7]; }, false -> { } } };
    // Propagate privacy: highest privacy level wins
    match mb_n[mb_g[19]*10+7] / 16 > mb_n[mb_g[18]*10+7] / 16 {
        true -> { mb_n[mb_ni*10+7] = mb_n[mb_g[19]*10+7] / 16 * 16 + mb_n[mb_ni*10+7] % 16; },
        false -> match mb_n[mb_g[18]*10+7] / 16 > 0 {
            true -> { mb_n[mb_ni*10+7] = mb_n[mb_g[18]*10+7] / 16 * 16 + mb_n[mb_ni*10+7] % 16; },
            false -> { },
        },
    };
    mb_ni
}

// Token name
fn tname(tn_t: Int) [] -> String { match tn_t { 0 -> "KW_FN", 1 -> "KW_LET", 2 -> "KW_TYPE", 3 -> "KW_MATCH", 4 -> "KW_FOR", 5 -> "KW_IN", 6 -> "KW_DO", 7 -> "KW_MODULE", 8 -> "KW_IMPORTS", 9 -> "KW_EXPORTS", 10 -> "KW_SEQUENTIAL", 11 -> "KW_TRUE", 12 -> "KW_FALSE", 13 -> "IDENT", 14 -> "LIT_INT", 15 -> "LIT_FLOAT", 16 -> "LIT_STRING", 17 -> "LBRACE", 18 -> "RBRACE", 19 -> "LPAREN", 20 -> "RPAREN", 21 -> "LBRACKET", 22 -> "RBRACKET", 23 -> "ASSIGN", 24 -> "PLUS", 25 -> "MINUS", 26 -> "STAR", 27 -> "SLASH", 28 -> "PERCENT", 29 -> "EQ", 30 -> "NEQ", 31 -> "LT", 32 -> "GT", 33 -> "LTE", 34 -> "GTE", 35 -> "AND", 36 -> "OR", 37 -> "NOT", 38 -> "ARROW", 39 -> "PIPE", 40 -> "COLON", 41 -> "SEMICOLON", 42 -> "COMMA", 43 -> "DOT", 44 -> "EOF", _ -> "?" } }

// AST dump
fn dump_ast(da_g: Array<Int>, da_n: Array<Int>) [IO] -> Unit {
    do print("tokens: " + int_to_string(da_g[4]));
    do print("nodes: " + int_to_string(da_g[12]));
    let da_fc: Array<Int> = Array(1); da_fc[0] = 0;
    for da_i in range(0, da_g[12]) { match da_n[da_i * 10] == 1 { true -> { da_fc[0] = da_fc[0] + 1; }, false -> { } }; };
    do print("funcs: " + int_to_string(da_fc[0]));
    for da_j in range(0, da_g[12]) {
        let da_nt: Int = da_n[da_j * 10];
        match da_nt == 0 { true -> do print("  MODULE " + int_to_string(da_n[da_j*10+2]) + ":" + int_to_string(da_n[da_j*10+3])),
        false -> match da_nt == 1 { true -> do print("  FN " + int_to_string(da_n[da_j*10+2]) + ":" + int_to_string(da_n[da_j*10+3]) + " params=" + int_to_string(da_n[da_j*10+4])),
        false -> match da_nt == 2 { true -> do print("    PARAM " + int_to_string(da_n[da_j*10+2]) + ":" + int_to_string(da_n[da_j*10+3])),
        false -> match da_nt == 3 { true -> do print("    BLOCK (body)"),
        false -> { } } } } };
    };
}

// ===================================================================
// Codegen — emit NASM x86-64 assembly to stdout
// ===================================================================

// Helper: emit a line to stdout
fn emit_line(el_s: String) [IO] -> Unit { do print_raw(el_s); do print(""); }

// Emit scaffolding: .data, .bss, .text, _start
fn cg_emit(cg_g: Array<Int>, cg_n: Array<Int>, cg_s: Array<Int>) [IO] -> Unit {
    // .data section — string literals
    do emit_line("section .data");
    do emit_line("    _newline_byte db 10");
    do emit_line("    _bump_pos  dq _bump_heap");
    // Walk nodes for STR_LIT, emit each
    cg_g[29] = 0; // string literal counter
    for cg_si in range(0, cg_g[12]) {
        let cg_is_str: Int = match cg_n[cg_si * 10] == 8 { true -> 1, false -> match cg_n[cg_si * 10] == 26 { true -> 1, false -> 0 } };
        match cg_is_str == 1 {
            true -> {
                let cg_off: Int = cg_n[cg_si * 10 + 2];
                let cg_len: Int = cg_n[cg_si * 10 + 3];
                // Emit: _sN db "content"
                do print_raw("    _s" + int_to_string(cg_g[29]) + "    db ");
                do print_byte(34); // opening "
                for cg_sj in range(0, cg_len) {
                    let cg_ch: Int = cg_s[cg_off + cg_sj];
                    match cg_ch == 34 { true -> { do print_byte(34); do print_raw(",34,"); do print_byte(34); }, false -> { do print_byte(cg_ch); } };
                };
                do print_byte(34); // closing "
                do emit_line("");
                do emit_line("    _s" + int_to_string(cg_g[29]) + "_len equ " + int_to_string(cg_len));
                cg_n[cg_si * 10 + 8] = cg_g[29]; // store string index in extra
                cg_g[29] = cg_g[29] + 1;
            },
            false -> { },
        };
    };
    do emit_line("");

    // .bss section
    do emit_line("section .bss");
    do emit_line("    _bump_heap resb 33554432");
    do emit_line("    _big_stack resb 8388608");
    do emit_line("    _capture_slots resb 800");
    do emit_line("    _argc resq 1");
    do emit_line("    _argv resq 1");
    do emit_line("");

    // .text section
    do emit_line("section .text");
    do emit_line("global _start");
    do emit_line("");

    // Emit each function — g[30] = current fn node index
    for cg_fi in range(0, cg_g[12]) {
        match cg_n[cg_fi * 10] == 1 {
            true -> match cg_n[cg_fi * 10 + 9] / 128 % 2 == 1 {
                // extern fn: emit extern declaration
                true -> {
                    do print_raw("extern fn_");
                    do cg_name(cg_s, cg_n[cg_fi * 10 + 2], cg_n[cg_fi * 10 + 3]);
                    do emit_line("");
                },
                // regular fn: emit full function
                false -> { cg_g[30] = cg_fi; do cg_fn(cg_g, cg_n, cg_s); },
            },
            false -> { },
        };
    };

    // _start
    do emit_line("_start:");
    do emit_line("    mov rax, [rsp]");
    do emit_line("    mov [_argc], rax");
    do emit_line("    lea rax, [rsp+8]");
    do emit_line("    mov [_argv], rax");
    // Switch to a larger stack (8MB dedicated area)
    do emit_line("    lea rsp, [_big_stack + 8388608]");
    do emit_line("    and rsp, -16");
    do emit_line("    call fn_main");
    do emit_line("    xor rdi, rdi");
    do emit_line("    mov rax, 60");
    do emit_line("    syscall");
    // Runtime builtins
    do cg_rt_itoa(cg_g, cg_n, cg_s);
    do cg_rt_concat(cg_g, cg_n, cg_s);
    do cg_rt_getarg(cg_g, cg_n, cg_s);
    do cg_rt_readfile(cg_g, cg_n, cg_s);
    do cg_rt_print_byte(cg_g, cg_n, cg_s);
    do cg_rt_streq(cg_g, cg_n, cg_s);
    do cg_rt_substring(cg_g, cg_n, cg_s);
    do cg_rt_starts_with(cg_g, cg_n, cg_s);
    do cg_rt_index_of(cg_g, cg_n, cg_s);
    do cg_rt_contains(cg_g, cg_n, cg_s);
    do cg_rt_trim(cg_g, cg_n, cg_s);
}

// ===== Runtime function emitters =====

// int_to_string: rdi=int → rax=ptr, rdx=len
fn cg_rt_itoa(ri_g: Array<Int>, ri_n: Array<Int>, ri_s: Array<Int>) [IO] -> Unit {
    do emit_line("_rt_int_to_string:");
    do emit_line("    push rbp"); do emit_line("    mov rbp, rsp"); do emit_line("    sub rsp, 32");
    do emit_line("    mov rax, rdi");
    do emit_line("    mov r8, [_bump_pos]"); // buffer start
    do emit_line("    mov r9, r8");          // write position
    do emit_line("    cmp rax, 0"); do emit_line("    jge .itoa_pos");
    do emit_line("    neg rax"); do emit_line("    mov byte [r9], 45"); do emit_line("    inc r9"); // '-' sign
    do emit_line(".itoa_pos:");
    do emit_line("    mov r10, r9"); // start of digits
    do emit_line(".itoa_loop:");
    do emit_line("    xor rdx, rdx"); do emit_line("    mov rcx, 10"); do emit_line("    div rcx");
    do emit_line("    add dl, 48"); do emit_line("    mov byte [r9], dl"); do emit_line("    inc r9");
    do emit_line("    cmp rax, 0"); do emit_line("    jne .itoa_loop");
    // reverse digits
    do emit_line("    mov r11, r9"); do emit_line("    dec r11"); // right end
    do emit_line(".itoa_rev:");
    do emit_line("    cmp r10, r11"); do emit_line("    jge .itoa_done");
    do emit_line("    mov al, byte [r10]"); do emit_line("    mov cl, byte [r11]");
    do emit_line("    mov byte [r10], cl"); do emit_line("    mov byte [r11], al");
    do emit_line("    inc r10"); do emit_line("    dec r11"); do emit_line("    jmp .itoa_rev");
    do emit_line(".itoa_done:");
    do emit_line("    mov rax, r8"); // ptr
    do emit_line("    mov rdx, r9"); do emit_line("    sub rdx, r8"); // len
    do emit_line("    mov [_bump_pos], r9"); // advance bump
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
    do emit_line("");
}

// string_concat: rdi=left_ptr, rsi=left_len, rdx=right_ptr, rcx=right_len → rax=ptr, rdx=len
fn cg_rt_concat(rc_g: Array<Int>, rc_n: Array<Int>, rc_s: Array<Int>) [IO] -> Unit {
    do emit_line("_rt_string_concat:");
    do emit_line("    push rbp"); do emit_line("    mov rbp, rsp"); do emit_line("    sub rsp, 48");
    do emit_line("    mov [rbp-8], rdi");   // left_ptr
    do emit_line("    mov [rbp-16], rsi");  // left_len
    do emit_line("    mov [rbp-24], rdx");  // right_ptr
    do emit_line("    mov [rbp-32], rcx");  // right_len
    do emit_line("    mov r8, [_bump_pos]"); // dest
    // copy left
    do emit_line("    mov rsi, rdi"); do emit_line("    mov rdi, r8"); do emit_line("    mov rcx, [rbp-16]");
    do emit_line("    rep movsb");
    // copy right
    do emit_line("    mov rsi, [rbp-24]"); do emit_line("    mov rcx, [rbp-32]");
    do emit_line("    rep movsb");
    do emit_line("    mov rax, r8"); // result ptr
    do emit_line("    mov rdx, [rbp-16]"); do emit_line("    add rdx, [rbp-32]"); // result len
    do emit_line("    add r8, rdx"); do emit_line("    mov [_bump_pos], r8"); // advance bump
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
    do emit_line("");
}

// get_arg: rdi=n → rax=ptr, rdx=len
fn cg_rt_getarg(rg_g: Array<Int>, rg_n: Array<Int>, rg_s: Array<Int>) [IO] -> Unit {
    do emit_line("_rt_get_arg:");
    do emit_line("    push rbp"); do emit_line("    mov rbp, rsp");
    do emit_line("    mov rax, [_argv]"); do emit_line("    mov rax, [rax + rdi*8]");
    // strlen
    do emit_line("    mov rdx, 0");
    do emit_line(".ga_loop:"); do emit_line("    cmp byte [rax + rdx], 0"); do emit_line("    je .ga_done");
    do emit_line("    inc rdx"); do emit_line("    jmp .ga_loop");
    do emit_line(".ga_done:");
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
    do emit_line("");
}

// read_file: rdi=path_ptr, rsi=path_len → rax=ptr, rdx=len
fn cg_rt_readfile(rf_g: Array<Int>, rf_n: Array<Int>, rf_s: Array<Int>) [IO] -> Unit {
    do emit_line("_rt_read_file:");
    do emit_line("    push rbp"); do emit_line("    mov rbp, rsp"); do emit_line("    sub rsp, 32");
    // null-terminate filename in bump heap
    do emit_line("    mov r8, [_bump_pos]"); do emit_line("    mov [rbp-8], rdi"); do emit_line("    mov [rbp-16], rsi");
    do emit_line("    mov rcx, rsi"); do emit_line("    mov rdi, r8"); do emit_line("    mov rsi, [rbp-8]");
    do emit_line("    rep movsb"); do emit_line("    mov byte [rdi], 0"); // null terminate
    // open
    do emit_line("    mov rdi, r8"); do emit_line("    xor rsi, rsi"); do emit_line("    xor rdx, rdx");
    do emit_line("    mov rax, 2"); do emit_line("    syscall"); // open
    do emit_line("    mov [rbp-24], rax"); // fd
    // read into bump heap after the filename
    do emit_line("    lea r9, [r8 + 256]"); // skip past filename
    do emit_line("    mov rdi, [rbp-24]"); do emit_line("    mov rsi, r9"); do emit_line("    mov rdx, 1048576");
    do emit_line("    mov rax, 0"); do emit_line("    syscall"); // read
    do emit_line("    mov [rbp-32], rax"); // bytes read
    // close
    do emit_line("    mov rdi, [rbp-24]"); do emit_line("    mov rax, 3"); do emit_line("    syscall");
    // result
    do emit_line("    mov rax, r9"); // ptr
    do emit_line("    mov rdx, [rbp-32]"); // len
    // advance bump past data
    do emit_line("    lea r8, [r9 + rdx]"); do emit_line("    mov [_bump_pos], r8");
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
    do emit_line("");
}

// print_byte: rdi=byte value
fn cg_rt_print_byte(pb_g: Array<Int>, pb_n: Array<Int>, pb_s: Array<Int>) [IO] -> Unit {
    do emit_line("_rt_print_byte:");
    do emit_line("    push rbp"); do emit_line("    mov rbp, rsp"); do emit_line("    sub rsp, 16");
    do emit_line("    mov [rbp-1], dil"); // store byte
    do emit_line("    lea rsi, [rbp-1]"); do emit_line("    mov rdi, 1"); do emit_line("    mov rdx, 1");
    do emit_line("    mov rax, 1"); do emit_line("    syscall");
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
    do emit_line("");
}

// string_equals(ptr1=rdi, len1=rsi, ptr2=rdx, len2=rcx) → rax=0/1
fn cg_rt_streq(sq_g: Array<Int>, sq_n: Array<Int>, sq_s: Array<Int>) [IO] -> Unit {
    do emit_line("_rt_string_equals:");
    do emit_line("    cmp rsi, rcx"); do emit_line("    jne .seq_fail");
    do emit_line("    xor r8, r8");
    do emit_line(".seq_loop:"); do emit_line("    cmp r8, rsi"); do emit_line("    jge .seq_pass");
    do emit_line("    movzx rax, byte [rdi + r8]"); do emit_line("    movzx rcx, byte [rdx + r8]");
    do emit_line("    cmp al, cl"); do emit_line("    jne .seq_fail");
    do emit_line("    inc r8"); do emit_line("    jmp .seq_loop");
    do emit_line(".seq_pass:"); do emit_line("    mov rax, 1"); do emit_line("    ret");
    do emit_line(".seq_fail:"); do emit_line("    xor rax, rax"); do emit_line("    ret");
    do emit_line("");
}

// substring(str_ptr, str_len, start, count) -> (ptr, len)
// Allocates new string from bump heap
fn cg_rt_substring(rs_g: Array<Int>, rs_n: Array<Int>, rs_s: Array<Int>) [IO] -> Unit {
    do emit_line("_rt_substring:");
    do emit_line("    push rbp"); do emit_line("    mov rbp, rsp"); do emit_line("    sub rsp, 32");
    // rdi=ptr, rsi=len, rdx=start, rcx=count
    // Clamp: if start >= len, return empty
    do emit_line("    cmp rdx, rsi"); do emit_line("    jge .substr_empty");
    // Clamp count to available
    do emit_line("    mov r8, rsi"); do emit_line("    sub r8, rdx"); // r8 = available
    do emit_line("    cmp rcx, r8"); do emit_line("    cmovg rcx, r8"); // count = min(count, available)
    // Allocate from bump heap
    do emit_line("    mov r9, [_bump_pos]");
    do emit_line("    lea r10, [rdi + rdx]"); // source start
    // Copy rcx bytes
    do emit_line("    mov r11, rcx"); // save count
    do emit_line("    mov rax, r9"); // dest = bump_pos
    do emit_line(".substr_copy:"); do emit_line("    cmp rcx, 0"); do emit_line("    je .substr_done");
    do emit_line("    movzx r8d, byte [r10]"); do emit_line("    mov byte [rax], r8b");
    do emit_line("    inc r10"); do emit_line("    inc rax"); do emit_line("    dec rcx");
    do emit_line("    jmp .substr_copy");
    do emit_line(".substr_done:");
    do emit_line("    mov [_bump_pos], rax");
    do emit_line("    mov rax, r9"); do emit_line("    mov rdx, r11"); // return (ptr, len)
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
    do emit_line(".substr_empty:");
    do emit_line("    mov rax, [_bump_pos]"); do emit_line("    xor rdx, rdx"); // empty string
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
}

// string_starts_with(str_ptr, str_len, prefix_ptr, prefix_len) -> 0/1
fn cg_rt_starts_with(rw_g: Array<Int>, rw_n: Array<Int>, rw_s: Array<Int>) [IO] -> Unit {
    do emit_line("_rt_string_starts_with:");
    do emit_line("    push rbp"); do emit_line("    mov rbp, rsp");
    // rdi=str_ptr, rsi=str_len, rdx=prefix_ptr, rcx=prefix_len
    do emit_line("    cmp rcx, rsi"); do emit_line("    jg .sw_false"); // prefix longer than string
    do emit_line("    mov r8, rcx"); // counter
    do emit_line(".sw_loop:"); do emit_line("    cmp r8, 0"); do emit_line("    je .sw_true");
    do emit_line("    dec r8");
    do emit_line("    movzx r9d, byte [rdi + r8]"); do emit_line("    movzx r10d, byte [rdx + r8]");
    do emit_line("    cmp r9d, r10d"); do emit_line("    jne .sw_false");
    do emit_line("    jmp .sw_loop");
    do emit_line(".sw_true:"); do emit_line("    mov rax, 1");
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
    do emit_line(".sw_false:"); do emit_line("    xor rax, rax");
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
}

// string_index_of(str_ptr, str_len, char_code) -> index or -1
fn cg_rt_index_of(ri2_g: Array<Int>, ri2_n: Array<Int>, ri2_s: Array<Int>) [IO] -> Unit {
    do emit_line("_rt_string_index_of:");
    do emit_line("    push rbp"); do emit_line("    mov rbp, rsp");
    // rdi=ptr, rsi=len, rdx=char
    do emit_line("    xor rcx, rcx"); // index = 0
    do emit_line(".sio_loop:"); do emit_line("    cmp rcx, rsi"); do emit_line("    jge .sio_not_found");
    do emit_line("    movzx r8d, byte [rdi + rcx]");
    do emit_line("    cmp r8d, edx"); do emit_line("    je .sio_found");
    do emit_line("    inc rcx"); do emit_line("    jmp .sio_loop");
    do emit_line(".sio_found:"); do emit_line("    mov rax, rcx");
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
    do emit_line(".sio_not_found:"); do emit_line("    mov rax, -1");
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
}

// string_contains(str_ptr, str_len, sub_ptr, sub_len) -> 0/1
fn cg_rt_contains(rc2_g: Array<Int>, rc2_n: Array<Int>, rc2_s: Array<Int>) [IO] -> Unit {
    do emit_line("_rt_string_contains:");
    do emit_line("    push rbp"); do emit_line("    mov rbp, rsp"); do emit_line("    sub rsp, 32");
    // rdi=str_ptr, rsi=str_len, rdx=sub_ptr, rcx=sub_len
    do emit_line("    cmp rcx, rsi"); do emit_line("    jg .sc_false"); // sub longer than str
    do emit_line("    mov r8, rsi"); do emit_line("    sub r8, rcx"); do emit_line("    inc r8"); // search range
    do emit_line("    xor r9, r9"); // outer index
    do emit_line(".sc_outer:"); do emit_line("    cmp r9, r8"); do emit_line("    jge .sc_false");
    // Compare substring at position r9
    do emit_line("    xor r10, r10"); // inner index
    do emit_line(".sc_inner:"); do emit_line("    cmp r10, rcx"); do emit_line("    je .sc_true");
    do emit_line("    mov r11, r9"); do emit_line("    add r11, r10");
    do emit_line("    movzx eax, byte [rdi + r11]"); do emit_line("    movzx ebx, byte [rdx + r10]");
    do emit_line("    cmp eax, ebx"); do emit_line("    jne .sc_next");
    do emit_line("    inc r10"); do emit_line("    jmp .sc_inner");
    do emit_line(".sc_next:"); do emit_line("    inc r9"); do emit_line("    jmp .sc_outer");
    do emit_line(".sc_true:"); do emit_line("    mov rax, 1");
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
    do emit_line(".sc_false:"); do emit_line("    xor rax, rax");
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
}

// string_trim(str_ptr, str_len) -> (ptr, len) — trims spaces from both ends
fn cg_rt_trim(rt2_g: Array<Int>, rt2_n: Array<Int>, rt2_s: Array<Int>) [IO] -> Unit {
    do emit_line("_rt_string_trim:");
    do emit_line("    push rbp"); do emit_line("    mov rbp, rsp");
    // rdi=ptr, rsi=len
    do emit_line("    mov rcx, rdi"); // start pointer
    do emit_line("    lea rdx, [rdi + rsi]"); // end pointer
    // Trim leading spaces
    do emit_line(".trim_lead:"); do emit_line("    cmp rcx, rdx"); do emit_line("    jge .trim_empty");
    do emit_line("    movzx eax, byte [rcx]");
    do emit_line("    cmp eax, 32"); do emit_line("    ja .trim_trail_start"); // not space/control
    do emit_line("    inc rcx"); do emit_line("    jmp .trim_lead");
    // Trim trailing spaces
    do emit_line(".trim_trail_start:"); do emit_line("    mov r8, rdx"); // save end
    do emit_line(".trim_trail:"); do emit_line("    cmp r8, rcx"); do emit_line("    jle .trim_empty");
    do emit_line("    movzx eax, byte [r8 - 1]");
    do emit_line("    cmp eax, 32"); do emit_line("    ja .trim_done");
    do emit_line("    dec r8"); do emit_line("    jmp .trim_trail");
    do emit_line(".trim_done:");
    do emit_line("    mov rax, rcx"); // trimmed start
    do emit_line("    mov rdx, r8"); do emit_line("    sub rdx, rcx"); // trimmed length
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
    do emit_line(".trim_empty:"); do emit_line("    mov rax, rdi"); do emit_line("    xor rdx, rdx");
    do emit_line("    mov rsp, rbp"); do emit_line("    pop rbp"); do emit_line("    ret");
}

// Emit one function
fn cg_fn(cf_g: Array<Int>, cf_n: Array<Int>, cf_s: Array<Int>) [IO] -> Unit {
    let cf_fi: Int = cf_g[30];
    let cf_off: Int = cf_n[cf_fi * 10 + 2];
    let cf_len: Int = cf_n[cf_fi * 10 + 3];
    // Reset variable table: g[50]=var_count, g[51..]=entries
    cf_g[50] = 0;
    // Assign slots for params
    let cf_pc: Int = cf_n[cf_fi * 10 + 4]; // param_count (child_count of FN_DECL)
    let cf_pi: Array<Int> = Array(1);
    cf_pi[0] = cf_n[cf_fi * 10 + 5]; // first_child = first PARAM
    let cf_soff: Array<Int> = Array(1); cf_soff[0] = 0;
    // Register indices for AMD64 calling convention
    // params use rdi,rsi,rdx,rcx,r8,r9 — 2 registers per param (16-byte convention)
    let cf_ptype: Array<Int> = Array(1);
    for _cfp in range(0, cf_pc) {
        cf_ptype[0] = cf_n[cf_pi[0] * 10 + 7];
        match cf_ptype[0] % 16 == 2 { true -> { cf_soff[0] = cf_soff[0] + 16; }, false -> match cf_ptype[0] % 16 == 4 { true -> { cf_soff[0] = cf_soff[0] + 16; }, false -> { cf_soff[0] = cf_soff[0] + 8; } } };
        cf_g[34] = cf_pi[0]; cf_g[35] = cf_soff[0]; do cg_add_var(cf_g, cf_n, cf_s);
        cf_pi[0] = cf_n[cf_pi[0] * 10 + 6];
    };
    // Walk body for let bindings — assign their slots too
    let cf_body: Int = cf_n[cf_fi * 10 + 8];
    cf_g[33] = cf_soff[0];
    match cf_body >= 0 { true -> { cf_g[31] = cf_body; do cg_walk_slots(cf_g, cf_n, cf_s); }, false -> { } };
    cf_soff[0] = cf_g[33];
    // Calculate frame size (round up to 16-byte alignment)
    match cf_soff[0] % 16 == 0 { true -> { }, false -> { cf_soff[0] = cf_soff[0] + 16 - cf_soff[0] % 16; } };
    match cf_soff[0] == 0 { true -> { cf_soff[0] = 16; }, false -> { } };
    // Emit function header
    do print_raw("fn_");
    do cg_name(cf_s, cf_off, cf_len);
    do emit_line(":");
    do emit_line("    push rbp");
    do emit_line("    mov rbp, rsp");
    do print_raw("    sub rsp, "); do emit_line(int_to_string(cf_soff[0]));
    // Store params from registers to stack
    do cg_store_params(cf_g, cf_n, cf_s);
    // Emit body
    match cf_body >= 0 { true -> { cf_g[31] = cf_body; do cg_block(cf_g, cf_n, cf_s); }, false -> { } };
    // ZeroOnDrop: zero sensitive variables before function return
    for cf_zi in range(0, cf_g[50]) {
        match cf_g[51 + cf_zi * 4 + 3] / 16 == 3 { true -> {
            // Zero the stack slot(s) for this variable
            do emit_line("    mov qword [rbp-" + int_to_string(cf_g[51 + cf_zi * 4 + 2]) + "], 0");
            // If String (16 bytes), zero the second slot too
            match cf_g[51 + cf_zi * 4 + 3] % 16 == 2 { true -> {
                do emit_line("    mov qword [rbp-" + int_to_string(cf_g[51 + cf_zi * 4 + 2] - 8) + "], 0");
            }, false -> { } };
        }, false -> { } };
    };
    do emit_line("    mov rsp, rbp");
    do emit_line("    pop rbp");
    do emit_line("    ret");
    do emit_line("");
}

// Add a variable to the table: g[50]=count, entries at g[51+i*4..]
// g[34]=node_index, g[35]=stack_offset — set before calling
fn cg_add_var(av_g: Array<Int>, av_n: Array<Int>, av_s: Array<Int>) [] -> Unit {
    let av_idx: Int = av_g[50];
    let av_base: Int = 51 + av_idx * 4;
    av_g[av_base] = av_n[av_g[34] * 10 + 2];
    av_g[av_base + 1] = av_n[av_g[34] * 10 + 3];
    av_g[av_base + 2] = av_g[35];
    av_g[av_base + 3] = av_n[av_g[34] * 10 + 7];
    av_g[50] = av_idx + 1;
}

// Iterative slot walker — explicit stack in g[2048..4095], var table at g[51..2047]
fn cg_walk_slots(ws_g: Array<Int>, ws_n: Array<Int>, ws_s: Array<Int>) [] -> Unit {
    ws_g[220] = 0;
    ws_g[2048] = ws_g[31]; ws_g[220] = 1;
    for _ws in range(0, 65536) {
        match ws_g[220] > 0 { true -> {
            ws_g[220] = ws_g[220] - 1;
            ws_g[136] = ws_g[2048 + ws_g[220]];
            match ws_g[136] >= 1 { true -> {
                ws_g[137] = ws_n[ws_g[136] * 10];
                match ws_g[137] == 4 { true -> {
                    ws_g[138] = ws_n[ws_g[136] * 10 + 7];
                    match ws_g[138] % 16 == 2 { true -> { ws_g[33] = ws_g[33] + 16; }, false -> match ws_g[138] % 16 == 4 { true -> { ws_g[33] = ws_g[33] + 16; }, false -> { ws_g[33] = ws_g[33] + 8; } } };
                    ws_g[34] = ws_g[136]; ws_g[35] = ws_g[33]; do cg_add_var(ws_g, ws_n, ws_s);
                }, false -> { } };
                match ws_g[137] == 18 { true -> {
                    ws_g[33] = ws_g[33] + 8;
                    ws_g[34] = ws_g[136]; ws_g[35] = ws_g[33]; do cg_add_var(ws_g, ws_n, ws_s);
                    ws_g[33] = ws_g[33] + 8;
                }, false -> { } };
                // ADT match arm bindings: allocate 8 bytes per binding PARAM
                match ws_g[137] == 25 { true -> {
                    let ws_bfc: Int = ws_n[ws_g[136] * 10 + 8]; // field count
                    let ws_bci: Array<Int> = Array(1); ws_bci[0] = ws_n[ws_g[136] * 10 + 5]; // first child
                    for _wsb in range(0, ws_bfc) {
                        match ws_bci[0] >= 1 { true -> {
                            ws_g[33] = ws_g[33] + 8;
                            ws_n[ws_bci[0] * 10 + 7] = ws_g[33]; // store offset in PARAM's type_info field
                            ws_bci[0] = ws_n[ws_bci[0] * 10 + 6]; // next sibling
                        }, false -> { } };
                    };
                }, false -> { } };
                // Push next_sibling (processed second = breadth after depth)
                ws_g[138] = ws_n[ws_g[136] * 10 + 6];
                match ws_g[138] >= 1 { true -> match ws_g[220] < 2000 { true -> { ws_g[2048 + ws_g[220]] = ws_g[138]; ws_g[220] = ws_g[220] + 1; }, false -> { } }, false -> { } };
                // Push first_child (processed first = depth-first)
                ws_g[138] = ws_n[ws_g[136] * 10 + 5];
                match ws_g[138] >= 1 { true -> match ws_g[220] < 2000 { true -> { ws_g[2048 + ws_g[220]] = ws_g[138]; ws_g[220] = ws_g[220] + 1; }, false -> { } }, false -> { } };
            }, false -> { } };
        }, false -> { } };
    };
}

// Store params from ABI registers to stack slots
fn cg_store_params(sp_g: Array<Int>, sp_n: Array<Int>, sp_s: Array<Int>) [IO] -> Unit {
    let sp_fi: Int = sp_g[30];
    let sp_pc: Int = sp_n[sp_fi * 10 + 4];
    match sp_pc <= 3 { true -> {
        // Standard register convention: params in rdi/rsi/rdx/rcx/r8/r9
        let sp_ri: Array<Int> = Array(1); sp_ri[0] = 0;
        let sp_pi: Array<Int> = Array(1); sp_pi[0] = sp_n[sp_fi * 10 + 5];
        for _spp in range(0, sp_pc) {
            let sp_vi: Int = sp_g[51 + (_spp) * 4 + 2];
            let sp_pt: Int = sp_n[sp_pi[0] * 10 + 7];
            match sp_pt % 16 == 2 { true -> { do cg_store_reg(sp_ri[0], sp_vi); do cg_store_reg(sp_ri[0] + 1, sp_vi - 8); sp_ri[0] = sp_ri[0] + 2; },
            false -> match sp_pt % 16 == 4 { true -> { do cg_store_reg(sp_ri[0], sp_vi); do cg_store_reg(sp_ri[0] + 1, sp_vi - 8); sp_ri[0] = sp_ri[0] + 2; },
            false -> { do cg_store_reg(sp_ri[0], sp_vi); sp_ri[0] = sp_ri[0] + 2; } } };
            sp_pi[0] = sp_n[sp_pi[0] * 10 + 6];
        };
    }, false -> {
        // Stack-passed convention for 4+ params
        // Stack layout at entry: [rbp+16] = argN_ptr, [rbp+24] = argN_len, ...
        // Args are in REVERSE order on stack (argN closest to rbp, arg1 farthest)
        let sp_pi2: Array<Int> = Array(1); sp_pi2[0] = sp_n[sp_fi * 10 + 5];
        for _spp2 in range(0, sp_pc) {
            let sp_vi2: Int = sp_g[51 + (_spp2) * 4 + 2];
            let sp_soff: Int = 16 + (sp_pc - 1 - _spp2) * 16; // stack offset for this param
            do print_raw("    mov rax, qword [rbp+"); do print_raw(int_to_string(sp_soff)); do emit_line("]");
            do print_raw("    mov qword [rbp-"); do print_raw(int_to_string(sp_vi2)); do emit_line("], rax");
            let sp_pt2: Int = sp_n[sp_pi2[0] * 10 + 7];
            match sp_pt2 % 16 == 2 { true -> {
                do print_raw("    mov rax, qword [rbp+"); do print_raw(int_to_string(sp_soff + 8)); do emit_line("]");
                do print_raw("    mov qword [rbp-"); do print_raw(int_to_string(sp_vi2 - 8)); do emit_line("], rax");
            }, false -> match sp_pt2 % 16 == 4 { true -> {
                do print_raw("    mov rax, qword [rbp+"); do print_raw(int_to_string(sp_soff + 8)); do emit_line("]");
                do print_raw("    mov qword [rbp-"); do print_raw(int_to_string(sp_vi2 - 8)); do emit_line("], rax");
            }, false -> { } } };
            sp_pi2[0] = sp_n[sp_pi2[0] * 10 + 6];
        };
    } };
}

// Emit: mov qword [rbp-offset], <register>
fn cg_store_reg(sr_ri: Int, sr_off: Int) [IO] -> Unit {
    let sr_reg: String = match sr_ri == 0 { true -> "rdi", false -> match sr_ri == 1 { true -> "rsi", false -> match sr_ri == 2 { true -> "rdx", false -> match sr_ri == 3 { true -> "rcx", false -> match sr_ri == 4 { true -> "r8", false -> "r9" } } } } };
    do print_raw("    mov qword [rbp-"); do print_raw(int_to_string(sr_off)); do print_raw("], "); do emit_line(sr_reg);
}

// Emit a name from source buffer byte by byte
fn cg_name(cn_s: Array<Int>, cn_off: Int, cn_len: Int) [IO] -> Unit {
    // Emit name bytes — for unqualified names, just print all bytes
    // For qualified names (with dot), print only the part after the dot
    // Skip dot search entirely if function has no dots (most common case)
    for cn_j in range(0, cn_len) { do print_byte(cn_s[cn_off + cn_j]); };
}

// Emit a block's children — g[31] = block node index (set before call)
fn cg_block(cb_g: Array<Int>, cb_n: Array<Int>, cb_s: Array<Int>) [IO] -> Unit {
    let cb_bi: Int = cb_g[31];
    let cb_cc: Int = cb_n[cb_bi * 10 + 4]; // child_count
    let cb_ci: Array<Int> = Array(1);
    cb_ci[0] = cb_n[cb_bi * 10 + 5]; // first_child
    let cb_t: Array<Int> = Array(1);
    for _cbi in range(0, cb_cc) {
        cb_t[0] = cb_n[cb_ci[0] * 10];
        match cb_t[0] == 5 { true -> { cb_g[31] = cb_n[cb_ci[0] * 10 + 5]; do cg_expr(cb_g, cb_n, cb_s); },
        false -> match cb_t[0] == 6 { true -> { cb_g[31] = cb_n[cb_ci[0] * 10 + 5]; do cg_expr(cb_g, cb_n, cb_s); },
        false -> match cb_t[0] == 4 { true -> { cb_g[31] = cb_ci[0]; do cg_let(cb_g, cb_n, cb_s); },
        false -> match cb_t[0] == 21 { true -> { cb_g[31] = cb_ci[0]; do cg_aryset(cb_g, cb_n, cb_s); },
        false -> { } } } } };
        cb_ci[0] = cb_n[cb_ci[0] * 10 + 6];
    };
}

// ===================================================================
// Expression codegen — emit instructions that leave result in rax
// g[31] = current expression node index
// ===================================================================

// cg_expr: dispatch on node type. Two halves to keep match nesting <= 4.
fn cg_expr(ce_g: Array<Int>, ce_n: Array<Int>, ce_s: Array<Int>) [IO] -> Unit {
    let ce_ni: Int = ce_g[31];
    let ce_nt: Int = ce_n[ce_ni * 10];
    match ce_nt == 7 { true -> do cg_int(ce_g, ce_n, ce_s),
    false -> match ce_nt == 9 { true -> do cg_int(ce_g, ce_n, ce_s),
    false -> match ce_nt == 11 { true -> do cg_binop(ce_g, ce_n, ce_s),
    false -> match ce_nt == 8 { true -> do cg_str(ce_g, ce_n, ce_s),
    false -> do cg_expr3(ce_g, ce_n, ce_s) } } } }
}

// cg_expr3: handles match, for, block, then falls to expr2
fn cg_expr3(e3_g: Array<Int>, e3_n: Array<Int>, e3_s: Array<Int>) [IO] -> Unit {
    e3_g[140] = e3_n[e3_g[31]*10];
    match e3_g[140] == 3 { true -> do cg_block(e3_g, e3_n, e3_s),
    false -> match e3_g[140] == 16 { true -> do cg_match(e3_g, e3_n, e3_s),
    false -> match e3_g[140] == 18 { true -> do cg_for(e3_g, e3_n, e3_s),
    false -> match e3_g[140] == 19 { true -> do cg_arynew(e3_g, e3_n, e3_s),
    false -> match e3_g[140] == 20 { true -> do cg_aryget(e3_g, e3_n, e3_s),
    false -> match e3_g[140] == 24 { true -> do cg_variant_new(e3_g, e3_n, e3_s),
    false -> match e3_g[140] == 28 { true -> do cg_lambda(e3_g, e3_n, e3_s),
    false -> do cg_expr2(e3_g, e3_n, e3_s) } } } } } } }
}

// cg_expr2: handles unary, do, call
fn cg_expr2(ce2_g: Array<Int>, ce2_n: Array<Int>, ce2_s: Array<Int>) [IO] -> Unit {
    let ce2_ni: Int = ce2_g[31];
    let ce2_nt: Int = ce2_n[ce2_ni * 10];
    match ce2_nt == 13 { true -> {
        ce2_g[31] = ce2_n[ce2_ni * 10 + 5]; do cg_expr(ce2_g, ce2_n, ce2_s); do emit_line("    neg rax");
    }, false -> match ce2_nt == 12 { true -> {
        ce2_g[31] = ce2_n[ce2_ni * 10 + 5]; do cg_expr(ce2_g, ce2_n, ce2_s); do emit_line("    xor rax, 1");
    }, false -> match ce2_nt == 15 { true -> {
        ce2_g[31] = ce2_n[ce2_ni * 10 + 5]; do cg_expr(ce2_g, ce2_n, ce2_s);
    }, false -> match ce2_nt == 14 { true -> do cg_call(ce2_g, ce2_n, ce2_s),
    false -> match ce2_nt == 10 { true -> do cg_var(ce2_g, ce2_n, ce2_s), // IDENT_REF
    false -> { } } } } } }
}

// cg_var: load variable from stack slot into rax
fn cg_var(cv_g: Array<Int>, cv_n: Array<Int>, cv_s: Array<Int>) [IO] -> Unit {
    let cv_ni: Int = cv_g[31];
    cv_g[40] = cv_n[cv_ni * 10 + 2]; cv_g[41] = cv_n[cv_ni * 10 + 3];
    let cv_off: Int = cg_find_var(cv_g, cv_s);
    let cv_tp: Int = cg_find_var_type(cv_g, cv_s);
    match cv_off >= 10000 { true -> {
        // Capture variable: load from _capture_slots instead of stack
        let cv_cap: Int = cv_off - 10000;
        do print_raw("    mov rax, qword [rel _capture_slots + "); do print_raw(int_to_string(cv_cap * 8)); do emit_line("]");
    }, false ->
    match cv_tp % 16 == 2 { true -> {
        do print_raw("    mov rax, qword [rbp-"); do print_raw(int_to_string(cv_off)); do emit_line("]");
        do print_raw("    mov rdx, qword [rbp-"); do print_raw(int_to_string(cv_off - 8)); do emit_line("]");
    }, false -> match cv_tp % 16 == 4 { true -> {
        do print_raw("    mov rax, qword [rbp-"); do print_raw(int_to_string(cv_off)); do emit_line("]");
        do print_raw("    mov rdx, qword [rbp-"); do print_raw(int_to_string(cv_off - 8)); do emit_line("]");
    }, false -> match cv_off == 8 {
        true -> match cg_is_fn(cv_g, cv_n, cv_s) == 1 {
            true -> { do print_raw("    lea rax, [rel fn_"); do cg_name(cv_s, cv_n[cv_ni * 10 + 2], cv_n[cv_ni * 10 + 3]); do emit_line("]"); },
            false -> { do print_raw("    mov rax, qword [rbp-"); do print_raw(int_to_string(cv_off)); do emit_line("]"); },
        },
        false -> {
            do print_raw("    mov rax, qword [rbp-"); do print_raw(int_to_string(cv_off)); do emit_line("]");
        },
    } } } }
}

// cg_int: emit mov rax, <literal value>. Works for INT_LIT and BOOL_LIT.
fn cg_int(ci_g: Array<Int>, ci_n: Array<Int>, ci_s: Array<Int>) [IO] -> Unit {
    let ci_ni: Int = ci_g[31];
    let ci_nt: Int = ci_n[ci_ni * 10];
    match ci_nt == 9 { true -> { // BOOL_LIT: extra has 0 or 1
        do print_raw("    mov rax, ");
        do emit_line(int_to_string(ci_n[ci_ni * 10 + 8]));
    }, false -> { // INT_LIT: parse from source buffer
        ci_g[40] = ci_n[ci_ni * 10 + 2]; ci_g[41] = ci_n[ci_ni * 10 + 3];
        let ci_val: Int = str2int(ci_g, ci_s);
        do print_raw("    mov rax, ");
        do emit_line(int_to_string(ci_val));
    } }
}

// cg_str: load string literal pointer and length
fn cg_str(cs_g: Array<Int>, cs_n: Array<Int>, cs_s: Array<Int>) [IO] -> Unit {
    let cs_ni: Int = cs_g[31];
    let cs_idx: Int = cs_n[cs_ni * 10 + 8]; // extra = string data label index
    do print_raw("    lea rax, [rel _s"); do print_raw(int_to_string(cs_idx)); do emit_line("]");
    do print_raw("    mov rdx, _s"); do print_raw(int_to_string(cs_idx)); do emit_line("_len");
}

// g[115..120]: 115=match_node 116=arm_count 117=label_id 118=arm_iter 119=arm_idx 120=pass(0=cmp,1=body)
fn cg_match(cm_g: Array<Int>, cm_n: Array<Int>, cm_s: Array<Int>) [IO] -> Unit {
    let cm_first_arm: Int = cm_n[cm_g[31]*10+5];
    let cm_arm_type: Int = cm_n[cm_first_arm*10];
    match cm_arm_type == 25 { true -> do cg_match_adt(cm_g, cm_n, cm_s),
    false -> match cm_arm_type == 26 { true -> do cg_match_str(cm_g, cm_n, cm_s),
    false -> {
        cm_g[850]=cm_g[31]; cm_g[851]=cm_n[cm_g[850]*10+4]; cm_g[852]=cm_g[32]; cm_g[32]=cm_g[32]+1;
        cm_g[31]=cm_n[cm_g[850]*10+8]; do cg_expr(cm_g, cm_n, cm_s);
        do emit_line("    mov r15, rax");
        cm_g[853]=cm_n[cm_g[850]*10+5]; cm_g[854]=0; cm_g[855]=0;
        do cg_mpass(cm_g, cm_n, cm_s);
        cm_g[853]=cm_n[cm_g[850]*10+5]; cm_g[854]=0; cm_g[855]=1;
        do cg_mpass(cm_g, cm_n, cm_s);
        do print_raw(".Lm"); do print_raw(int_to_string(cm_g[852])); do emit_line("_end:");
    } } };
}
// cg_mpass — emit match comparison chain (icmp + branch per arm)
fn cg_mpass(mp_g: Array<Int>, mp_n: Array<Int>, mp_s: Array<Int>) [IO] -> Unit {
    for _mp in range(0, mp_g[851]) {
        match mp_g[855]==0 { true -> do cg_marm_c(mp_g, mp_n, mp_s), false -> do cg_marm_b(mp_g, mp_n, mp_s) };
        mp_g[854]=mp_g[854]+1; mp_g[853]=mp_n[mp_g[853]*10+6];
    };
}
// cg_marm_c — emit match arm comparison label
fn cg_marm_c(ac_g: Array<Int>, ac_n: Array<Int>, ac_s: Array<Int>) [IO] -> Unit {
    match ac_n[ac_g[853]*10+1]==1 { true -> {
        do print_raw("    jmp .Lm"); do print_raw(int_to_string(ac_g[852])); do print_raw("_a"); do emit_line(int_to_string(ac_g[854]));
    }, false -> {
        ac_g[40]=ac_n[ac_g[853]*10+2]; ac_g[41]=ac_n[ac_g[853]*10+3];
        match ac_g[41] > 0 { true -> {
            ac_g[42] = str2int(ac_g, ac_s);
            match ac_n[ac_g[853]*10+9]==1 { true -> { ac_g[42] = 0 - ac_g[42]; }, false -> { } };
            do print_raw("    cmp r15, "); do emit_line(int_to_string(ac_g[42]));
        },
        false -> { do print_raw("    cmp r15, "); do emit_line(int_to_string(ac_n[ac_g[853]*10+8])); } };
        do print_raw("    je .Lm"); do print_raw(int_to_string(ac_g[852])); do print_raw("_a"); do emit_line(int_to_string(ac_g[854]));
    } };
}
// cg_marm_b — emit match arm body block
fn cg_marm_b(ab_g: Array<Int>, ab_n: Array<Int>, ab_s: Array<Int>) [IO] -> Unit {
    do print_raw(".Lm"); do print_raw(int_to_string(ab_g[852])); do print_raw("_a"); do print_raw(int_to_string(ab_g[854])); do emit_line(":");
    ab_g[856]=ab_g[856]+1; ab_g[857]=6000+ab_g[856]*6;
    ab_g[ab_g[857]]=ab_g[850]; ab_g[ab_g[857]+1]=ab_g[851]; ab_g[ab_g[857]+2]=ab_g[852];
    ab_g[ab_g[857]+3]=ab_g[853]; ab_g[ab_g[857]+4]=ab_g[854]; ab_g[ab_g[857]+5]=ab_g[855];
    ab_g[31]=ab_n[ab_g[853]*10+5]; do cg_expr(ab_g, ab_n, ab_s);
    ab_g[857]=6000+ab_g[856]*6;
    ab_g[850]=ab_g[ab_g[857]]; ab_g[851]=ab_g[ab_g[857]+1]; ab_g[852]=ab_g[ab_g[857]+2];
    ab_g[853]=ab_g[ab_g[857]+3]; ab_g[854]=ab_g[ab_g[857]+4]; ab_g[855]=ab_g[ab_g[857]+5];
    ab_g[856]=ab_g[856]-1;
    do print_raw("    jmp .Lm"); do print_raw(int_to_string(ab_g[852])); do emit_line("_end");
}

// Variant constructor: Circle(5) → bump-allocate [tag, field0, field1, ...]
// cg_lambda — emit lambda as inline function, return its address
// cg_cap_save — store outer variables to _capture_slots before lambda jmp
// g[7100+i*4] = saved outer variable table entries
// cap_count = number of captures (outer var count - 1, skipping the LET being defined)
fn cg_cap_save(cs_g: Array<Int>, cs_n: Array<Int>, cs_s: Array<Int>, cs_count: Int) [IO] -> Unit {
    // Save outer variable table to g[7100+]
    for cs_i in range(0, cs_count) {
        cs_g[7100 + cs_i * 4] = cs_g[51 + cs_i * 4];
        cs_g[7100 + cs_i * 4 + 1] = cs_g[51 + cs_i * 4 + 1];
        cs_g[7100 + cs_i * 4 + 2] = cs_g[51 + cs_i * 4 + 2];
        cs_g[7100 + cs_i * 4 + 3] = cs_g[51 + cs_i * 4 + 3];
    };
    // Emit stores to _capture_slots
    for cs_j in range(0, cs_count) {
        let cs_off: Int = cs_g[7100 + cs_j * 4 + 2];
        match cs_off >= 10000 { true -> { }, false -> {
            do print_raw("    mov rax, qword [rbp-"); do print_raw(int_to_string(cs_off)); do emit_line("]");
            do print_raw("    mov qword [rel _capture_slots + "); do print_raw(int_to_string(cs_j * 8)); do emit_line("], rax");
        } };
    };
}

// cg_cap_register — register captured outer variables in lambda's variable table
// Reads from g[7100+] (saved by cg_cap_save), registers with offset 10000+index
fn cg_cap_register(cr_g: Array<Int>, cr_count: Int) [] -> Unit {
    for cr_i in range(0, cr_count) {
        let cr_vi: Int = cr_g[50];
        cr_g[51 + cr_vi * 4] = cr_g[7100 + cr_i * 4];
        cr_g[51 + cr_vi * 4 + 1] = cr_g[7100 + cr_i * 4 + 1];
        cr_g[51 + cr_vi * 4 + 2] = 10000 + cr_i;
        cr_g[51 + cr_vi * 4 + 3] = cr_g[7100 + cr_i * 4 + 3];
        cr_g[50] = cr_vi + 1;
    };
}

// cg_lambda — emit lambda as inline function, return its address
// Supports captures: outer variables stored to _capture_slots before jmp,
// loaded from _capture_slots inside the lambda body.
fn cg_lambda(cl_g: Array<Int>, cl_n: Array<Int>, cl_s: Array<Int>) [IO] -> Unit {
    let cl_ni: Int = cl_g[31];
    let cl_name_off: Int = cl_n[cl_ni * 10 + 2];
    let cl_name_len: Int = cl_n[cl_ni * 10 + 3];
    let cl_pc: Int = cl_n[cl_ni * 10 + 4]; // param count
    let cl_body: Int = cl_n[cl_ni * 10 + 8]; // body block
    let cl_lid: Int = cl_g[32]; cl_g[32] = cl_g[32] + 1;
    // Save outer variable table state + capture setup
    let cl_sv50: Int = cl_g[50];
    let cl_cap_count: Int = match cl_sv50 > 0 { true -> cl_sv50 - 1, false -> 0 };
    // Save and emit capture stores (BEFORE jumping past lambda)
    do cg_cap_save(cl_g, cl_n, cl_s, cl_cap_count);
    // Jump past the lambda body
    do print_raw("    jmp _lam_end_"); do emit_line(int_to_string(cl_lid));
    // Emit the function
    do print_raw("fn_"); do cg_name(cl_s, cl_name_off, cl_name_len); do emit_line(":");
    do emit_line("    push rbp");
    do emit_line("    mov rbp, rsp");
    cl_g[50] = 0;
    // Register params in variable table
    let cl_pi: Array<Int> = Array(1);
    cl_pi[0] = cl_n[cl_ni * 10 + 5];
    let cl_soff: Array<Int> = Array(1); cl_soff[0] = 0;
    for _clp in range(0, cl_pc) {
        let cl_pty: Int = cl_n[cl_pi[0] * 10 + 7];
        match cl_pty % 16 == 2 { true -> { cl_soff[0] = cl_soff[0] + 16; }, false -> match cl_pty % 16 == 4 { true -> { cl_soff[0] = cl_soff[0] + 16; }, false -> { cl_soff[0] = cl_soff[0] + 8; } } };
        cl_g[34] = cl_pi[0]; cl_g[35] = cl_soff[0]; do cg_add_var(cl_g, cl_n, cl_s);
        cl_pi[0] = cl_n[cl_pi[0] * 10 + 6];
    };
    // Walk body for let bindings (BEFORE registering captures — captures don't need stack slots)
    cl_g[33] = cl_soff[0];
    match cl_body >= 0 { true -> { cl_g[31] = cl_body; do cg_walk_slots(cl_g, cl_n, cl_s); }, false -> { } };
    cl_soff[0] = cl_g[33];
    match cl_soff[0] % 16 == 0 { true -> { }, false -> { cl_soff[0] = cl_soff[0] + 16 - cl_soff[0] % 16; } };
    match cl_soff[0] == 0 { true -> { cl_soff[0] = 16; }, false -> { } };
    do print_raw("    sub rsp, "); do emit_line(int_to_string(cl_soff[0]));
    // Store params from registers to stack slots (BEFORE capture registration)
    let cl_ri: Array<Int> = Array(1); cl_ri[0] = 0;
    let cl_sp: Array<Int> = Array(1); cl_sp[0] = cl_n[cl_ni * 10 + 5];
    for _cls in range(0, cl_pc) {
        let cl_vix: Int = cl_g[51 + (cl_g[50] - cl_pc + _cls) * 4 + 2];
        let cl_pt: Int = cl_g[51 + (cl_g[50] - cl_pc + _cls) * 4 + 3];
        match cl_pt % 16 == 2 { true -> { do cg_store_reg(cl_ri[0], cl_vix); do cg_store_reg(cl_ri[0] + 1, cl_vix - 8); cl_ri[0] = cl_ri[0] + 2; },
        false -> match cl_pt % 16 == 4 { true -> { do cg_store_reg(cl_ri[0], cl_vix); do cg_store_reg(cl_ri[0] + 1, cl_vix - 8); cl_ri[0] = cl_ri[0] + 2; },
        false -> { do cg_store_reg(cl_ri[0], cl_vix); cl_ri[0] = cl_ri[0] + 2; } } };
        cl_sp[0] = cl_n[cl_sp[0] * 10 + 6];
    };
    // NOW register captures (after param stores are done, so g[50] offset is correct)
    do cg_cap_register(cl_g, cl_cap_count);
    // Emit body
    cl_g[31] = cl_body; do cg_block(cl_g, cl_n, cl_s);
    do emit_line("    mov rsp, rbp");
    do emit_line("    pop rbp");
    do emit_line("    ret");
    // Restore variable table
    cl_g[50] = cl_sv50;
    // Skip label
    do print_raw("_lam_end_"); do emit_line(int_to_string(cl_lid) + ":");
    // Return the function address
    do print_raw("    lea rax, [rel fn_"); do cg_name(cl_s, cl_name_off, cl_name_len); do emit_line("]");
}

fn cg_variant_new(vn_g: Array<Int>, vn_n: Array<Int>, vn_s: Array<Int>) [IO] -> Unit {
    let vn_ni: Int = vn_g[31];
    let vn_tag: Int = vn_n[vn_ni * 10 + 1]; // sub_type = tag
    let vn_ac: Int = vn_n[vn_ni * 10 + 4]; // arg count
    // Allocate (1 + arg_count) * 8 bytes
    do print_raw("    mov r10, [_bump_pos]"); do emit_line("");
    do print_raw("    add qword [_bump_pos], "); do emit_line(int_to_string((1 + vn_ac) * 8));
    // Store tag at [r10]
    do print_raw("    mov qword [r10], "); do emit_line(int_to_string(vn_tag));
    // Evaluate and store each field
    let vn_ci: Array<Int> = Array(1); vn_ci[0] = vn_n[vn_ni * 10 + 5]; // first child
    for vn_fi in range(0, vn_ac) {
        do emit_line("    push r10");
        vn_g[31] = vn_ci[0]; do cg_expr(vn_g, vn_n, vn_s);
        do emit_line("    pop r10");
        do print_raw("    mov qword [r10 + "); do print_raw(int_to_string((vn_fi + 1) * 8)); do emit_line("], rax");
        vn_ci[0] = vn_n[vn_ci[0] * 10 + 6]; // next sibling
    };
    // Return pointer
    do emit_line("    mov rax, r10");
}

// ADT match: evaluate discriminant, load tag, dispatch by variant
fn cg_match_adt(ma_g: Array<Int>, ma_n: Array<Int>, ma_s: Array<Int>) [IO] -> Unit {
    ma_g[850]=ma_g[31]; ma_g[851]=ma_n[ma_g[850]*10+4]; ma_g[852]=ma_g[32]; ma_g[32]=ma_g[32]+1;
    // Evaluate discriminant → rax = ADT pointer
    ma_g[31]=ma_n[ma_g[850]*10+8]; do cg_expr(ma_g, ma_n, ma_s);
    // Save ADT pointer and load tag
    do emit_line("    push rax");
    do emit_line("    mov r15, [rax]");
    // Comparison pass
    ma_g[853]=ma_n[ma_g[850]*10+5]; ma_g[854]=0; ma_g[855]=0;
    do cg_mpass_adt(ma_g, ma_n, ma_s);
    // Body pass
    ma_g[853]=ma_n[ma_g[850]*10+5]; ma_g[854]=0; ma_g[855]=1;
    do cg_mpass_adt(ma_g, ma_n, ma_s);
    // End label + cleanup
    do print_raw(".Lm"); do print_raw(int_to_string(ma_g[852])); do emit_line("_end:");
    do emit_line("    add rsp, 8"); // discard saved ADT pointer
}

// cg_mpass_adt — emit ADT match: tag load, comparison, field binding
fn cg_mpass_adt(mp_g: Array<Int>, mp_n: Array<Int>, mp_s: Array<Int>) [IO] -> Unit {
    for _mp in range(0, mp_g[851]) {
        match mp_g[855]==0 { true -> do cg_marm_adt_c(mp_g, mp_n, mp_s), false -> do cg_marm_adt_b(mp_g, mp_n, mp_s) };
        mp_g[854]=mp_g[854]+1; mp_g[853]=mp_n[mp_g[853]*10+6];
    };
}

// ADT match arm comparison: cmp r15, TAG / je .label (or jmp for wildcard)
fn cg_marm_adt_c(ac_g: Array<Int>, ac_n: Array<Int>, ac_s: Array<Int>) [IO] -> Unit {
    match ac_n[ac_g[853]*10] == 17 { true -> {
        // Wildcard arm (NODE_MATCH_ARM with sub_type=1)
        do print_raw("    jmp .Lm"); do print_raw(int_to_string(ac_g[852])); do print_raw("_a"); do emit_line(int_to_string(ac_g[854]));
    }, false -> {
        // ADT arm (NODE_MATCH_ARM_ADT)
        do print_raw("    cmp r15, "); do emit_line(int_to_string(ac_n[ac_g[853]*10+1])); // tag
        do print_raw("    je .Lm"); do print_raw(int_to_string(ac_g[852])); do print_raw("_a"); do emit_line(int_to_string(ac_g[854]));
    } };
}

// ADT match arm body: extract fields, register bindings, evaluate body
fn cg_marm_adt_b(ab_g: Array<Int>, ab_n: Array<Int>, ab_s: Array<Int>) [IO] -> Unit {
    do print_raw(".Lm"); do print_raw(int_to_string(ab_g[852])); do print_raw("_a"); do print_raw(int_to_string(ab_g[854])); do emit_line(":");
    // Save match state (depth-indexed)
    ab_g[856]=ab_g[856]+1; ab_g[857]=6000+ab_g[856]*6;
    ab_g[ab_g[857]]=ab_g[850]; ab_g[ab_g[857]+1]=ab_g[851]; ab_g[ab_g[857]+2]=ab_g[852];
    ab_g[ab_g[857]+3]=ab_g[853]; ab_g[ab_g[857]+4]=ab_g[854]; ab_g[ab_g[857]+5]=ab_g[855];
    // Get field count and first child
    let ab_fc: Int = ab_n[ab_g[853]*10+8]; // extra = field count
    let ab_ci: Array<Int> = Array(1); ab_ci[0] = ab_n[ab_g[853]*10+5]; // first child
    // Extract fields: load ADT pointer from stack, read fields, store to binding stack slots
    let ab_sv50: Int = ab_g[50]; // save var count before adding bindings
    for ab_fi in range(0, ab_fc) {
        // ab_ci[0] is a NODE_PARAM with the binding name
        do print_raw("    mov r14, [rsp]"); do emit_line(""); // reload ADT pointer
        do print_raw("    mov rax, [r14 + "); do print_raw(int_to_string((ab_fi + 1) * 8)); do emit_line("]");
        // Register binding as variable and store to its stack slot
        ab_g[34] = ab_ci[0]; ab_g[35] = ab_n[ab_ci[0]*10+7]; // node_index, stack_offset (from slot walker)
        do cg_add_var(ab_g, ab_n, ab_s);
        do print_raw("    mov qword [rbp-"); do print_raw(int_to_string(ab_g[35])); do emit_line("], rax");
        ab_ci[0] = ab_n[ab_ci[0]*10+6]; // next sibling → next binding or body
    };
    // ab_ci[0] is now the body expression
    ab_g[31] = ab_ci[0]; do cg_expr(ab_g, ab_n, ab_s);
    // Restore match state
    ab_g[857]=6000+ab_g[856]*6;
    ab_g[850]=ab_g[ab_g[857]]; ab_g[851]=ab_g[ab_g[857]+1]; ab_g[852]=ab_g[ab_g[857]+2];
    ab_g[853]=ab_g[ab_g[857]+3]; ab_g[854]=ab_g[ab_g[857]+4]; ab_g[855]=ab_g[ab_g[857]+5];
    ab_g[856]=ab_g[856]-1;
    // Restore var count (remove bindings from scope)
    ab_g[50] = ab_sv50;
    do print_raw("    jmp .Lm"); do print_raw(int_to_string(ab_g[852])); do emit_line("_end");
}

// Array(N): allocate N*8 bytes from bump heap, return (ptr, len) in rax/rdx
// String match: compare discriminant with string literal per arm
fn cg_match_str(ms_g: Array<Int>, ms_n: Array<Int>, ms_s: Array<Int>) [IO] -> Unit {
    ms_g[850]=ms_g[31]; ms_g[851]=ms_n[ms_g[850]*10+4]; ms_g[852]=ms_g[32]; ms_g[32]=ms_g[32]+1;
    // Evaluate discriminant → rax=ptr, rdx=len (String)
    ms_g[31]=ms_n[ms_g[850]*10+8]; do cg_expr(ms_g, ms_n, ms_s);
    do emit_line("    push rdx"); do emit_line("    push rax"); // save string on stack
    // Comparison pass
    ms_g[853]=ms_n[ms_g[850]*10+5]; ms_g[854]=0;
    for _msc in range(0, ms_g[851]) {
        match ms_n[ms_g[853]*10] == 26 { true -> {
            let ms_idx: Int = ms_n[ms_g[853]*10+8]; // _sN index
            do emit_line("    mov rdi, [rsp]"); do emit_line("    mov rsi, [rsp+8]");
            do print_raw("    lea rdx, [rel _s"); do print_raw(int_to_string(ms_idx)); do emit_line("]");
            do print_raw("    mov rcx, _s"); do print_raw(int_to_string(ms_idx)); do emit_line("_len");
            do emit_line("    call _rt_string_equals");
            do print_raw("    cmp rax, 1"); do emit_line("");
            do print_raw("    je .Lm"); do print_raw(int_to_string(ms_g[852])); do print_raw("_a"); do emit_line(int_to_string(ms_g[854]));
        }, false -> {
            // Wildcard arm
            do print_raw("    jmp .Lm"); do print_raw(int_to_string(ms_g[852])); do print_raw("_a"); do emit_line(int_to_string(ms_g[854]));
        } };
        ms_g[854]=ms_g[854]+1; ms_g[853]=ms_n[ms_g[853]*10+6];
    };
    // Body pass
    ms_g[853]=ms_n[ms_g[850]*10+5]; ms_g[854]=0;
    for _msb in range(0, ms_g[851]) {
        do print_raw(".Lm"); do print_raw(int_to_string(ms_g[852])); do print_raw("_a"); do print_raw(int_to_string(ms_g[854])); do emit_line(":");
        ms_g[856]=ms_g[856]+1; ms_g[857]=6000+ms_g[856]*6;
        ms_g[ms_g[857]]=ms_g[850]; ms_g[ms_g[857]+1]=ms_g[851]; ms_g[ms_g[857]+2]=ms_g[852];
        ms_g[ms_g[857]+3]=ms_g[853]; ms_g[ms_g[857]+4]=ms_g[854]; ms_g[ms_g[857]+5]=0;
        ms_g[31]=ms_n[ms_g[853]*10+5]; do cg_expr(ms_g, ms_n, ms_s);
        ms_g[857]=6000+ms_g[856]*6;
        ms_g[850]=ms_g[ms_g[857]]; ms_g[851]=ms_g[ms_g[857]+1]; ms_g[852]=ms_g[ms_g[857]+2];
        ms_g[853]=ms_g[ms_g[857]+3]; ms_g[854]=ms_g[ms_g[857]+4];
        ms_g[856]=ms_g[856]-1;
        do print_raw("    jmp .Lm"); do print_raw(int_to_string(ms_g[852])); do emit_line("_end");
        ms_g[854]=ms_g[854]+1; ms_g[853]=ms_n[ms_g[853]*10+6];
    };
    do print_raw(".Lm"); do print_raw(int_to_string(ms_g[852])); do emit_line("_end:");
    do emit_line("    add rsp, 16");
}

// cg_arynew — emit Array(n) allocation with bounds header
fn cg_arynew(an_g: Array<Int>, an_n: Array<Int>, an_s: Array<Int>) [IO] -> Unit {
    do cg_expr(an_g, an_n, an_s); // g[31] already set to size expr by caller
    do emit_line("    mov rcx, rax"); // save count
    do emit_line("    shl rax, 3");   // bytes = count * 8
    do emit_line("    mov rdi, [_bump_pos]");
    do emit_line("    add [_bump_pos], rax");
    do emit_line("    mov rax, rdi"); // ptr
    do emit_line("    mov rdx, rcx"); // len = count
}

// arr[i]: load element — arr ptr in rax, arr len in rdx (from var load), index in g[31]
fn cg_aryget(ag_g: Array<Int>, ag_n: Array<Int>, ag_s: Array<Int>) [IO] -> Unit {
    ag_g[173] = ag_g[31];
    ag_g[40] = ag_n[ag_g[173]*10+2]; ag_g[41] = ag_n[ag_g[173]*10+3];
    ag_g[174] = cg_find_var(ag_g, ag_s);
    do print_raw("    mov r10, qword [rbp-"); do print_raw(int_to_string(ag_g[174])); do emit_line("]");
    do emit_line("    push r10"); // save array ptr (r10 clobbered by index eval)
    ag_g[31] = ag_n[ag_g[173]*10+5]; do cg_expr(ag_g, ag_n, ag_s);
    do emit_line("    pop r10"); // restore array ptr
    do emit_line("    mov rax, qword [r10 + rax*8]");
}

// For loop: counter from start to end
fn cg_for(cf_g: Array<Int>, cf_n: Array<Int>, cf_s: Array<Int>) [IO] -> Unit {
    cf_g[141] = cf_g[31]; // save FOR node
    cf_g[142] = cf_g[32]; cf_g[32] = cf_g[32] + 1; // label id
    // Find loop var stack offset
    cf_g[40] = cf_n[cf_g[141]*10+2]; cf_g[41] = cf_n[cf_g[141]*10+3];
    cf_g[143] = cg_find_var(cf_g, cf_s); // loop var offset
    // Children: start, end, body
    cf_g[144] = cf_n[cf_g[141]*10+5]; // start expr (first child)
    cf_g[145] = cf_n[cf_g[144]*10+6]; // end expr (start's sibling)
    cf_g[146] = cf_n[cf_g[145]*10+6]; // body block (end's sibling)
    // Eval start, store to loop var
    cf_g[31] = cf_g[144]; do cg_expr(cf_g, cf_n, cf_s);
    do print_raw("    mov qword [rbp-"); do print_raw(int_to_string(cf_g[143])); do emit_line("], rax");
    // Eval end, store to temp (loop var offset + 8)
    cf_g[31] = cf_g[145]; do cg_expr(cf_g, cf_n, cf_s);
    do print_raw("    mov qword [rbp-"); do print_raw(int_to_string(cf_g[143] + 8)); do emit_line("], rax");
    // Loop top
    do print_raw(".Lf"); do print_raw(int_to_string(cf_g[142])); do emit_line("_top:");
    do print_raw("    mov rax, qword [rbp-"); do print_raw(int_to_string(cf_g[143])); do emit_line("]");
    do print_raw("    cmp rax, qword [rbp-"); do print_raw(int_to_string(cf_g[143] + 8)); do emit_line("]");
    do print_raw("    jge .Lf"); do print_raw(int_to_string(cf_g[142])); do emit_line("_end");
    // Save for-loop state (depth-indexed) for nested for re-entrancy
    cf_g[256]=cf_g[256]+1; cf_g[257]=260+cf_g[256]*6;
    cf_g[cf_g[257]]=cf_g[141]; cf_g[cf_g[257]+1]=cf_g[142]; cf_g[cf_g[257]+2]=cf_g[143];
    cf_g[cf_g[257]+3]=cf_g[144]; cf_g[cf_g[257]+4]=cf_g[145]; cf_g[cf_g[257]+5]=cf_g[146];
    cf_g[31] = cf_g[146]; do cg_block(cf_g, cf_n, cf_s);
    cf_g[257]=260+cf_g[256]*6;
    cf_g[141]=cf_g[cf_g[257]]; cf_g[142]=cf_g[cf_g[257]+1]; cf_g[143]=cf_g[cf_g[257]+2];
    cf_g[144]=cf_g[cf_g[257]+3]; cf_g[145]=cf_g[cf_g[257]+4]; cf_g[146]=cf_g[cf_g[257]+5];
    cf_g[256]=cf_g[256]-1;
    do print_raw("    inc qword [rbp-"); do print_raw(int_to_string(cf_g[143])); do emit_line("]");
    do print_raw("    jmp .Lf"); do print_raw(int_to_string(cf_g[142])); do emit_line("_top");
    do print_raw(".Lf"); do print_raw(int_to_string(cf_g[142])); do emit_line("_end:");
}

// cg_binop: emit left, push, right, pop, operate
fn cg_binop(bo_g: Array<Int>, bo_n: Array<Int>, bo_s: Array<Int>) [IO] -> Unit {
    let bo_ni: Int = bo_g[31];
    let bo_left: Int = bo_n[bo_ni * 10 + 5];
    let bo_right: Int = bo_n[bo_left * 10 + 6];
    let bo_op: Int = bo_n[bo_ni * 10 + 1];
    // Check if this is string concat: either operand is STR_LIT (type 8) or has string type_info
    // Detect string concat: STR_LIT operand, or BINOP type_info is String, or operand variable is String
    let bo_is_str: Int = match bo_n[bo_left * 10] == 8 { true -> 1, false -> match bo_n[bo_right * 10] == 8 { true -> 1, false -> match bo_n[bo_ni * 10 + 7] % 16 == 2 { true -> 1, false -> match bo_n[bo_left * 10] == 10 { true -> { bo_g[40] = bo_n[bo_left * 10 + 2]; bo_g[41] = bo_n[bo_left * 10 + 3]; match cg_find_var_type(bo_g, bo_s) % 16 == 2 { true -> 1, false -> 0 } }, false -> 0 } } } };
    match bo_op == 0 { true -> match bo_is_str == 1 { true -> { // String concat
        bo_g[31] = bo_left; do cg_expr(bo_g, bo_n, bo_s);
        // rax=left_ptr, rdx=left_len
        do emit_line("    push rdx"); do emit_line("    push rax"); // save left (ptr,len)
        bo_g[31] = bo_right; do cg_expr(bo_g, bo_n, bo_s);
        // rax=right_ptr, rdx=right_len. Need: rdi=left_ptr, rsi=left_len, rdx=right_ptr, rcx=right_len
        do emit_line("    mov rcx, rdx"); do emit_line("    mov rdx, rax");
        do emit_line("    pop rdi"); do emit_line("    pop rsi");
        do emit_line("    call _rt_string_concat");
        // result: rax=new_ptr, rdx=new_len
    }, false -> do cg_binop_int(bo_g, bo_n, bo_s) },
    false -> do cg_binop_int(bo_g, bo_n, bo_s) };
}

// Integer binary operation — evaluates left, right, applies operator
fn cg_binop_int(bi_g: Array<Int>, bi_n: Array<Int>, bi_s: Array<Int>) [IO] -> Unit {
    let bi_ni: Int = bi_g[31];
    let bi_left: Int = bi_n[bi_ni * 10 + 5];
    let bi_right: Int = bi_n[bi_left * 10 + 6];
    let bi_op: Int = bi_n[bi_ni * 10 + 1];
    bi_g[31] = bi_left; do cg_expr(bi_g, bi_n, bi_s);
    do emit_line("    push rax");
    bi_g[31] = bi_right; do cg_expr(bi_g, bi_n, bi_s);
    do emit_line("    mov rcx, rax");
    do emit_line("    pop rax");
    match bi_op == 0 { true -> do emit_line("    add rax, rcx"),
    false -> match bi_op == 1 { true -> do emit_line("    sub rax, rcx"),
    false -> match bi_op == 2 { true -> do emit_line("    imul rax, rcx"),
    false -> match bi_op == 3 { true -> { do emit_line("    cqo"); do emit_line("    idiv rcx"); },
    false -> do cg_binop_int2(bi_op) } } } };
}

// cg_binop_int2 — emit integer binop instruction (add/sub/mul/div)
fn cg_binop_int2(b2_op: Int) [IO] -> Unit {
    match b2_op == 4 { true -> { do emit_line("    cqo"); do emit_line("    idiv rcx"); do emit_line("    mov rax, rdx"); },
    false -> match b2_op >= 5 { true -> match b2_op <= 10 { true -> do cg_cmp(b2_op), false -> { } },
    false -> match b2_op == 11 { true -> { do emit_line("    and rax, rcx"); do emit_line("    movzx rax, al"); },
    false -> match b2_op == 12 { true -> { do emit_line("    or rax, rcx"); do emit_line("    movzx rax, al"); },
    false -> { } } } } };
}

// cg_cmp — emit comparison operation (eq/ne/lt/gt/le/ge)
fn cg_cmp(cc_op: Int) [IO] -> Unit {
    do emit_line("    cmp rax, rcx");
    match cc_op == 5 { true -> do emit_line("    sete al"),
    false -> match cc_op == 6 { true -> do emit_line("    setne al"),
    false -> match cc_op == 7 { true -> do emit_line("    setl al"),
    false -> match cc_op == 8 { true -> do emit_line("    setg al"),
    false -> match cc_op == 9 { true -> do emit_line("    setle al"),
    false -> match cc_op == 10 { true -> do emit_line("    setge al"),
    false -> { } } } } } } };
    do emit_line("    movzx rax, al");
}

// cg_call: dispatch on builtin sub_type
fn cg_call(cc_g: Array<Int>, cc_n: Array<Int>, cc_s: Array<Int>) [IO] -> Unit {
    let cc_ni: Int = cc_g[31];
    cc_g[40] = cc_n[cc_ni * 10 + 2]; cc_g[41] = cc_n[cc_ni * 10 + 3];
    // Check for Array(N) constructor
    match cc_g[41] == 5 { true -> match cc_s[cc_g[40]] == 65 { true -> { cc_g[31]=cc_n[cc_ni*10+5]; do cg_arynew(cc_g, cc_n, cc_s); cc_g[160]=1; }, false -> { cc_g[160]=0; } }, false -> { cc_g[160]=0; } };
    match cc_g[160] == 0 { true -> do cg_call_inner(cc_g, cc_n, cc_s), false -> { } };
}
// cg_call_inner — dispatch call to builtin or user function
fn cg_call_inner(ci2_g: Array<Int>, ci2_n: Array<Int>, ci2_s: Array<Int>) [IO] -> Unit {
    let ci2_ni: Int = ci2_g[31];
    let cc_sub: Int = chk_bi(ci2_g, ci2_s);
    match cc_sub == 8 { true -> { // BUILTIN_EXIT
        ci2_g[31] = ci2_n[ci2_ni * 10 + 5];
        do cg_expr(ci2_g, ci2_n, ci2_s);
        do emit_line("    mov rdi, rax");
        do emit_line("    mov rax, 60");
        do emit_line("    syscall");
    }, false -> { ci2_g[36] = cc_sub; do cg_call2(ci2_g, ci2_n, ci2_s); } };
}

// User function call: evaluate args, push to stack, pop into registers, call
// cg_call2: handle builtins (print, int_to_string, etc.) and user calls
// g[36] = builtin sub_type
fn cg_call2(c2_g: Array<Int>, c2_n: Array<Int>, c2_s: Array<Int>) [IO] -> Unit {
    let c2_ni: Int = c2_g[31];
    let c2_sub: Int = c2_g[36];
    match c2_sub == 1 { true -> { // print(String) — write + newline
        c2_g[31] = c2_n[c2_ni * 10 + 5]; do cg_expr(c2_g, c2_n, c2_s);
        // rax=ptr, rdx=len → write(1, ptr, len)
        do emit_line("    mov rsi, rax"); // ptr
        do emit_line("    mov rdi, 1");   // fd=stdout
        do emit_line("    mov rax, 1");   // syscall=write
        do emit_line("    syscall");
        // write newline
        do emit_line("    lea rsi, [rel _newline_byte]");
        do emit_line("    mov rdi, 1");
        do emit_line("    mov rdx, 1");
        do emit_line("    mov rax, 1");
        do emit_line("    syscall");
    }, false -> match c2_sub == 3 { true -> { // int_to_string(Int) — call runtime
        c2_g[31] = c2_n[c2_ni * 10 + 5]; do cg_expr(c2_g, c2_n, c2_s);
        do emit_line("    mov rdi, rax");
        do emit_line("    call _rt_int_to_string");
    }, false -> match c2_sub == 0 { true -> do cg_user_call(c2_g, c2_n, c2_s), // user call
    false -> { // Other builtins — print_raw, string_length, etc.
        do cg_call3(c2_g, c2_n, c2_s);
    } } } };
}

// cg_call3: remaining builtins
fn cg_call3(c3_g: Array<Int>, c3_n: Array<Int>, c3_s: Array<Int>) [IO] -> Unit {
    c3_g[139] = c3_g[31]; c3_g[140] = c3_g[36];
    match c3_g[140] == 2 { true -> { c3_g[31]=c3_n[c3_g[139]*10+5]; do cg_expr(c3_g, c3_n, c3_s); do emit_line("    mov rsi, rax"); do emit_line("    mov rdi, 1"); do emit_line("    mov rax, 1"); do emit_line("    syscall"); },
    false -> match c3_g[140] == 9 { true -> { c3_g[31]=c3_n[c3_g[139]*10+5]; do cg_expr(c3_g, c3_n, c3_s); do emit_line("    mov rdi, rax"); do emit_line("    call _rt_get_arg"); },
    false -> match c3_g[140] == 7 { true -> { c3_g[31]=c3_n[c3_g[139]*10+5]; do cg_expr(c3_g, c3_n, c3_s); do emit_line("    mov rdi, rax"); do emit_line("    mov rsi, rdx"); do emit_line("    call _rt_read_file"); },
    false -> do cg_call4(c3_g, c3_n, c3_s) } } };
}
// cg_call4 — handle builtins: string_length, string_char_at, print_byte
fn cg_call4(c4_g: Array<Int>, c4_n: Array<Int>, c4_s: Array<Int>) [IO] -> Unit {
    match c4_g[140] == 4 { true -> { c4_g[31]=c4_n[c4_g[139]*10+5]; do cg_expr(c4_g, c4_n, c4_s); do emit_line("    mov rax, rdx"); },
    false -> match c4_g[140] == 6 { true -> do cg_bi_char(c4_g, c4_n, c4_s),
    false -> match c4_g[140] == 10 { true -> { c4_g[31]=c4_n[c4_g[139]*10+5]; do cg_expr(c4_g, c4_n, c4_s); do emit_line("    mov rdi, rax"); do emit_line("    call _rt_print_byte"); },
    false -> match c4_g[140] == 15 { true -> {
        // expose(sensitive_val, reason_str): write reason to stderr, pass through value
        // eval arg 1 (sensitive value) → save in r15
        c4_g[31]=c4_n[c4_g[139]*10+5]; do cg_expr(c4_g, c4_n, c4_s);
        do emit_line("    push rax"); do emit_line("    push rdx"); // save sensitive value
        // eval arg 2 (reason string) — next sibling of first arg
        c4_g[31]=c4_n[c4_n[c4_g[139]*10+5]*10+6]; do cg_expr(c4_g, c4_n, c4_s);
        // write reason to stderr (fd=2)
        do emit_line("    mov rsi, rax"); do emit_line("    mov rdi, 2"); do emit_line("    mov rax, 1"); do emit_line("    syscall");
        // write newline to stderr
        do emit_line("    lea rsi, [rel _newline_byte]"); do emit_line("    mov rdi, 2"); do emit_line("    mov rdx, 1"); do emit_line("    mov rax, 1"); do emit_line("    syscall");
        // restore sensitive value as result
        do emit_line("    pop rdx"); do emit_line("    pop rax");
    }, false -> do cg_call5(c4_g, c4_n, c4_s) } } } };
}

// cg_call5: string stdlib builtins (16-20)
fn cg_call5(c5_g: Array<Int>, c5_n: Array<Int>, c5_s: Array<Int>) [IO] -> Unit {
    match c5_g[140] == 16 { true -> {
        // substring(str, start, count) → new string
        // eval str → rdi/rsi (ptr/len)
        c5_g[31]=c5_n[c5_g[139]*10+5]; do cg_expr(c5_g, c5_n, c5_s);
        do emit_line("    push rax"); do emit_line("    push rdx");
        // eval start → rdx
        c5_g[31]=c5_n[c5_n[c5_g[139]*10+5]*10+6]; do cg_expr(c5_g, c5_n, c5_s);
        do emit_line("    push rax");
        // eval count → rcx
        c5_g[31]=c5_n[c5_n[c5_n[c5_g[139]*10+5]*10+6]*10+6]; do cg_expr(c5_g, c5_n, c5_s);
        do emit_line("    mov rcx, rax"); // count
        do emit_line("    pop rdx"); // start
        do emit_line("    pop rsi"); // str_len (was rdx of string)
        do emit_line("    pop rdi"); // str_ptr (was rax of string)
        // Actually: string returns (ptr=rax, len=rdx). We need (rdi=ptr, rsi=len, rdx=start, rcx=count)
        do emit_line("    mov rsi, rsi"); // len already in rsi from pop
        do emit_line("    call _rt_substring");
    },
    false -> match c5_g[140] == 17 { true -> {
        // string_starts_with(str, prefix) → Bool
        // Eval str → (rax=ptr, rdx=len), save to stack
        c5_g[31]=c5_n[c5_g[139]*10+5]; do cg_expr(c5_g, c5_n, c5_s);
        do emit_line("    push rax"); do emit_line("    push rdx");
        // Eval prefix → (rax=ptr, rdx=len)
        c5_g[31]=c5_n[c5_n[c5_g[139]*10+5]*10+6]; do cg_expr(c5_g, c5_n, c5_s);
        // Set up: rdi=str_ptr, rsi=str_len, rdx=prefix_ptr, rcx=prefix_len
        do emit_line("    mov rcx, rdx"); // rcx = prefix_len (BEFORE rdx is overwritten)
        do emit_line("    mov rdx, rax"); // rdx = prefix_ptr
        do emit_line("    pop rsi");      // rsi = str_len
        do emit_line("    pop rdi");      // rdi = str_ptr
        do emit_line("    call _rt_string_starts_with");
    },
    false -> match c5_g[140] == 18 { true -> {
        // string_index_of(str, char_code) → Int (-1 if not found)
        c5_g[31]=c5_n[c5_g[139]*10+5]; do cg_expr(c5_g, c5_n, c5_s);
        do emit_line("    mov rdi, rax"); do emit_line("    mov rsi, rdx"); // str ptr, len
        c5_g[31]=c5_n[c5_n[c5_g[139]*10+5]*10+6]; do cg_expr(c5_g, c5_n, c5_s);
        do emit_line("    mov rdx, rax"); // char code
        do emit_line("    call _rt_string_index_of");
    },
    false -> match c5_g[140] == 19 { true -> {
        // string_contains(str, sub) → Bool
        c5_g[31]=c5_n[c5_g[139]*10+5]; do cg_expr(c5_g, c5_n, c5_s);
        do emit_line("    push rax"); do emit_line("    push rdx");
        c5_g[31]=c5_n[c5_n[c5_g[139]*10+5]*10+6]; do cg_expr(c5_g, c5_n, c5_s);
        do emit_line("    mov rcx, rdx"); // sub_len (BEFORE rdx overwritten)
        do emit_line("    mov rdx, rax"); // sub_ptr
        do emit_line("    pop rsi");      // str_len
        do emit_line("    pop rdi");      // str_ptr
        do emit_line("    call _rt_string_contains");
    },
    false -> match c5_g[140] == 20 { true -> {
        // string_trim(str) → trimmed string
        c5_g[31]=c5_n[c5_g[139]*10+5]; do cg_expr(c5_g, c5_n, c5_s);
        do emit_line("    mov rdi, rax"); do emit_line("    mov rsi, rdx");
        do emit_line("    call _rt_string_trim");
    },
    false -> match c5_g[140] == 13 { true -> {
        // string_equals(str1, str2) → Bool
        // Eval str1 → (rax=ptr1, rdx=len1), save on stack
        c5_g[31]=c5_n[c5_g[139]*10+5]; do cg_expr(c5_g, c5_n, c5_s);
        do emit_line("    push rax"); do emit_line("    push rdx");
        // Eval str2 → (rax=ptr2, rdx=len2)
        c5_g[31]=c5_n[c5_n[c5_g[139]*10+5]*10+6]; do cg_expr(c5_g, c5_n, c5_s);
        // Now: rax=ptr2, rdx=len2. Stack: [ptr1, len1]
        // Need: rdi=ptr1, rsi=len1, rdx=ptr2, rcx=len2
        do emit_line("    mov rcx, rdx"); // rcx = len2 (save before rdx overwrite)
        do emit_line("    mov rdx, rax"); // rdx = ptr2
        do emit_line("    pop rsi");      // rsi = len1
        do emit_line("    pop rdi");      // rdi = ptr1
        do emit_line("    call _rt_string_equals");
    },
    false -> { } } } } } } };
}

// cg_bi_char — emit string_char_at builtin
fn cg_bi_char(bc_g: Array<Int>, bc_n: Array<Int>, bc_s: Array<Int>) [IO] -> Unit {
    bc_g[31]=bc_n[bc_g[139]*10+5]; do cg_expr(bc_g, bc_n, bc_s);
    do emit_line("    push rax");
    bc_g[31]=bc_n[bc_n[bc_g[139]*10+5]*10+6]; do cg_expr(bc_g, bc_n, bc_s);
    do emit_line("    pop rdi"); do emit_line("    movzx rax, byte [rdi + rax]");
}
// cg_user_call — emit call to user-defined function
fn cg_user_call(uc_g: Array<Int>, uc_n: Array<Int>, uc_s: Array<Int>) [IO] -> Unit {
    let uc_ni: Int = uc_g[31];
    let uc_ac: Int = uc_n[uc_ni * 10 + 4]; // arg count
    // Evaluate each arg and push to stack (reverse order for correct register assignment)
    let uc_ai: Array<Int> = Array(1);
    uc_ai[0] = uc_n[uc_ni * 10 + 5]; // first arg
    for _uca in range(0, uc_ac) {
        uc_g[31] = uc_ai[0]; do cg_expr(uc_g, uc_n, uc_s);
        do emit_line("    push rdx"); // push len (for String/Array)
        do emit_line("    push rax"); // push ptr/value
        uc_ai[0] = uc_n[uc_ai[0] * 10 + 6]; // next arg
    };
    // Pop args into registers (in reverse — last pushed = first popped)
    // For N args: pop arg_N into highest regs first, then arg_1 into rdi/rsi
    do cg_pop_args(uc_ac);
    // Emit call — direct for known functions, indirect for function pointers
    let uc_no: Int = uc_n[uc_ni * 10 + 2]; let uc_nl: Int = uc_n[uc_ni * 10 + 3];
    uc_g[40] = uc_no; uc_g[41] = uc_nl;
    match cg_is_fn(uc_g, uc_n, uc_s) == 1 {
        true -> {
            // Direct call to known function
            do print_raw("    call fn_");
            do cg_name(uc_s, uc_no, uc_nl);
            do emit_line("");
        },
        false -> {
            // Indirect call through function pointer variable
            uc_g[40] = uc_no; uc_g[41] = uc_nl;
            let uc_fp_off: Int = cg_find_var(uc_g, uc_s);
            do print_raw("    mov rax, qword [rbp-"); do print_raw(int_to_string(uc_fp_off)); do emit_line("]");
            do emit_line("    call rax");
        },
    };
    // Clean up stack-passed args for 4+ params
    match uc_ac >= 4 { true -> {
        do print_raw("    add rsp, "); do emit_line(int_to_string(uc_ac * 16));
    }, false -> { } };
}

// Pop N args from stack into ABI registers
// For N <= 3: all in registers. For N > 3: first 3 in regs, rest stay on stack.
fn cg_pop_args(pa_n: Int) [IO] -> Unit {
    match pa_n >= 4 { true -> {
        // 4+ args: leave ALL on stack. Callee reads from [rsp] after call.
        // Don't pop anything — the callee handles it.
        // After call returns, caller cleans up stack: add rsp, pa_n*16
    }, false -> match pa_n == 3 { true -> {
        do emit_line("    pop r8"); do emit_line("    pop r9");
        do emit_line("    pop rdx"); do emit_line("    pop rcx");
        do emit_line("    pop rdi"); do emit_line("    pop rsi");
    }, false -> match pa_n == 2 { true -> {
        do emit_line("    pop rdx"); do emit_line("    pop rcx");
        do emit_line("    pop rdi"); do emit_line("    pop rsi");
    }, false -> match pa_n == 1 { true -> {
        do emit_line("    pop rdi"); do emit_line("    pop rsi");
    }, false -> { } } } } };
}

// LET binding: evaluate initializer, store to stack slot
fn cg_let(cl_g: Array<Int>, cl_n: Array<Int>, cl_s: Array<Int>) [IO] -> Unit {
    let cl_ni: Int = cl_g[31];
    let cl_init: Int = cl_n[cl_ni * 10 + 5]; // first_child = initializer
    // Evaluate initializer
    cl_g[31] = cl_init; do cg_expr(cl_g, cl_n, cl_s);
    // Find this variable's stack offset
    cl_g[40] = cl_n[cl_ni * 10 + 2]; cl_g[41] = cl_n[cl_ni * 10 + 3];
    let cl_off: Int = cg_find_var(cl_g, cl_s);
    let cl_tp: Int = cg_find_var_type(cl_g, cl_s);
    match cl_tp % 16 == 2 { true -> { // String (inc. privacy-wrapped): store ptr and len
        do print_raw("    mov qword [rbp-"); do print_raw(int_to_string(cl_off)); do emit_line("], rax");
        do print_raw("    mov qword [rbp-"); do print_raw(int_to_string(cl_off - 8)); do emit_line("], rdx");
    }, false -> match cl_tp % 16 == 4 { true -> { // Array (inc. privacy-wrapped): store ptr and len
        do print_raw("    mov qword [rbp-"); do print_raw(int_to_string(cl_off)); do emit_line("], rax");
        do print_raw("    mov qword [rbp-"); do print_raw(int_to_string(cl_off - 8)); do emit_line("], rdx");
    }, false -> { // Int/Bool/other: store single value
        do print_raw("    mov qword [rbp-"); do print_raw(int_to_string(cl_off)); do emit_line("], rax");
    } } }
}

// Array set stub — M2.2f
// arr[i] = val: store value at array index
fn cg_aryset(ca_g: Array<Int>, ca_n: Array<Int>, ca_s: Array<Int>) [IO] -> Unit {
    ca_g[170] = ca_g[31];
    ca_g[40] = ca_n[ca_g[170]*10+2]; ca_g[41] = ca_n[ca_g[170]*10+3];
    ca_g[171] = cg_find_var(ca_g, ca_s);
    do print_raw("    mov r10, qword [rbp-"); do print_raw(int_to_string(ca_g[171])); do emit_line("]");
    do emit_line("    push r10"); // save array ptr (r10 clobbered by value eval)
    ca_g[31] = ca_n[ca_g[170]*10+5]; do cg_expr(ca_g, ca_n, ca_s);
    do emit_line("    push rax"); // save index
    ca_g[31] = ca_n[ca_n[ca_g[170]*10+5]*10+6]; do cg_expr(ca_g, ca_n, ca_s);
    do emit_line("    pop rcx"); // index
    do emit_line("    pop r10"); // array ptr
    do emit_line("    mov qword [r10 + rcx*8], rax");
}

// Find variable stack offset by name — g[40]=name_off, g[41]=name_len
fn cg_find_var(fv_g: Array<Int>, fv_s: Array<Int>) [] -> Int {
    let fv_o: Int = fv_g[40]; let fv_l: Int = fv_g[41];
    let fv_res: Array<Int> = Array(1); fv_res[0] = 8;
    let fv_b: Array<Int> = Array(1);
    for fv_i in range(0, fv_g[50]) {
        fv_b[0] = 51 + fv_i * 4;
        match fv_g[fv_b[0] + 1] == fv_l { true -> {
            fv_g[40] = fv_o; fv_g[41] = fv_g[fv_b[0]]; fv_g[42] = fv_l;
            match cg_name_eq(fv_g, fv_s) { true -> { fv_res[0] = fv_g[fv_b[0] + 2]; }, false -> { } };
            fv_g[40] = fv_o; fv_g[41] = fv_l;
        }, false -> { } };
    };
    fv_res[0]
}

// cg_is_fn — check if name at g[40]/g[41] is a top-level function. Returns 1 if yes, 0 if no.
fn cg_is_fn(cf_g: Array<Int>, cf_n: Array<Int>, cf_s: Array<Int>) [] -> Int {
    let cf_o: Int = cf_g[40]; let cf_l: Int = cf_g[41];
    let cf_found: Array<Int> = Array(1); cf_found[0] = 0;
    for cf_i in range(0, cf_g[12]) {
        match cf_n[cf_i * 10] == 1 { true -> {
            match cf_n[cf_i * 10 + 3] == cf_l { true -> {
                cf_g[40] = cf_o; cf_g[41] = cf_n[cf_i * 10 + 2]; cf_g[42] = cf_l;
                match cg_name_eq(cf_g, cf_s) { true -> { cf_found[0] = 1; }, false -> { } };
                cf_g[40] = cf_o; cf_g[41] = cf_l;
            }, false -> { } };
        }, false -> { } };
    };
    cf_found[0]
}

// cg_find_var_type — look up variable type in var table
fn cg_find_var_type(ft_g: Array<Int>, ft_s: Array<Int>) [] -> Int {
    let ft_o: Int = ft_g[40]; let ft_l: Int = ft_g[41];
    let ft_res: Array<Int> = Array(1); ft_res[0] = 0;
    let ft_b: Array<Int> = Array(1);
    for ft_i in range(0, ft_g[50]) {
        ft_b[0] = 51 + ft_i * 4;
        match ft_g[ft_b[0] + 1] == ft_l { true -> {
            ft_g[40] = ft_o; ft_g[41] = ft_g[ft_b[0]]; ft_g[42] = ft_l;
            match cg_name_eq(ft_g, ft_s) { true -> { ft_res[0] = ft_g[ft_b[0] + 3]; }, false -> { } };
            ft_g[40] = ft_o; ft_g[41] = ft_l;
        }, false -> { } };
    };
    ft_res[0]
}

// Compare two names: s[g[40]..+g[42]] == s[g[41]..+g[42]]
fn cg_name_eq(ne_g: Array<Int>, ne_s: Array<Int>) [] -> Bool {
    let ne_a: Int = ne_g[40]; let ne_b: Int = ne_g[41]; let ne_l: Int = ne_g[42];
    let ne_ok: Array<Int> = Array(1); ne_ok[0] = 1;
    for ne_i in range(0, ne_l) {
        match ne_s[ne_a + ne_i] == ne_s[ne_b + ne_i] { true -> { }, false -> { ne_ok[0] = 0; } };
    };
    match ne_ok[0] == 1 { true -> true, false -> false }
}

// ===== Type Checker + Effect Verifier =====
// gs[910] = --json flag, gs[911] = error count

// tc_type_name — convert type_info to human-readable name
fn tc_type_name(tn_t: Int) [] -> String {
    match tn_t { 0 -> "Int", 2 -> "String", 4 -> "Array", 6 -> "ADT", _ -> "Unknown" }
}

// Report a type error. g[905]=node, g[906]=kind (1=type_mismatch, 2=undeclared_effect), g[907]=expected, g[908]=received
fn tc_error(te_g: Array<Int>, te_n: Array<Int>, te_s: Array<Int>) [IO] -> Unit {
    te_g[911] = te_g[911] + 1;
    let te_kind: String = match te_g[906] { 1 -> "type_mismatch", 2 -> "undeclared_effect", 3 -> "undefined_variable", 4 -> "wrong_arg_count", 5 -> "return_type_mismatch", 6 -> "undefined_function", _ -> "error" };
    match te_g[910] == 1 { true -> {
        // JSON output
        do print_byte(123);
        do print_byte(34); do print_raw("error"); do print_byte(34); do print_raw(":");
        do print_byte(34); do print_raw(te_kind); do print_byte(34);
        match te_g[906] == 2 { true -> {
            do print_raw(","); do print_byte(34); do print_raw("function"); do print_byte(34); do print_raw(":");
            do print_byte(34);
            let te_fo: Int = te_n[te_g[905] * 10 + 2]; let te_fl: Int = te_n[te_g[905] * 10 + 3];
            for te_i in range(0, te_fl) { do print_byte(te_s[te_fo + te_i]); };
            do print_byte(34);
        }, false -> { } };
        match te_g[906] == 1 { true -> {
            do print_raw(","); do print_byte(34); do print_raw("expected"); do print_byte(34); do print_raw(":");
            do print_byte(34); do print_raw(tc_type_name(te_g[907])); do print_byte(34);
            do print_raw(","); do print_byte(34); do print_raw("received"); do print_byte(34); do print_raw(":");
            do print_byte(34); do print_raw(tc_type_name(te_g[908])); do print_byte(34);
        }, false -> { } };
        do print_byte(125);
        do print("");
    }, false -> {
        do print_raw("error: ");
        match te_g[906] == 1 { true -> {
            do print_raw("type mismatch: expected "); do print_raw(tc_type_name(te_g[907]));
            do print_raw(", got "); do print_raw(tc_type_name(te_g[908])); do print(" — change the value type or the annotation");
        }, false -> match te_g[906] == 2 { true -> {
            do print_raw("undeclared effect: function ");
            let te_fo2: Int = te_n[te_g[905] * 10 + 2]; let te_fl2: Int = te_n[te_g[905] * 10 + 3];
            for te_i2 in range(0, te_fl2) { do print_byte(te_s[te_fo2 + te_i2]); };
            do print(" uses IO but declares []");
        }, false -> match te_g[906] == 3 { true -> {
            do print_raw("undefined variable: ");
            let te_fo3: Int = te_n[te_g[905] * 10 + 2]; let te_fl3: Int = te_n[te_g[905] * 10 + 3];
            for te_i3 in range(0, te_fl3) { do print_byte(te_s[te_fo3 + te_i3]); };
            do print("");
        }, false -> match te_g[906] == 4 { true -> {
            do print_raw("wrong argument count: expected "); do print_raw(int_to_string(te_g[907]));
            do print_raw(", got "); do print(int_to_string(te_g[908]));
        }, false -> match te_g[906] == 5 { true -> {
            do print_raw("return type mismatch: declared "); do print_raw(tc_type_name(te_g[907]));
            do print_raw(", returns "); do print_raw(tc_type_name(te_g[908])); do print(" — change the return type or the last expression");
        }, false -> match te_g[906] == 6 { true -> {
            do print_raw("undefined function: ");
            let te_fo6: Int = te_n[te_g[905] * 10 + 2]; let te_fl6: Int = te_n[te_g[905] * 10 + 3];
            for te_i6 in range(0, te_fl6) { do print_byte(te_s[te_fo6 + te_i6]); };
            do print("");
        }, false -> do print("unknown error") } } } } } };
    } };
}

// Look up function return type by name at g[40]/g[41]
fn tc_fn_ret_type(fr_g: Array<Int>, fr_n: Array<Int>, fr_s: Array<Int>) [] -> Int {
    let fr_res: Array<Int> = Array(1); fr_res[0] = 0;
    for fr_fi in range(0, fr_g[12]) {
        match fr_n[fr_fi * 10] == 1 { true -> {
            match fr_n[fr_fi * 10 + 3] == fr_g[41] { true -> {
                fr_g[42] = fr_g[41];
                let fr_sv41: Int = fr_g[41];
                fr_g[41] = fr_n[fr_fi * 10 + 2];
                match cg_name_eq(fr_g, fr_s) { true -> { fr_res[0] = fr_n[fr_fi * 10 + 7]; }, false -> { } };
                fr_g[41] = fr_sv41;
            }, false -> { } };
        }, false -> { } };
    };
    fr_res[0]
}

// Look up function effects by name at g[40]/g[41]. Only checks builtins if not user-defined.
fn tc_fn_effects(fe_g: Array<Int>, fe_n: Array<Int>, fe_s: Array<Int>) [] -> Int {
    let fe_res: Array<Int> = Array(1); fe_res[0] = 0;
    let fe_found: Array<Int> = Array(1); fe_found[0] = 0;
    for fe_fi in range(0, fe_g[12]) {
        match fe_n[fe_fi * 10] == 1 { true -> {
            match fe_n[fe_fi * 10 + 3] == fe_g[41] { true -> {
                fe_g[42] = fe_g[41];
                let fe_sv41: Int = fe_g[41];
                fe_g[41] = fe_n[fe_fi * 10 + 2];
                match cg_name_eq(fe_g, fe_s) { true -> { fe_res[0] = fe_n[fe_fi * 10 + 9]; fe_found[0] = 1; }, false -> { } };
                fe_g[41] = fe_sv41;
            }, false -> { } };
        }, false -> { } };
    };
    // Builtins (only if not found as user function): print* exit read_file = IO
    match fe_found[0] == 0 { true -> {
        let fe_fc: Int = fe_s[fe_g[40]];
        match fe_fc == 112 { true -> { fe_res[0] = 1; }, false -> { } }; // print* → IO
        match fe_fc == 114 { true -> { fe_res[0] = 1; }, false -> { } }; // read_file → IO
        match fe_fc == 101 { true -> match fe_g[41] == 6 { true -> { fe_res[0] = 2; }, false -> { fe_res[0] = 1; } }, false -> { } }; // expose(6)→Audit, exit(4)→IO
        match fe_fc == 103 { true -> { fe_res[0] = 1; }, false -> { } }; // get_arg → IO
    }, false -> { } };
    fe_res[0]
}

// Effect checker: iterative scan for DO_EXPR → CALL within pure function boundaries
fn tc_check_effects(ce_g: Array<Int>, ce_n: Array<Int>, ce_s: Array<Int>) [IO] -> Unit {
    for ce_fi in range(0, ce_g[12]) {
        match ce_n[ce_fi * 10] == 1 { true -> {
            match ce_n[ce_fi * 10 + 9] == 0 { true -> {
                // Pure function — find boundary
                let ce_end: Array<Int> = Array(1); ce_end[0] = ce_g[12];
                for ce_bi in range(ce_fi + 1, ce_g[12]) {
                    match ce_n[ce_bi * 10] == 1 { true -> match ce_end[0] == ce_g[12] { true -> { ce_end[0] = ce_bi; }, false -> { } }, false -> { } };
                    match ce_n[ce_bi * 10] == 22 { true -> match ce_end[0] == ce_g[12] { true -> { ce_end[0] = ce_bi; }, false -> { } }, false -> { } };
                };
                // Scan for DO_EXPR → CALL and bare CALL to IO function
                let ce_found_io: Array<Int> = Array(1); ce_found_io[0] = 0;
                for ce_ni in range(ce_fi + 1, ce_end[0]) {
                    match ce_n[ce_ni * 10] == 15 { true -> {
                        let ce_call: Int = ce_n[ce_ni * 10 + 5];
                        match ce_call >= 1 { true -> match ce_n[ce_call * 10] == 14 { true -> {
                            ce_g[40] = ce_n[ce_call * 10 + 2]; ce_g[41] = ce_n[ce_call * 10 + 3];
                            match tc_fn_effects(ce_g, ce_n, ce_s) == 1 { true -> { ce_found_io[0] = 1; }, false -> { } };
                        }, false -> { } }, false -> { } };
                    }, false -> { } };
                    // Also check bare CALL nodes (IO builtins used as expressions)
                    match ce_n[ce_ni * 10] == 14 { true -> {
                        ce_g[40] = ce_n[ce_ni * 10 + 2]; ce_g[41] = ce_n[ce_ni * 10 + 3];
                        match tc_fn_effects(ce_g, ce_n, ce_s) == 1 { true -> { ce_found_io[0] = 1; }, false -> { } };
                    }, false -> { } };
                };
                match ce_found_io[0] == 1 { true -> {
                    ce_g[905] = ce_fi; ce_g[906] = 2; ce_g[907] = 0; ce_g[908] = 0;
                    do tc_error(ce_g, ce_n, ce_s);
                }, false -> { } };
            }, false -> { } };
            // Audit effect check: if function doesn't have Audit (bit 1),
            // check if any call requires it (expose builtin = effect 2)
            match ce_n[ce_fi * 10 + 9] / 2 % 2 == 0 { true -> {
                // No Audit declared — scan for expose() calls
                let ce_end2: Array<Int> = Array(1); ce_end2[0] = ce_g[12];
                for ce_b2 in range(ce_fi + 1, ce_g[12]) {
                    match ce_n[ce_b2 * 10] == 1 { true -> match ce_end2[0] == ce_g[12] { true -> { ce_end2[0] = ce_b2; }, false -> { } }, false -> { } };
                    match ce_n[ce_b2 * 10] == 22 { true -> match ce_end2[0] == ce_g[12] { true -> { ce_end2[0] = ce_b2; }, false -> { } }, false -> { } };
                };
                for ce_n2 in range(ce_fi + 1, ce_end2[0]) {
                    match ce_n[ce_n2 * 10] == 14 { true -> {
                        ce_g[40] = ce_n[ce_n2 * 10 + 2]; ce_g[41] = ce_n[ce_n2 * 10 + 3];
                        match tc_fn_effects(ce_g, ce_n, ce_s) == 2 { true -> {
                            do print("error: undeclared effect: function uses Audit but declares without it");
                            ce_g[911] = ce_g[911] + 1;
                        }, false -> { } };
                    }, false -> { } };
                };
            }, false -> { } };
        }, false -> { } };
    };
}

// Main type check entry point
// Type mismatch check: scan LET nodes with type annotations
fn tc_check_types(tt_g: Array<Int>, tt_n: Array<Int>, tt_s: Array<Int>) [IO] -> Unit {
    for tt_ni in range(0, tt_g[12]) {
        match tt_n[tt_ni * 10] == 4 { true -> {
            let tt_decl: Int = tt_n[tt_ni * 10 + 7];
            match tt_n[tt_ni * 10 + 9] == 1 { true -> {
                let tt_init: Int = tt_n[tt_ni * 10 + 5];
                match tt_init >= 1 { true -> {
                    let tt_init_nt: Int = tt_n[tt_init * 10];
                    // Only check literals with unambiguous types
                    // INT_LIT(7)/BOOL_LIT(9) → 0 (Int), STR_LIT(8) → 2 (String)
                    let tt_can_check: Int = match tt_init_nt == 7 { true -> 1, false -> match tt_init_nt == 8 { true -> 1, false -> match tt_init_nt == 9 { true -> 1, false -> 0 } } };
                    match tt_can_check == 1 { true -> {
                        let tt_actual: Int = match tt_init_nt == 8 { true -> 2, false -> 0 };
                        match tt_decl == 2 { true -> match tt_actual == 0 { true -> {
                            tt_g[905]=tt_ni; tt_g[906]=1; tt_g[907]=2; tt_g[908]=0; do tc_error(tt_g, tt_n, tt_s);
                        }, false -> { } }, false -> { } };
                        match tt_decl == 0 { true -> match tt_actual == 2 { true -> {
                            tt_g[905]=tt_ni; tt_g[906]=1; tt_g[907]=0; tt_g[908]=2; do tc_error(tt_g, tt_n, tt_s);
                        }, false -> { } }, false -> { } };
                    }, false -> { } };
                }, false -> { } };
            }, false -> { } };
        }, false -> { } };
    };
}

// Undefined variable check: scan each function, collect declared names, verify IDENT_REFs
fn tc_check_undef(tu_g: Array<Int>, tu_n: Array<Int>, tu_s: Array<Int>) [IO] -> Unit {
    for tu_fi in range(0, tu_g[12]) {
        match tu_n[tu_fi * 10] == 1 { true -> {
            // Find function boundary
            let tu_end: Array<Int> = Array(1); tu_end[0] = tu_g[12];
            for tu_bi in range(tu_fi + 1, tu_g[12]) {
                match tu_n[tu_bi * 10] == 1 { true -> match tu_end[0] == tu_g[12] { true -> { tu_end[0] = tu_bi; }, false -> { } }, false -> { } };
                match tu_n[tu_bi * 10] == 22 { true -> match tu_end[0] == tu_g[12] { true -> { tu_end[0] = tu_bi; }, false -> { } }, false -> { } };
            };
            // Collect declared names: params (type 2) and let bindings (type 4) and for vars (type 18)
            // Store in g[4400..5999] as (off, len) pairs — room for 800 names
            let tu_dc: Array<Int> = Array(1); tu_dc[0] = 0;
            for tu_ni in range(tu_fi, tu_end[0]) {
                let tu_nt: Int = tu_n[tu_ni * 10];
                match tu_nt == 2 { true -> { tu_g[4400 + tu_dc[0] * 2] = tu_n[tu_ni * 10 + 2]; tu_g[4400 + tu_dc[0] * 2 + 1] = tu_n[tu_ni * 10 + 3]; tu_dc[0] = tu_dc[0] + 1; }, false -> { } };
                match tu_nt == 4 { true -> { tu_g[4400 + tu_dc[0] * 2] = tu_n[tu_ni * 10 + 2]; tu_g[4400 + tu_dc[0] * 2 + 1] = tu_n[tu_ni * 10 + 3]; tu_dc[0] = tu_dc[0] + 1; }, false -> { } };
                match tu_nt == 18 { true -> { tu_g[4400 + tu_dc[0] * 2] = tu_n[tu_ni * 10 + 2]; tu_g[4400 + tu_dc[0] * 2 + 1] = tu_n[tu_ni * 10 + 3]; tu_dc[0] = tu_dc[0] + 1; }, false -> { } };
            };
            // Check every IDENT_REF (type 10) in this function against declared names
            for tu_ni2 in range(tu_fi + 1, tu_end[0]) {
                match tu_n[tu_ni2 * 10] == 10 { true -> {
                    let tu_ref_off: Int = tu_n[tu_ni2 * 10 + 2];
                    let tu_ref_len: Int = tu_n[tu_ni2 * 10 + 3];
                    let tu_found: Array<Int> = Array(1); tu_found[0] = 0;
                    for tu_di in range(0, tu_dc[0]) {
                        match tu_g[4400 + tu_di * 2 + 1] == tu_ref_len { true -> {
                            tu_g[40] = tu_ref_off; tu_g[41] = tu_g[4400 + tu_di * 2]; tu_g[42] = tu_ref_len;
                            match cg_name_eq(tu_g, tu_s) { true -> { tu_found[0] = 1; }, false -> { } };
                        }, false -> { } };
                    };
                    match tu_found[0] == 0 { true -> {
                        // Check if it's a function name used as a value (function reference)
                        tu_g[40] = tu_ref_off; tu_g[41] = tu_ref_len;
                        let tu_is_fn: Int = cg_is_fn(tu_g, tu_n, tu_s);
                        match tu_is_fn == 1 { true -> { }, false -> {
                            tu_g[905] = tu_ni2; tu_g[906] = 3; tu_g[907] = 0; tu_g[908] = 0;
                            do tc_error(tu_g, tu_n, tu_s);
                        } };
                    }, false -> { } };
                }, false -> { } };
            };
        }, false -> { } };
    };
}

// Wrong argument count check: compare CALL child_count against FN_DECL param_count
// tc_args_priv — check privacy downcast for one arg-param pair
// g[4200]=arg node, g[4202]=param type. If arg is IDENT_REF with higher privacy → error.
fn tc_args_priv(ap_g: Array<Int>, ap_n: Array<Int>, ap_s: Array<Int>, ap_call_ni: Int) [IO] -> Unit {
    match ap_n[ap_g[4200] * 10] == 10 { true -> {
        ap_g[4205] = 0 - 1;
        for ap_vi in range(0, ap_call_ni) {
            ap_g[4206] = ap_n[ap_vi * 10];
            match ap_g[4206] == 4 { true -> {
                ap_g[40] = ap_n[ap_g[4200] * 10 + 2]; ap_g[42] = ap_n[ap_g[4200] * 10 + 3];
                ap_g[41] = ap_n[ap_vi * 10 + 2];
                match ap_g[42] == ap_n[ap_vi * 10 + 3] { true -> match cg_name_eq(ap_g, ap_s) { true -> { ap_g[4205] = ap_n[ap_vi * 10 + 7]; }, false -> { } }, false -> { } };
            }, false -> { } };
            match ap_g[4206] == 2 { true -> {
                ap_g[40] = ap_n[ap_g[4200] * 10 + 2]; ap_g[42] = ap_n[ap_g[4200] * 10 + 3];
                ap_g[41] = ap_n[ap_vi * 10 + 2];
                match ap_g[42] == ap_n[ap_vi * 10 + 3] { true -> match cg_name_eq(ap_g, ap_s) { true -> { ap_g[4205] = ap_n[ap_vi * 10 + 7]; }, false -> { } }, false -> { } };
            }, false -> { } };
        };
        match ap_g[4205] >= 0 { true -> match ap_g[4205] / 16 > ap_g[4202] / 16 { true -> {
            do print("error: cannot pass Sensitive value to less restrictive parameter — use expose()");
            ap_g[911] = ap_g[911] + 1;
        }, false -> { } }, false -> { } };
    }, false -> { } };
}

// tc_args_undef — check if undefined call name is a local variable (function pointer)
fn tc_args_undef(au_g: Array<Int>, au_n: Array<Int>, au_s: Array<Int>, au_call_ni: Int) [IO] -> Unit {
    au_g[40] = au_n[au_call_ni * 10 + 2]; au_g[42] = au_n[au_call_ni * 10 + 3];
    let au_is_var: Array<Int> = Array(1); au_is_var[0] = 0;
    let au_fn_start: Array<Int> = Array(1); au_fn_start[0] = 0;
    for au_si in range(0, au_call_ni) {
        match au_n[au_si * 10] == 1 { true -> { au_fn_start[0] = au_si; }, false -> { } };
    };
    for au_vi in range(au_fn_start[0], au_call_ni) {
        let au_vnt: Int = au_n[au_vi * 10];
        match au_vnt == 2 { true -> {
            match au_n[au_vi * 10 + 3] == au_g[42] { true -> {
                au_g[41] = au_n[au_vi * 10 + 2];
                match cg_name_eq(au_g, au_s) { true -> { au_is_var[0] = 1; }, false -> { } };
            }, false -> { } };
        }, false -> match au_vnt == 4 { true -> {
            match au_n[au_vi * 10 + 3] == au_g[42] { true -> {
                au_g[41] = au_n[au_vi * 10 + 2];
                match cg_name_eq(au_g, au_s) { true -> { au_is_var[0] = 1; }, false -> { } };
            }, false -> { } };
        }, false -> { } } };
    };
    match au_is_var[0] == 0 { true -> {
        au_g[905] = au_call_ni; au_g[906] = 6; au_g[907] = 0; au_g[908] = 0;
        do tc_error(au_g, au_n, au_s);
    }, false -> { } };
}

// tc_args_types — check arg count + types for one CALL against its FN_DECL
fn tc_args_types(at_g: Array<Int>, at_n: Array<Int>, at_s: Array<Int>, at_call_ni: Int) [IO] -> Int {
    let at_call_ac: Int = at_n[at_call_ni * 10 + 4];
    at_g[40] = at_n[at_call_ni * 10 + 2]; at_g[41] = at_n[at_call_ni * 10 + 3];
    let at_found: Array<Int> = Array(1); at_found[0] = 0;
    for at_fi in range(0, at_g[12]) {
        match at_n[at_fi * 10] == 1 { true -> {
            match at_n[at_fi * 10 + 3] == at_g[41] { true -> {
                at_g[42] = at_g[41];
                let at_sv41: Int = at_g[41];
                at_g[41] = at_n[at_fi * 10 + 2];
                match cg_name_eq(at_g, at_s) { true -> {
                    let at_expected: Int = at_n[at_fi * 10 + 4];
                    match at_expected == at_call_ac { true -> { }, false -> {
                        at_g[905] = at_call_ni; at_g[906] = 4; at_g[907] = at_expected; at_g[908] = at_call_ac;
                        do tc_error(at_g, at_n, at_s);
                    } };
                    at_found[0] = 1;
                    // Check arg types
                    at_g[4200] = at_n[at_call_ni * 10 + 5];
                    at_g[4201] = at_n[at_fi * 10 + 5];
                    for _atc in range(0, at_expected) {
                        match at_g[4200] >= 1 { true -> match at_g[4201] >= 1 { true -> {
                            at_g[4202] = at_n[at_g[4201] * 10 + 7];
                            at_g[4203] = at_n[at_g[4200] * 10];
                            at_g[4204] = 0 - 1;
                            match at_g[4203] == 7 { true -> { at_g[4204] = 0; }, false -> { } };
                            match at_g[4203] == 8 { true -> { at_g[4204] = 2; }, false -> { } };
                            match at_g[4203] == 9 { true -> { at_g[4204] = 1; }, false -> { } };
                            match at_g[4204] >= 0 { true -> match at_g[4204] == at_g[4202] { true -> { }, false -> {
                                at_g[905] = at_call_ni; at_g[906] = 1; at_g[907] = at_g[4202]; at_g[908] = at_g[4204];
                                do tc_error(at_g, at_n, at_s);
                            } }, false -> { } };
                            do tc_args_priv(at_g, at_n, at_s, at_call_ni);
                            at_g[4200] = at_n[at_g[4200] * 10 + 6];
                            at_g[4201] = at_n[at_g[4201] * 10 + 6];
                        }, false -> { } }, false -> { } };
                    };
                }, false -> { } };
                at_g[41] = at_sv41;
            }, false -> { } };
        }, false -> { } };
    };
    at_found[0]
}

// tc_check_args — orchestrator: for each CALL, check args + types + undefined
fn tc_check_args(ta_g: Array<Int>, ta_n: Array<Int>, ta_s: Array<Int>) [IO] -> Unit {
    for ta_ni in range(0, ta_g[12]) {
        match ta_n[ta_ni * 10] == 14 { true -> {
            ta_g[40] = ta_n[ta_ni * 10 + 2]; ta_g[41] = ta_n[ta_ni * 10 + 3];
            let ta_is_bi: Int = chk_bi(ta_g, ta_s);
            match ta_is_bi == 0 { true -> {
                let ta_found: Int = tc_args_types(ta_g, ta_n, ta_s, ta_ni);
                match ta_found == 0 { true -> do tc_args_undef(ta_g, ta_n, ta_s, ta_ni), false -> { } };
            }, false -> { } };
        }, false -> { } };
    };
}

// Return type check: verify last expression in body matches declared return type
// tc_ret_find_last — find last child node of a block (the return expression)
fn tc_ret_find_last(rl_n: Array<Int>, rl_body: Int) [] -> Int {
    let rl_cc: Int = rl_n[rl_body * 10 + 4];
    match rl_cc >= 1 { true -> {
        let rl_cur: Array<Int> = Array(1); rl_cur[0] = rl_n[rl_body * 10 + 5];
        for _rl in range(0, rl_cc - 1) {
            let rl_ns: Int = rl_n[rl_cur[0] * 10 + 6];
            match rl_ns >= 1 { true -> { rl_cur[0] = rl_ns; }, false -> { } };
        };
        rl_cur[0]
    }, false -> 0 - 1 }
}

// tc_ret_check_priv — check IDENT_REF return for privacy downcast
fn tc_ret_check_priv(rp_g: Array<Int>, rp_n: Array<Int>, rp_s: Array<Int>, rp_expr: Int, rp_fi: Int, rp_ret: Int) [IO] -> Unit {
    let rp_voff: Int = rp_n[rp_expr * 10 + 2];
    let rp_vlen: Int = rp_n[rp_expr * 10 + 3];
    for rp_vi in range(rp_fi, rp_fi + 200) {
        match rp_vi < rp_g[12] { true -> {
            let rp_vnt: Int = rp_n[rp_vi * 10];
            match rp_vnt == 2 { true -> match rp_n[rp_vi * 10 + 3] == rp_vlen { true -> {
                rp_g[40] = rp_voff; rp_g[41] = rp_n[rp_vi * 10 + 2]; rp_g[42] = rp_vlen;
                match cg_name_eq(rp_g, rp_s) { true -> match rp_n[rp_vi * 10 + 7] / 16 > rp_ret / 16 { true -> {
                    do print("error: cannot return Sensitive value as less restrictive type — use expose()");
                    rp_g[911] = rp_g[911] + 1;
                }, false -> { } }, false -> { } };
            }, false -> { } }, false -> { } };
            match rp_vnt == 4 { true -> match rp_n[rp_vi * 10 + 3] == rp_vlen { true -> {
                rp_g[40] = rp_voff; rp_g[41] = rp_n[rp_vi * 10 + 2]; rp_g[42] = rp_vlen;
                match cg_name_eq(rp_g, rp_s) { true -> match rp_n[rp_vi * 10 + 7] / 16 > rp_ret / 16 { true -> {
                    do print("error: cannot return Sensitive value as less restrictive type — use expose()");
                    rp_g[911] = rp_g[911] + 1;
                }, false -> { } }, false -> { } };
            }, false -> { } }, false -> { } };
        }, false -> { } };
    };
}

// tc_check_return — verify last expression type matches declared return type
fn tc_check_return(tr_g: Array<Int>, tr_n: Array<Int>, tr_s: Array<Int>) [IO] -> Unit {
    for tr_fi in range(0, tr_g[12]) {
        match tr_n[tr_fi * 10] == 1 { true -> {
            let tr_ret_type: Int = tr_n[tr_fi * 10 + 7];
            let tr_body: Int = tr_n[tr_fi * 10 + 8];
            match tr_body >= 1 { true -> {
                let tr_last: Int = tc_ret_find_last(tr_n, tr_body);
                match tr_last >= 0 { true -> match tr_n[tr_last * 10] == 6 { true -> {
                    let tr_expr: Int = tr_n[tr_last * 10 + 5];
                    match tr_expr >= 1 { true -> {
                        let tr_nt: Int = tr_n[tr_expr * 10];
                        let tr_actual: Int = match tr_nt == 8 { true -> 2, false -> match tr_nt == 7 { true -> 0, false -> match tr_nt == 9 { true -> 0, false -> 0 - 1 } } };
                        match tr_actual >= 0 { true -> {
                            match tr_ret_type % 16 == 0 { true -> match tr_actual == 2 { true -> {
                                tr_g[905]=tr_fi; tr_g[906]=5; tr_g[907]=0; tr_g[908]=2; do tc_error(tr_g, tr_n, tr_s);
                            }, false -> { } }, false -> { } };
                            match tr_ret_type % 16 == 2 { true -> match tr_actual == 0 { true -> {
                                tr_g[905]=tr_fi; tr_g[906]=5; tr_g[907]=2; tr_g[908]=0; do tc_error(tr_g, tr_n, tr_s);
                            }, false -> { } }, false -> { } };
                        }, false -> { } };
                        match tr_nt == 10 { true -> do tc_ret_check_priv(tr_g, tr_n, tr_s, tr_expr, tr_fi, tr_ret_type), false -> { } };
                    }, false -> { } };
                }, false -> { } }, false -> { } };
            }, false -> { } };
        }, false -> { } };
    };
}

// Privacy check: cannot log Sensitive values via print/print_raw
// tc_priv_ref_check — check if IDENT_REF node matches any sensitive var in g[4510+]
// g[4501] = sensitive var count. Sets g[911]++ and prints error if match.
fn tc_priv_ref_check(pr_g: Array<Int>, pr_n: Array<Int>, pr_s: Array<Int>, pr_ni: Int) [IO] -> Int {
    let pr_found: Array<Int> = Array(1); pr_found[0] = 0;
    match pr_ni >= 0 { true -> match pr_n[pr_ni * 10] == 10 { true -> {
        for pr_vi in range(0, pr_g[4501]) {
            pr_g[40] = pr_n[pr_ni * 10 + 2]; pr_g[42] = pr_n[pr_ni * 10 + 3];
            pr_g[41] = pr_g[4510 + pr_vi * 2];
            match pr_g[42] == pr_g[4510 + pr_vi * 2 + 1] { true -> match cg_name_eq(pr_g, pr_s) { true -> {
                pr_found[0] = 1;
            }, false -> { } }, false -> { } };
        };
    }, false -> { } }, false -> { } };
    pr_found[0]
}

// tc_priv_collect — collect sensitive variable names for a function
// Scans range [fn_start..fn_end) for PARAM(2) and LET(4) with privacy >= 2
// Stores in g[4510+i*2] = (str_off, str_len). Sets g[4501] = count.
fn tc_priv_collect(pc_g: Array<Int>, pc_n: Array<Int>, pc_start: Int, pc_end: Int) [] -> Unit {
    pc_g[4501] = 0;
    for pc_ni in range(pc_start, pc_end) {
        match pc_n[pc_ni * 10] == 4 { true -> match pc_n[pc_ni * 10 + 7] / 16 >= 2 { true -> {
            pc_g[4510 + pc_g[4501] * 2] = pc_n[pc_ni * 10 + 2];
            pc_g[4510 + pc_g[4501] * 2 + 1] = pc_n[pc_ni * 10 + 3];
            pc_g[4501] = pc_g[4501] + 1;
        }, false -> { } }, false -> { } };
        match pc_n[pc_ni * 10] == 2 { true -> match pc_n[pc_ni * 10 + 7] / 16 >= 2 { true -> {
            pc_g[4510 + pc_g[4501] * 2] = pc_n[pc_ni * 10 + 2];
            pc_g[4510 + pc_g[4501] * 2 + 1] = pc_n[pc_ni * 10 + 3];
            pc_g[4501] = pc_g[4501] + 1;
        }, false -> { } }, false -> { } };
    };
}

// tc_priv_check_log — check print/print_raw calls for sensitive refs
fn tc_priv_check_log(pl_g: Array<Int>, pl_n: Array<Int>, pl_s: Array<Int>, pl_ci: Int) [IO] -> Unit {
    pl_g[4503] = pl_n[pl_ci * 10 + 5];
    match pl_g[4503] >= 0 { true -> {
        // Direct IDENT_REF arg
        match tc_priv_ref_check(pl_g, pl_n, pl_s, pl_g[4503]) == 1 { true -> {
            do print("error: cannot log Sensitive value — use expose() with audit context");
            pl_g[911] = pl_g[911] + 1;
        }, false -> { } };
        // BINOP arg — check left and right children
        match pl_n[pl_g[4503] * 10] == 11 { true -> {
            pl_g[4504] = pl_n[pl_g[4503] * 10 + 5]; // left
            pl_g[4505] = pl_n[pl_g[4504] * 10 + 6]; // right
            match tc_priv_ref_check(pl_g, pl_n, pl_s, pl_g[4504]) == 1 { true -> {
                do print("error: cannot log Sensitive value — use expose() with audit context");
                pl_g[911] = pl_g[911] + 1;
            }, false -> { } };
            match pl_g[4505] >= 0 { true -> match tc_priv_ref_check(pl_g, pl_n, pl_s, pl_g[4505]) == 1 { true -> {
                do print("error: cannot log Sensitive value — use expose() with audit context");
                pl_g[911] = pl_g[911] + 1;
            }, false -> { } }, false -> { } };
            // Nested BINOP (one level deeper)
            match pl_n[pl_g[4504] * 10] == 11 { true -> {
                pl_g[4506] = pl_n[pl_g[4504] * 10 + 5];
                pl_g[4507] = pl_n[pl_g[4506] * 10 + 6];
                match tc_priv_ref_check(pl_g, pl_n, pl_s, pl_g[4506]) == 1 { true -> {
                    pl_g[911] = pl_g[911] + 1;
                    do print("error: cannot log Sensitive value — use expose() with audit context");
                }, false -> { } };
                match pl_g[4507] >= 0 { true -> match tc_priv_ref_check(pl_g, pl_n, pl_s, pl_g[4507]) == 1 { true -> {
                    pl_g[911] = pl_g[911] + 1;
                    do print("error: cannot log Sensitive value — use expose() with audit context");
                }, false -> { } }, false -> { } };
            }, false -> { } };
        }, false -> { } };
        // Check type_info directly for BINOP with known sensitive type
        match pl_n[pl_g[4503] * 10] == 11 { true -> match pl_n[pl_g[4503] * 10 + 7] / 16 >= 2 { true -> {
            do print("error: cannot log Sensitive value — use expose() with audit context");
            pl_g[911] = pl_g[911] + 1;
        }, false -> { } }, false -> { } };
    }, false -> { } };
}

// tc_priv_check_expose — verify expose() arg is actually Sensitive
fn tc_priv_check_expose(pe_g: Array<Int>, pe_n: Array<Int>, pe_s: Array<Int>, pe_start: Int, pe_end: Int) [IO] -> Unit {
    for pe_ei in range(pe_start, pe_end) {
        match pe_n[pe_ei * 10] == 14 { true -> {
            pe_g[40] = pe_n[pe_ei * 10 + 2]; pe_g[41] = pe_n[pe_ei * 10 + 3];
            match chk_bi(pe_g, pe_s) == 15 { true -> {
                pe_g[4506] = pe_n[pe_ei * 10 + 5];
                pe_g[4507] = 0;
                match pe_g[4506] >= 0 { true -> match pe_n[pe_g[4506] * 10] == 10 { true -> {
                    for pe_vi in range(pe_start, pe_end) {
                        pe_g[4508] = pe_n[pe_vi * 10];
                        match pe_g[4508] == 2 { true -> match pe_n[pe_vi * 10 + 7] / 16 >= 2 { true -> {
                            pe_g[40] = pe_n[pe_g[4506] * 10 + 2]; pe_g[42] = pe_n[pe_g[4506] * 10 + 3];
                            pe_g[41] = pe_n[pe_vi * 10 + 2];
                            match pe_g[42] == pe_n[pe_vi * 10 + 3] { true -> match cg_name_eq(pe_g, pe_s) { true -> { pe_g[4507] = 1; }, false -> { } }, false -> { } };
                        }, false -> { } }, false -> { } };
                        match pe_g[4508] == 4 { true -> match pe_n[pe_vi * 10 + 7] / 16 >= 2 { true -> {
                            pe_g[40] = pe_n[pe_g[4506] * 10 + 2]; pe_g[42] = pe_n[pe_g[4506] * 10 + 3];
                            pe_g[41] = pe_n[pe_vi * 10 + 2];
                            match pe_g[42] == pe_n[pe_vi * 10 + 3] { true -> match cg_name_eq(pe_g, pe_s) { true -> { pe_g[4507] = 1; }, false -> { } }, false -> { } };
                        }, false -> { } }, false -> { } };
                    };
                    match pe_g[4507] == 0 { true -> {
                        do print("error: expose() argument must be Sensitive — only use with Sensitive values");
                        pe_g[911] = pe_g[911] + 1;
                    }, false -> { } };
                }, false -> { } }, false -> { } };
            }, false -> { } };
        }, false -> { } };
    };
}

// tc_priv_check_downcast — verify LET bindings don't downcast Sensitive
fn tc_priv_check_dc(pd_g: Array<Int>, pd_n: Array<Int>, pd_s: Array<Int>, pd_start: Int, pd_end: Int) [IO] -> Unit {
    for pd_di in range(pd_start, pd_end) {
        match pd_n[pd_di * 10] == 4 { true -> {
            pd_g[4504] = pd_n[pd_di * 10 + 7] / 16;
            pd_g[4505] = pd_n[pd_di * 10 + 5];
            match pd_g[4505] >= 0 { true -> match pd_n[pd_g[4505] * 10] == 10 { true -> {
                match tc_priv_ref_check(pd_g, pd_n, pd_s, pd_g[4505]) == 1 { true -> {
                    match pd_g[4504] < 2 { true -> {
                        do print("error: cannot assign Sensitive value to less restrictive type — use expose()");
                        pd_g[911] = pd_g[911] + 1;
                    }, false -> { } };
                }, false -> { } };
            }, false -> { } }, false -> { } };
        }, false -> { } };
    };
}

// tc_priv_check_algos — check for forbidden algorithms (md5, sha1, des, rc4)
fn tc_priv_check_algos(pa_g: Array<Int>, pa_n: Array<Int>, pa_s: Array<Int>) [IO] -> Unit {
    for pa_fa in range(0, pa_g[12]) {
        match pa_n[pa_fa * 10] == 14 { true -> {
            pa_g[40] = pa_n[pa_fa * 10 + 2]; pa_g[41] = pa_n[pa_fa * 10 + 3];
            match str_eq(pa_g, pa_s, "md5") { true -> {
                do print("error: forbidden algorithm — MD5 is broken, not available in Loon");
                pa_g[911] = pa_g[911] + 1;
            }, false -> match str_eq(pa_g, pa_s, "sha1") { true -> {
                do print("error: forbidden algorithm — SHA1 is broken, not available in Loon");
                pa_g[911] = pa_g[911] + 1;
            }, false -> match str_eq(pa_g, pa_s, "des") { true -> {
                do print("error: forbidden algorithm — DES is broken, not available in Loon");
                pa_g[911] = pa_g[911] + 1;
            }, false -> match str_eq(pa_g, pa_s, "rc4") { true -> {
                do print("error: forbidden algorithm — RC4 is broken, not available in Loon");
                pa_g[911] = pa_g[911] + 1;
            }, false -> { } } } } };
        }, false -> { } };
    };
}

// tc_check_privacy — orchestrator that calls the helpers above
fn tc_check_privacy(tp_g: Array<Int>, tp_n: Array<Int>, tp_s: Array<Int>) [IO] -> Unit {
    for tp_fi in range(0, tp_g[12]) {
        match tp_n[tp_fi * 10] == 1 { true -> {
            // Find function boundary
            tp_g[4500] = tp_g[12];
            for tp_bi in range(tp_fi + 1, tp_g[12]) {
                match tp_n[tp_bi * 10] == 1 { true -> match tp_g[4500] == tp_g[12] { true -> { tp_g[4500] = tp_bi; }, false -> { } }, false -> { } };
                match tp_n[tp_bi * 10] == 22 { true -> match tp_g[4500] == tp_g[12] { true -> { tp_g[4500] = tp_bi; }, false -> { } }, false -> { } };
            };
            // Step 1: Collect sensitive variable names
            do tc_priv_collect(tp_g, tp_n, tp_fi, tp_g[4500]);
            // Step 2: Check print/print_raw calls for sensitive refs
            match tp_g[4501] > 0 { true -> {
                for tp_ci in range(tp_fi + 1, tp_g[4500]) {
                    match tp_n[tp_ci * 10] == 14 { true -> {
                        tp_g[40] = tp_n[tp_ci * 10 + 2]; tp_g[41] = tp_n[tp_ci * 10 + 3];
                        tp_g[4502] = chk_bi(tp_g, tp_s);
                        match tp_g[4502] == 1 { true -> do tc_priv_check_log(tp_g, tp_n, tp_s, tp_ci), false -> { } };
                        match tp_g[4502] == 2 { true -> do tc_priv_check_log(tp_g, tp_n, tp_s, tp_ci), false -> { } };
                    }, false -> { } };
                };
            }, false -> { } };
            // Step 3: Check expose() args
            do tc_priv_check_expose(tp_g, tp_n, tp_s, tp_fi + 1, tp_g[4500]);
            // Step 4: Check downcast
            match tp_g[4501] > 0 { true -> do tc_priv_check_dc(tp_g, tp_n, tp_s, tp_fi + 1, tp_g[4500]), false -> { } };
        }, false -> { } };
    };
    // Step 5: Forbidden algorithms
    do tc_priv_check_algos(tp_g, tp_n, tp_s);
}

// tc_check — run all type/effect/scope checks on the AST
fn tc_check(tc_g: Array<Int>, tc_n: Array<Int>, tc_s: Array<Int>) [IO] -> Unit {
    tc_g[911] = 0;
    do tc_check_effects(tc_g, tc_n, tc_s);
    do tc_check_types(tc_g, tc_n, tc_s);
    do tc_check_undef(tc_g, tc_n, tc_s);
    do tc_check_args(tc_g, tc_n, tc_s);
    do tc_check_return(tc_g, tc_n, tc_s);
    do tc_check_privacy(tc_g, tc_n, tc_s);
    match tc_g[911] > 0 { true -> do exit(1), false -> { } };
}

// ========== LLVM IR Backend (stub) ==========
// ========== LLVM IR Backend ==========
// gs[32] = SSA temp counter (reused from label counter)
// gs[31] = current node index
// Node layout: [type, sub_type, str_off, str_len, child_count, first_child, next_sibling, type_info, extra, padding]

// ll_tmp — allocate next LLVM SSA temp number
fn ll_tmp(ll_g: Array<Int>) [] -> Int {
    let ll_n: Int = ll_g[32];
    ll_g[32] = ll_n + 1;
    ll_n
}

// LLVM: emit string concat (a + b where both are String type)
fn ll_strcat(sc_g: Array<Int>, sc_lt: Int, sc_rt: Int) [IO] -> Int {
    sc_g[35]=ll_tmp(sc_g); do print("    %t"+int_to_string(sc_g[35])+" = inttoptr i64 %t"+int_to_string(sc_lt)+" to i8*");
    sc_g[36]=ll_tmp(sc_g); do print("    %t"+int_to_string(sc_g[36])+" = call i64 @strlen(i8* %t"+int_to_string(sc_g[35])+")");
    sc_g[37]=ll_tmp(sc_g); do print("    %t"+int_to_string(sc_g[37])+" = inttoptr i64 %t"+int_to_string(sc_rt)+" to i8*");
    sc_g[38]=ll_tmp(sc_g); do print("    %t"+int_to_string(sc_g[38])+" = call i64 @strlen(i8* %t"+int_to_string(sc_g[37])+")");
    sc_g[39]=ll_tmp(sc_g); do print("    %t"+int_to_string(sc_g[39])+" = add i64 %t"+int_to_string(sc_g[36])+", %t"+int_to_string(sc_g[38]));
    sc_g[750]=ll_tmp(sc_g); do print("    %t"+int_to_string(sc_g[750])+" = add i64 %t"+int_to_string(sc_g[39])+", 1");
    sc_g[751]=ll_tmp(sc_g); do print("    %t"+int_to_string(sc_g[751])+" = call i8* @malloc(i64 %t"+int_to_string(sc_g[750])+")");
    do print("    call void @llvm.memcpy.p0.p0.i64(i8* %t"+int_to_string(sc_g[751])+", i8* %t"+int_to_string(sc_g[35])+", i64 %t"+int_to_string(sc_g[36])+", i1 false)");
    sc_g[753]=ll_tmp(sc_g); do print("    %t"+int_to_string(sc_g[753])+" = getelementptr i8, i8* %t"+int_to_string(sc_g[751])+", i64 %t"+int_to_string(sc_g[36]));
    do print("    call void @llvm.memcpy.p0.p0.i64(i8* %t"+int_to_string(sc_g[753])+", i8* %t"+int_to_string(sc_g[37])+", i64 %t"+int_to_string(sc_g[38])+", i1 false)");
    sc_g[754]=ll_tmp(sc_g); do print("    %t"+int_to_string(sc_g[754])+" = getelementptr i8, i8* %t"+int_to_string(sc_g[751])+", i64 %t"+int_to_string(sc_g[39]));
    do print("    store i8 0, i8* %t"+int_to_string(sc_g[754]));
    sc_g[755]=ll_tmp(sc_g); do print("    %t"+int_to_string(sc_g[755])+" = ptrtoint i8* %t"+int_to_string(sc_g[751])+" to i64");
    sc_g[761]=2;
    sc_g[755]
}

// LLVM: emit BINOP expression
fn ll_binop(lb_g: Array<Int>, lb_n: Array<Int>, lb_s: Array<Int>) [IO] -> Int {
    let lb_ni: Int = lb_g[31];
    let lb_op: Int = lb_n[lb_ni * 10 + 1];
    let lb_lhs: Int = lb_n[lb_ni * 10 + 5];
    let lb_rhs: Int = lb_n[lb_lhs * 10 + 6];
    lb_g[31] = lb_lhs;
    let lb_lt: Int = ll_expr(lb_g, lb_n, lb_s);
    lb_g[760] = lb_g[761]; // capture left operand type (7=Float) before right overwrites
    lb_g[31] = lb_rhs;
    let lb_rt: Int = ll_expr(lb_g, lb_n, lb_s);
    // If right is Float, also set g[760]
    match lb_g[761] == 7 { true -> { lb_g[760] = 7; }, false -> { } };
    let lb_t: Int = ll_tmp(lb_g);
    match lb_g[760] == 7 {
        true -> {
            // Float arithmetic/comparison
            match lb_op <= 4 {
                true -> {
                    let lb_fop: String = match lb_op { 0 -> "fadd", 1 -> "fsub", 2 -> "fmul", 3 -> "fdiv", _ -> "frem" };
                    do print("    %t" + int_to_string(lb_t) + " = " + lb_fop + " double %t" + int_to_string(lb_lt) + ", %t" + int_to_string(lb_rt));
                },
                false -> {
                    let lb_fcmp: String = match lb_op { 5 -> "oeq", 6 -> "one", 7 -> "olt", 8 -> "ogt", 9 -> "ole", 10 -> "oge", _ -> "oeq" };
                    let lb_fct: Int = ll_tmp(lb_g);
                    do print("    %t" + int_to_string(lb_fct) + " = fcmp " + lb_fcmp + " double %t" + int_to_string(lb_lt) + ", %t" + int_to_string(lb_rt));
                    do print("    %t" + int_to_string(lb_t) + " = zext i1 %t" + int_to_string(lb_fct) + " to i64");
                },
            };
        },
        false -> match lb_g[760] == 2 { true -> match lb_op == 0 { true -> { lb_g[4190] = ll_strcat(lb_g, lb_lt, lb_rt); }, false -> { lb_g[4190] = lb_t; } },
        false -> {
            // Integer arithmetic/comparison
            match lb_op <= 4 {
                true -> {
                    let lb_opn: String = match lb_op { 0 -> "add", 1 -> "sub", 2 -> "mul", 3 -> "sdiv", _ -> "srem" };
                    // Division/modulo: check for zero divisor
                    match lb_op >= 3 { true -> {
                        lb_g[39] = ll_tmp(lb_g);
                        do print("    %t" + int_to_string(lb_g[39]) + " = icmp eq i64 %t" + int_to_string(lb_rt) + ", 0");
                        lb_g[38] = lb_g[34]; lb_g[34] = lb_g[34] + 1;
                        do print("    br i1 %t" + int_to_string(lb_g[39]) + ", label %dz_trap_" + int_to_string(lb_g[38]) + ", label %dz_ok_" + int_to_string(lb_g[38]));
                        do print("dz_trap_" + int_to_string(lb_g[38]) + ":");
                        match lb_g[916] == 4 { true -> do print("    call void @proc_exit(i32 1)"), false -> do print("    call void @exit(i32 1)") };
                        do print("    unreachable");
                        do print("dz_ok_" + int_to_string(lb_g[38]) + ":");
                    }, false -> { } };
                    do print("    %t" + int_to_string(lb_t) + " = " + lb_opn + " i64 %t" + int_to_string(lb_lt) + ", %t" + int_to_string(lb_rt));
                },
                false -> {
                    let lb_cmp: String = match lb_op { 5 -> "eq", 6 -> "ne", 7 -> "slt", 8 -> "sgt", 9 -> "sle", 10 -> "sge", 11 -> "eq", _ -> "eq" };
                    let lb_ct: Int = ll_tmp(lb_g);
                    do print("    %t" + int_to_string(lb_ct) + " = icmp " + lb_cmp + " i64 %t" + int_to_string(lb_lt) + ", %t" + int_to_string(lb_rt));
                    do print("    %t" + int_to_string(lb_t) + " = zext i1 %t" + int_to_string(lb_ct) + " to i64");
                },
            };
        },
    } };
    match lb_g[760] == 2 { true -> lb_g[4190], false -> lb_t }
}

// LLVM: emit variable reference
fn ll_ident(li_g: Array<Int>, li_n: Array<Int>, li_s: Array<Int>) [IO] -> Int {
    let li_ni: Int = li_g[31];
    let li_t: Int = ll_tmp(li_g);
    let li_voff: Int = li_n[li_ni * 10 + 2];
    let li_vlen: Int = li_n[li_ni * 10 + 3];
    li_g[40] = li_voff; li_g[42] = li_vlen;
    let li_vf: Array<Int> = Array(1); li_vf[0] = 0 - 1;
    for li_fi in range(0, li_g[50]) {
        li_g[41] = li_g[51 + li_fi * 4];
        match li_g[42] == li_g[51 + li_fi * 4 + 1] { true -> match cg_name_eq(li_g, li_s) { true -> { li_vf[0] = li_fi; }, false -> { } }, false -> { } };
    };
    match li_vf[0] >= 0 {
        true -> match li_g[51 + li_vf[0] * 4 + 2] == 1 {
            // Param — reference directly
            true -> {
                let li_vt: Int = li_g[51 + li_vf[0] * 4 + 3]; // type_info
                let li_pty: String = match li_vt == 7 { true -> "fadd double", false -> "add i64" };
                let li_psf: String = match li_vt == 7 { true -> ", 0.0", false -> ", 0" };
                do print_raw("    %t" + int_to_string(li_t) + " = " + li_pty + " %p_");
                let li_po: Int = li_g[51 + li_vf[0] * 4];
                let li_pl: Int = li_g[51 + li_vf[0] * 4 + 1];
                for li_pk in range(0, li_pl) { do print_byte(li_s[li_po + li_pk]); };
                do print(li_psf);
            },
            // Local — load from alloca
            false -> {
                let li_lt: Int = li_g[51 + li_vf[0] * 4 + 3];
                match li_lt == 7 { true -> do print("    %t" + int_to_string(li_t) + " = load double, double* %v" + int_to_string(li_vf[0])),
                false -> do print("    %t" + int_to_string(li_t) + " = load i64, i64* %v" + int_to_string(li_vf[0])) };
            },
        },
        false -> {
            do print_raw("    %t" + int_to_string(li_t) + " = add i64 %p_");
            for li_pi in range(0, li_vlen) { do print_byte(li_s[li_voff + li_pi]); };
            do print(", 0");
        },
    };
    // Set g[761] to the variable's type (7=Float) for callers like ll_binop
    match li_vf[0] >= 0 { true -> { li_g[761] = li_g[51 + li_vf[0] * 4 + 3] % 16; }, false -> { li_g[761] = 0; } };
    li_t
}

// LLVM: emit builtin call (exit, print, int_to_string)
fn ll_builtin(lbu_g: Array<Int>, lbu_n: Array<Int>, lbu_s: Array<Int>) [IO] -> Int {
    let lbu_ni: Int = lbu_g[31];
    let lbu_bi: Int = lbu_g[140]; // builtin ID passed via g[140]
    match lbu_bi == 8 {
        true -> {
            let lbu_arg: Int = lbu_n[lbu_ni * 10 + 5];
            lbu_g[31] = lbu_arg;
            let lbu_at: Int = ll_expr(lbu_g, lbu_n, lbu_s);
            let lbu_t: Int = ll_tmp(lbu_g);
            do print("    %t" + int_to_string(lbu_t) + " = trunc i64 %t" + int_to_string(lbu_at) + " to i32");
            match lbu_g[916] == 4 { true -> do print("    call void @proc_exit(i32 %t" + int_to_string(lbu_t) + ")"), false -> do print("    call void @exit(i32 %t" + int_to_string(lbu_t) + ")") };
            do print("    unreachable");
                lbu_g[33] = 1;
            lbu_at
        },
        false -> match lbu_bi == 1 {
            true -> {
                lbu_g[35] = lbu_n[lbu_ni * 10 + 5]; // first arg node
                match lbu_n[lbu_g[35] * 10] == 8 {
                    true -> {
                        // STR_LIT — GEP + write with known length
                        lbu_g[36] = lbu_n[lbu_g[35] * 10 + 8]; // string index
                        lbu_g[37] = lbu_n[lbu_g[35] * 10 + 3]; // string length
                        lbu_g[38] = ll_tmp(lbu_g);
                        do print("    %t" + int_to_string(lbu_g[38]) + " = getelementptr [" + int_to_string(lbu_g[37]) + " x i8], [" + int_to_string(lbu_g[37]) + " x i8]* @_s" + int_to_string(lbu_g[36]) + ", i64 0, i64 0");
                        lbu_g[39] = ll_tmp(lbu_g);
                        do print("    %t" + int_to_string(lbu_g[39]) + " = call i64 @write(i32 1, i8* %t" + int_to_string(lbu_g[38]) + ", i64 " + int_to_string(lbu_g[37]) + ")");
                    },
                    false -> {
                        // Dynamic string — eval, convert to i8* if needed, strlen + write
                        lbu_g[31] = lbu_g[35];
                        lbu_g[36] = ll_expr(lbu_g, lbu_n, lbu_s);
                        // Check if result is already i8* (from float_to_string/int_to_string builtins)
                        // or i64 (from user functions returning String)
                        lbu_g[37] = ll_tmp(lbu_g);
                        do print("    %t" + int_to_string(lbu_g[37]) + " = inttoptr i64 %t" + int_to_string(lbu_g[36]) + " to i8*");
                        lbu_g[38] = ll_tmp(lbu_g);
                        do print("    %t" + int_to_string(lbu_g[38]) + " = call i64 @strlen(i8* %t" + int_to_string(lbu_g[37]) + ")");
                        lbu_g[39] = ll_tmp(lbu_g);
                        do print("    %t" + int_to_string(lbu_g[39]) + " = call i64 @write(i32 1, i8* %t" + int_to_string(lbu_g[37]) + ", i64 %t" + int_to_string(lbu_g[38]) + ")");
                    },
                };
                // Newline
                lbu_g[38] = ll_tmp(lbu_g);
                do print("    %t" + int_to_string(lbu_g[38]) + " = getelementptr [1 x i8], [1 x i8]* @_nl, i64 0, i64 0");
                lbu_g[39] = ll_tmp(lbu_g);
                do print("    %t" + int_to_string(lbu_g[39]) + " = call i64 @write(i32 1, i8* %t" + int_to_string(lbu_g[38]) + ", i64 1)");
                lbu_g[39]
            },
            false -> match lbu_bi == 11 {
                // Array(n) — malloc (n+1)*8 bytes, store length at slot 0, return slot 1
                true -> {
                    lbu_g[31] = lbu_n[lbu_ni * 10 + 5];
                    lbu_g[35] = ll_expr(lbu_g, lbu_n, lbu_s); // size temp
                    lbu_g[36] = ll_tmp(lbu_g);
                    do print("    %t" + int_to_string(lbu_g[36]) + " = add i64 %t" + int_to_string(lbu_g[35]) + ", 1");
                    lbu_g[37] = ll_tmp(lbu_g);
                    do print("    %t" + int_to_string(lbu_g[37]) + " = mul i64 %t" + int_to_string(lbu_g[36]) + ", 8");
                    lbu_g[38] = ll_tmp(lbu_g);
                    do print("    %t" + int_to_string(lbu_g[38]) + " = call i8* @malloc(i64 %t" + int_to_string(lbu_g[37]) + ")");
                    lbu_g[39] = ll_tmp(lbu_g);
                    do print("    %t" + int_to_string(lbu_g[39]) + " = bitcast i8* %t" + int_to_string(lbu_g[38]) + " to i64*");
                    // Store length at slot 0
                    do print("    store i64 %t" + int_to_string(lbu_g[35]) + ", i64* %t" + int_to_string(lbu_g[39]));
                    // Return pointer to slot 1 (data start)
                    lbu_g[750] = ll_tmp(lbu_g);
                    do print("    %t" + int_to_string(lbu_g[750]) + " = getelementptr i64, i64* %t" + int_to_string(lbu_g[39]) + ", i64 1");
                    lbu_g[751] = ll_tmp(lbu_g);
                    do print("    %t" + int_to_string(lbu_g[751]) + " = ptrtoint i64* %t" + int_to_string(lbu_g[750]) + " to i64");
                    lbu_g[751]
                },
                false -> match lbu_bi == 3 {
                    true -> { lbu_g[31] = lbu_n[lbu_ni * 10 + 5]; lbu_g[35] = ll_expr(lbu_g, lbu_n, lbu_s);
                        match lbu_g[916] == 4 { true -> { lbu_g[37] = ll_tmp(lbu_g); do print("    %t" + int_to_string(lbu_g[37]) + " = call i8* @_loon_i64_to_str(i64 %t" + int_to_string(lbu_g[35]) + ")"); lbu_g[36] = ll_tmp(lbu_g); do print("    %t" + int_to_string(lbu_g[36]) + " = ptrtoint i8* %t" + int_to_string(lbu_g[37]) + " to i64"); },
                        false -> { lbu_g[36] = ll_tmp(lbu_g); do print("    %t" + int_to_string(lbu_g[36]) + " = call i8* @malloc(i64 24)"); lbu_g[37] = ll_tmp(lbu_g); do print("    %t" + int_to_string(lbu_g[37]) + " = getelementptr [4 x i8], [4 x i8]* @_fmt_int, i64 0, i64 0"); lbu_g[38] = ll_tmp(lbu_g); do print("    %t" + int_to_string(lbu_g[38]) + " = call i32 (i8*, i8*, ...) @sprintf(i8* %t" + int_to_string(lbu_g[36]) + ", i8* %t" + int_to_string(lbu_g[37]) + ", i64 %t" + int_to_string(lbu_g[35]) + ")"); lbu_g[38] = ll_tmp(lbu_g); do print("    %t" + int_to_string(lbu_g[38]) + " = ptrtoint i8* %t" + int_to_string(lbu_g[36]) + " to i64"); lbu_g[36] = lbu_g[38]; } };
                    lbu_g[36] },
                false -> match lbu_bi == 14 {
                    // float_to_string: sprintf %g → returns i8* ptr
                    true -> {
                        lbu_g[31] = lbu_n[lbu_ni * 10 + 5];
                        lbu_g[35] = ll_expr(lbu_g, lbu_n, lbu_s);
                        lbu_g[36] = ll_tmp(lbu_g);
                        do print("    %t" + int_to_string(lbu_g[36]) + " = call i8* @malloc(i64 32)");
                        lbu_g[37] = ll_tmp(lbu_g);
                        do print("    %t" + int_to_string(lbu_g[37]) + " = getelementptr [3 x i8], [3 x i8]* @_fmt_float, i64 0, i64 0");
                        lbu_g[38] = ll_tmp(lbu_g);
                        do print("    %t" + int_to_string(lbu_g[38]) + " = call i32 (i8*, i8*, ...) @sprintf(i8* %t" + int_to_string(lbu_g[36]) + ", i8* %t" + int_to_string(lbu_g[37]) + ", double %t" + int_to_string(lbu_g[35]) + ")");
                        lbu_g[36]
                    },
                    false -> match lbu_bi == 2 { true -> { lbu_g[35]=lbu_n[lbu_ni*10+5]; match lbu_n[lbu_g[35]*10]==8 { true -> { lbu_g[36]=lbu_n[lbu_g[35]*10+8]; lbu_g[37]=lbu_n[lbu_g[35]*10+3]+1; lbu_g[38]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[38])+" = getelementptr ["+int_to_string(lbu_g[37])+" x i8], ["+int_to_string(lbu_g[37])+" x i8]* @_s"+int_to_string(lbu_g[36])+", i64 0, i64 0"); lbu_g[39]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[39])+" = call i64 @write(i32 1, i8* %t"+int_to_string(lbu_g[38])+", i64 "+int_to_string(lbu_g[37] - 1)+")"); }, false -> { lbu_g[31]=lbu_g[35]; lbu_g[36]=ll_expr(lbu_g,lbu_n,lbu_s); lbu_g[37]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[37])+" = inttoptr i64 %t"+int_to_string(lbu_g[36])+" to i8*"); lbu_g[38]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[38])+" = call i64 @strlen(i8* %t"+int_to_string(lbu_g[37])+")"); lbu_g[39]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[39])+" = call i64 @write(i32 1, i8* %t"+int_to_string(lbu_g[37])+", i64 %t"+int_to_string(lbu_g[38])+")"); } }; lbu_g[39] },
                    false -> match lbu_bi == 10 { true -> { lbu_g[31]=lbu_n[lbu_ni*10+5]; lbu_g[35]=ll_expr(lbu_g,lbu_n,lbu_s); do print("    call void @_loon_print_byte(i64 %t"+int_to_string(lbu_g[35])+")"); lbu_g[35] },
                    false -> match lbu_bi == 7 { true -> { lbu_g[31]=lbu_n[lbu_ni*10+5]; lbu_g[35]=ll_expr(lbu_g,lbu_n,lbu_s); lbu_g[37]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[37])+" = call i8* @_loon_read_file(i64 %t"+int_to_string(lbu_g[35])+")"); lbu_g[36]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[36])+" = ptrtoint i8* %t"+int_to_string(lbu_g[37])+" to i64"); lbu_g[36] },
                    false -> match lbu_bi == 9 { true -> { lbu_g[31]=lbu_n[lbu_ni*10+5]; lbu_g[35]=ll_expr(lbu_g,lbu_n,lbu_s); lbu_g[37]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[37])+" = call i8* @_loon_get_arg(i64 %t"+int_to_string(lbu_g[35])+")"); lbu_g[36]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[36])+" = ptrtoint i8* %t"+int_to_string(lbu_g[37])+" to i64"); lbu_g[36] },
                    false -> match lbu_bi == 5 { true -> { lbu_g[31]=lbu_n[lbu_ni*10+5]; lbu_g[35]=ll_expr(lbu_g,lbu_n,lbu_s); lbu_g[36]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[36])+" = inttoptr i64 %t"+int_to_string(lbu_g[35])+" to i8*"); lbu_g[37]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[37])+" = call i64 @strlen(i8* %t"+int_to_string(lbu_g[36])+")"); lbu_g[37] },
                    false -> match lbu_bi == 6 { true -> { lbu_g[31]=lbu_n[lbu_ni*10+5]; lbu_g[35]=ll_expr(lbu_g,lbu_n,lbu_s); lbu_g[31]=lbu_n[lbu_n[lbu_ni*10+5]*10+6]; lbu_g[36]=ll_expr(lbu_g,lbu_n,lbu_s); lbu_g[37]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[37])+" = inttoptr i64 %t"+int_to_string(lbu_g[35])+" to i8*"); lbu_g[38]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[38])+" = getelementptr i8, i8* %t"+int_to_string(lbu_g[37])+", i64 %t"+int_to_string(lbu_g[36])); lbu_g[39]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[39])+" = load i8, i8* %t"+int_to_string(lbu_g[38])); lbu_g[750]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[750])+" = zext i8 %t"+int_to_string(lbu_g[39])+" to i64"); lbu_g[750] },
                    false -> match lbu_bi == 15 { true -> { lbu_g[31]=lbu_n[lbu_ni*10+5]; lbu_g[35]=ll_expr(lbu_g,lbu_n,lbu_s); lbu_g[31]=lbu_n[lbu_n[lbu_ni*10+5]*10+6]; lbu_g[36]=ll_expr(lbu_g,lbu_n,lbu_s); lbu_g[37]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[37])+" = inttoptr i64 %t"+int_to_string(lbu_g[36])+" to i8*"); lbu_g[38]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[38])+" = call i64 @strlen(i8* %t"+int_to_string(lbu_g[37])+")"); lbu_g[39]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[39])+" = call i64 @write(i32 2, i8* %t"+int_to_string(lbu_g[37])+", i64 %t"+int_to_string(lbu_g[38])+")"); lbu_g[35] },
                    false -> { match lbu_bi == 4 { true -> { lbu_g[31]=lbu_n[lbu_ni*10+5]; lbu_g[35]=ll_expr(lbu_g,lbu_n,lbu_s); lbu_g[36]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[36])+" = inttoptr i64 %t"+int_to_string(lbu_g[35])+" to i8*"); lbu_g[37]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[37])+" = call i64 @strlen(i8* %t"+int_to_string(lbu_g[36])+")"); lbu_g[35] = lbu_g[37]; }, false -> { lbu_g[35]=ll_tmp(lbu_g); do print("    %t"+int_to_string(lbu_g[35])+" = add i64 0, 0 ; stub "+int_to_string(lbu_bi)); } }; lbu_g[35] } } } } } } } },
                },
            },
            },
        },
    }
}

// LLVM: emit user function call
fn ll_call(lc_g: Array<Int>, lc_n: Array<Int>, lc_s: Array<Int>) [IO] -> Int {
    let lc_ni: Int = lc_g[31];
    let lc_coff: Int = lc_n[lc_ni * 10 + 2];
    let lc_clen: Int = lc_n[lc_ni * 10 + 3];
    let lc_cac: Int = lc_n[lc_ni * 10 + 4];
    // Evaluate args FIRST (before fn lookup which clobbers array pointers)
    let lc_args: Array<Int> = Array(8);
    let lc_ari: Array<Int> = Array(1); lc_ari[0] = lc_n[lc_ni * 10 + 5];
    for lc_ai in range(0, lc_cac) {
        lc_g[31] = lc_ari[0];
        lc_args[lc_ai] = ll_expr(lc_g, lc_n, lc_s);
        lc_ari[0] = lc_n[lc_ari[0] * 10 + 6];
    };
    // Look up callee FN_DECL for return type + param types (AFTER arg eval)
    lc_g[40] = lc_coff; lc_g[42] = lc_clen;
    lc_g[4103] = 0 - 1;
    for lc_fi in range(0, lc_g[12]) {
        match lc_n[lc_fi * 10] == 1 { true -> {
            lc_g[41] = lc_n[lc_fi * 10 + 2];
            match lc_g[42] == lc_n[lc_fi * 10 + 3] { true -> match cg_name_eq(lc_g, lc_s) { true -> { lc_g[4103] = lc_fi; }, false -> { } }, false -> { } };
        }, false -> { } };
    };
    lc_g[4104] = match lc_g[4103] >= 0 { true -> lc_n[lc_g[4103] * 10 + 7], false -> 0 };
    let lc_t: Int = ll_tmp(lc_g);
    // Emit call with correct return type
    let lc_rty: String = match lc_g[4104] == 7 { true -> "double", false -> "i64" };
    do print_raw("    %t" + int_to_string(lc_t) + " = call " + lc_rty + " @fn_");
    for lc_ni2 in range(0, lc_clen) { do print_byte(lc_s[lc_coff + lc_ni2]); };
    do print_raw("(");
    for lc_ai2 in range(0, lc_cac) {
        match lc_ai2 > 0 { true -> do print_raw(", "), false -> { } };
        match lc_g[4104] == 7 { true -> do print_raw("double %t" + int_to_string(lc_args[lc_ai2])), false -> do print_raw("i64 %t" + int_to_string(lc_args[lc_ai2])) };
    };
    do print(")");
    lc_g[761] = lc_g[4104];
    lc_t
}

// LLVM: emit for loop as statement
fn ll_for(lfr_g: Array<Int>, lfr_n: Array<Int>, lfr_s: Array<Int>) [IO] -> Unit {
    let lfr_ni: Int = lfr_g[31];
    let lfr_fid: Int = lfr_g[34]; lfr_g[34] = lfr_g[34] + 1;
    // Register loop var as alloca
    let lfr_vi: Int = lfr_g[50];
    lfr_g[51 + lfr_vi * 4] = lfr_n[lfr_ni * 10 + 2];
    lfr_g[51 + lfr_vi * 4 + 1] = lfr_n[lfr_ni * 10 + 3];
    lfr_g[51 + lfr_vi * 4 + 2] = 0;
    lfr_g[51 + lfr_vi * 4 + 3] = 0; // type_info = Int
    lfr_g[50] = lfr_vi + 1;
    do print("    %v" + int_to_string(lfr_vi) + " = alloca i64");
    // Eval start expression (first child)
    let lfr_start: Int = lfr_n[lfr_ni * 10 + 5];
    lfr_g[31] = lfr_start;
    let lfr_st: Int = ll_expr(lfr_g, lfr_n, lfr_s);
    do print("    store i64 %t" + int_to_string(lfr_st) + ", i64* %v" + int_to_string(lfr_vi));
    // Eval end expression (second child) — once before loop
    let lfr_end: Int = lfr_n[lfr_start * 10 + 6];
    lfr_g[31] = lfr_end;
    let lfr_et: Int = ll_expr(lfr_g, lfr_n, lfr_s);
    do print("    br label %for_ck_" + int_to_string(lfr_fid));
    // Check block
    do print("for_ck_" + int_to_string(lfr_fid) + ":");
    let lfr_lt: Int = ll_tmp(lfr_g);
    do print("    %t" + int_to_string(lfr_lt) + " = load i64, i64* %v" + int_to_string(lfr_vi));
    let lfr_ct: Int = ll_tmp(lfr_g);
    do print("    %t" + int_to_string(lfr_ct) + " = icmp slt i64 %t" + int_to_string(lfr_lt) + ", %t" + int_to_string(lfr_et));
    do print("    br i1 %t" + int_to_string(lfr_ct) + ", label %for_bd_" + int_to_string(lfr_fid) + ", label %for_ed_" + int_to_string(lfr_fid));
    // Body block (third child)
    do print("for_bd_" + int_to_string(lfr_fid) + ":");
    let lfr_body: Int = lfr_n[lfr_end * 10 + 6];
    lfr_g[31] = lfr_body;
    do ll_block(lfr_g, lfr_n, lfr_s);
    // Increment
    let lfr_it: Int = ll_tmp(lfr_g);
    do print("    %t" + int_to_string(lfr_it) + " = load i64, i64* %v" + int_to_string(lfr_vi));
    let lfr_i2: Int = ll_tmp(lfr_g);
    do print("    %t" + int_to_string(lfr_i2) + " = add i64 %t" + int_to_string(lfr_it) + ", 1");
    do print("    store i64 %t" + int_to_string(lfr_i2) + ", i64* %v" + int_to_string(lfr_vi));
    do print("    br label %for_ck_" + int_to_string(lfr_fid));
    do print("for_ed_" + int_to_string(lfr_fid) + ":");
}

// LLVM: emit Array(n) constructor
fn ll_arynew(lan_g: Array<Int>, lan_n: Array<Int>, lan_s: Array<Int>) [IO] -> Int {
    let lan_ni: Int = lan_g[31];
    let lan_sz_ni: Int = lan_n[lan_ni * 10 + 5]; // first child = size expr
    lan_g[31] = lan_sz_ni;
    let lan_st: Int = ll_expr(lan_g, lan_n, lan_s);
    let lan_bt: Int = ll_tmp(lan_g);
    do print("    %t" + int_to_string(lan_bt) + " = mul i64 %t" + int_to_string(lan_st) + ", 8");
    let lan_rt: Int = ll_tmp(lan_g);
    do print("    %t" + int_to_string(lan_rt) + " = call i8* @malloc(i64 %t" + int_to_string(lan_bt) + ")");
    let lan_ct: Int = ll_tmp(lan_g);
    do print("    %t" + int_to_string(lan_ct) + " = bitcast i8* %t" + int_to_string(lan_rt) + " to i64*");
    lan_ct
}

// LLVM: emit arr[i] read
fn ll_aryget(lag_g: Array<Int>, lag_n: Array<Int>, lag_s: Array<Int>) [IO] -> Int {
    let lag_ni: Int = lag_g[31];
    // Look up array variable
    lag_g[40] = lag_n[lag_ni * 10 + 2]; lag_g[42] = lag_n[lag_ni * 10 + 3];
    let lag_vf: Array<Int> = Array(1); lag_vf[0] = 0 - 1;
    for lag_fi in range(0, lag_g[50]) {
        lag_g[41] = lag_g[51 + lag_fi * 4];
        match lag_g[42] == lag_g[51 + lag_fi * 4 + 1] { true -> match cg_name_eq(lag_g, lag_s) { true -> { lag_vf[0] = lag_fi; }, false -> { } }, false -> { } };
    };
    // Load array pointer (param uses %p_name directly, local uses %v{i})
    let lag_at: Int = ll_tmp(lag_g);
    match lag_vf[0] >= 0 { true -> match lag_g[51+lag_vf[0]*4+2]==1 { true -> { do print_raw("    %t"+int_to_string(lag_at)+" = add i64 %p_"); let lag_po: Int=lag_g[51+lag_vf[0]*4]; let lag_pl: Int=lag_g[51+lag_vf[0]*4+1]; for lag_pk in range(0,lag_pl) { do print_byte(lag_s[lag_po+lag_pk]); }; do print(", 0"); }, false -> do print("    %t"+int_to_string(lag_at)+" = load i64, i64* %v"+int_to_string(lag_vf[0])) }, false -> do print("    %t"+int_to_string(lag_at)+" = add i64 0, 0 ; unfound var") };
    let lag_apt: Int = ll_tmp(lag_g);
    do print("    %t" + int_to_string(lag_apt) + " = inttoptr i64 %t" + int_to_string(lag_at) + " to i64*");
    // Eval index
    lag_g[31] = lag_n[lag_ni * 10 + 5];
    let lag_it: Int = ll_expr(lag_g, lag_n, lag_s);
    // Bounds check: load length from ptr[-1]
    lag_g[750] = ll_tmp(lag_g);
    do print("    %t" + int_to_string(lag_g[750]) + " = getelementptr i64, i64* %t" + int_to_string(lag_apt) + ", i64 -1");
    lag_g[751] = ll_tmp(lag_g);
    do print("    %t" + int_to_string(lag_g[751]) + " = load i64, i64* %t" + int_to_string(lag_g[750]));
    lag_g[752] = ll_tmp(lag_g);
    do print("    %t" + int_to_string(lag_g[752]) + " = icmp ult i64 %t" + int_to_string(lag_it) + ", %t" + int_to_string(lag_g[751]));
    lag_g[753] = lag_g[34]; lag_g[34] = lag_g[34] + 1;
    do print("    br i1 %t" + int_to_string(lag_g[752]) + ", label %bnd_ok_" + int_to_string(lag_g[753]) + ", label %bnd_fail_" + int_to_string(lag_g[753]));
    do print("bnd_fail_" + int_to_string(lag_g[753]) + ":");
    do print("    call void @__loon_bounds_panic(i64 %t" + int_to_string(lag_it) + ", i64 %t" + int_to_string(lag_g[751]) + ")");
    do print("    unreachable");
    do print("bnd_ok_" + int_to_string(lag_g[753]) + ":");
    // GEP + load
    let lag_pt: Int = ll_tmp(lag_g);
    do print("    %t" + int_to_string(lag_pt) + " = getelementptr i64, i64* %t" + int_to_string(lag_apt) + ", i64 %t" + int_to_string(lag_it));
    let lag_vt: Int = ll_tmp(lag_g);
    do print("    %t" + int_to_string(lag_vt) + " = load i64, i64* %t" + int_to_string(lag_pt));
    lag_vt
}

// LLVM: emit arr[i] = v write (statement)
fn ll_aryset(las_g: Array<Int>, las_n: Array<Int>, las_s: Array<Int>) [IO] -> Unit {
    let las_ni: Int = las_g[31];
    // Look up array variable
    las_g[40] = las_n[las_ni * 10 + 2]; las_g[42] = las_n[las_ni * 10 + 3];
    let las_vf: Array<Int> = Array(1); las_vf[0] = 0 - 1;
    for las_fi in range(0, las_g[50]) {
        las_g[41] = las_g[51 + las_fi * 4];
        match las_g[42] == las_g[51 + las_fi * 4 + 1] { true -> match cg_name_eq(las_g, las_s) { true -> { las_vf[0] = las_fi; }, false -> { } }, false -> { } };
    };
    // Load array pointer (param uses %p_name directly, local uses %v{i})
    let las_at: Int = ll_tmp(las_g);
    match las_vf[0] >= 0 { true -> match las_g[51+las_vf[0]*4+2]==1 { true -> { do print_raw("    %t"+int_to_string(las_at)+" = add i64 %p_"); let las_po: Int=las_g[51+las_vf[0]*4]; let las_pl: Int=las_g[51+las_vf[0]*4+1]; for las_pk in range(0,las_pl) { do print_byte(las_s[las_po+las_pk]); }; do print(", 0"); }, false -> do print("    %t"+int_to_string(las_at)+" = load i64, i64* %v"+int_to_string(las_vf[0])) }, false -> do print("    %t"+int_to_string(las_at)+" = add i64 0, 0 ; unfound var") };
    let las_apt: Int = ll_tmp(las_g);
    do print("    %t" + int_to_string(las_apt) + " = inttoptr i64 %t" + int_to_string(las_at) + " to i64*");
    // Eval index (first child)
    las_g[31] = las_n[las_ni * 10 + 5];
    let las_it: Int = ll_expr(las_g, las_n, las_s);
    // Bounds check: load length from ptr[-1]
    las_g[750] = ll_tmp(las_g);
    do print("    %t" + int_to_string(las_g[750]) + " = getelementptr i64, i64* %t" + int_to_string(las_apt) + ", i64 -1");
    las_g[751] = ll_tmp(las_g);
    do print("    %t" + int_to_string(las_g[751]) + " = load i64, i64* %t" + int_to_string(las_g[750]));
    las_g[752] = ll_tmp(las_g);
    do print("    %t" + int_to_string(las_g[752]) + " = icmp ult i64 %t" + int_to_string(las_it) + ", %t" + int_to_string(las_g[751]));
    las_g[753] = las_g[34]; las_g[34] = las_g[34] + 1;
    do print("    br i1 %t" + int_to_string(las_g[752]) + ", label %bnd_ok_" + int_to_string(las_g[753]) + ", label %bnd_fail_" + int_to_string(las_g[753]));
    do print("bnd_fail_" + int_to_string(las_g[753]) + ":");
    do print("    call void @__loon_bounds_panic(i64 %t" + int_to_string(las_it) + ", i64 %t" + int_to_string(las_g[751]) + ")");
    do print("    unreachable");
    do print("bnd_ok_" + int_to_string(las_g[753]) + ":");
    // Eval value (second child = next sibling of index)
    las_g[31] = las_n[las_n[las_ni * 10 + 5] * 10 + 6];
    let las_vt: Int = ll_expr(las_g, las_n, las_s);
    // GEP + store
    let las_pt: Int = ll_tmp(las_g);
    do print("    %t" + int_to_string(las_pt) + " = getelementptr i64, i64* %t" + int_to_string(las_apt) + ", i64 %t" + int_to_string(las_it));
    do print("    store i64 %t" + int_to_string(las_vt) + ", i64* %t" + int_to_string(las_pt));
}

// LLVM: emit match expression
// LLVM: emit variant constructor (type 24)
fn ll_vnew(lv_g: Array<Int>, lv_n: Array<Int>, lv_s: Array<Int>) [IO] -> Int {
    let lv_ni: Int = lv_g[31];
    let lv_tag: Int = lv_n[lv_ni * 10 + 1];
    let lv_ac: Int = lv_n[lv_ni * 10 + 4];
    let lv_sz: Int = (1 + lv_ac) * 8;
    lv_g[35] = ll_tmp(lv_g);
    do print("    %t" + int_to_string(lv_g[35]) + " = call i8* @malloc(i64 " + int_to_string(lv_sz) + ")");
    lv_g[36] = ll_tmp(lv_g);
    do print("    %t" + int_to_string(lv_g[36]) + " = bitcast i8* %t" + int_to_string(lv_g[35]) + " to i64*");
    lv_g[37] = ll_tmp(lv_g);
    do print("    %t" + int_to_string(lv_g[37]) + " = getelementptr i64, i64* %t" + int_to_string(lv_g[36]) + ", i64 0");
    do print("    store i64 " + int_to_string(lv_tag) + ", i64* %t" + int_to_string(lv_g[37]));
    // Save the allocation base pointer temp in a depth-safe slot
    // g[4800 + depth] holds the bitcast temp for each nesting level
    lv_g[4199] = lv_g[4199] + 1; // reuse match depth for vnew nesting
    lv_g[4800 + lv_g[4199] - 1] = lv_g[36]; // save base ptr temp
    // Store fields
    lv_g[703] = lv_n[lv_ni * 10 + 5]; // first child
    for lv_fi in range(0, lv_ac) {
        lv_g[31] = lv_g[703];
        lv_g[38] = ll_expr(lv_g, lv_n, lv_s); // may recurse into ll_vnew!
        lv_g[39] = ll_tmp(lv_g);
        do print("    %t" + int_to_string(lv_g[39]) + " = getelementptr i64, i64* %t" + int_to_string(lv_g[4800 + lv_g[4199] - 1]) + ", i64 " + int_to_string(lv_fi + 1));
        do print("    store i64 %t" + int_to_string(lv_g[38]) + ", i64* %t" + int_to_string(lv_g[39]));
        lv_g[703] = lv_n[lv_g[703] * 10 + 6];
    };
    lv_g[38] = ll_tmp(lv_g);
    do print("    %t" + int_to_string(lv_g[38]) + " = ptrtoint i64* %t" + int_to_string(lv_g[4800 + lv_g[4199] - 1]) + " to i64");
    lv_g[4199] = lv_g[4199] - 1; // restore depth
    lv_g[38]
}

// LLVM: ADT match — emit comparison chain only (no bodies)
// g[700]=match_ni, g[701]=adt_ptr_temp, g[702]=tag_temp, g[703]=match_id, g[704]=arm_count
fn ll_amcmp(ac_g: Array<Int>, ac_n: Array<Int>, ac_s: Array<Int>) [IO] -> Unit {
    let ac_ac: Int = ac_g[704];
    ac_g[705] = ac_n[ac_g[700] * 10 + 5]; // first arm node
    for ac_ai in range(0, ac_ac) {
        let ac_atag: Int = ac_n[ac_g[705] * 10 + 1];
        ac_g[38] = ll_tmp(ac_g);
        do print("    %t" + int_to_string(ac_g[38]) + " = icmp eq i64 %t" + int_to_string(ac_g[702]) + ", " + int_to_string(ac_atag));
        let ac_nxt: String = match ac_ai == ac_ac - 1 { true -> "am" + int_to_string(ac_g[703]) + "_b" + int_to_string(ac_ai), false -> "am" + int_to_string(ac_g[703]) + "_c" + int_to_string(ac_ai + 1) };
        do print("    br i1 %t" + int_to_string(ac_g[38]) + ", label %am" + int_to_string(ac_g[703]) + "_b" + int_to_string(ac_ai) + ", label %" + ac_nxt);
        match ac_ai + 1 < ac_ac { true -> do print("am" + int_to_string(ac_g[703]) + "_c" + int_to_string(ac_ai + 1) + ":"), false -> { } };
        ac_g[705] = ac_n[ac_g[705] * 10 + 6];
    };
}

// LLVM: ADT match — emit arm bodies
// g[700]=match_ni, g[701]=adt_ptr_temp, g[703]=match_id, g[704]=arm_count
// g[710+i]=result temp for arm i
fn ll_ambod(ab_g: Array<Int>, ab_n: Array<Int>, ab_s: Array<Int>) [IO] -> Unit {
    let ab_ac: Int = ab_g[704];
    ab_g[705] = ab_n[ab_g[700] * 10 + 5]; // first arm
    for ab_ai in range(0, ab_ac) {
        let ab_an: Int = ab_g[705];
        let ab_fc: Int = ab_n[ab_an * 10 + 8]; // field count
        do print("am" + int_to_string(ab_g[703]) + "_b" + int_to_string(ab_ai) + ":");
        // Bind fields
        ab_g[706] = ab_n[ab_an * 10 + 5]; // first child (binding or body)
        for ab_bi in range(0, ab_fc) {
            let ab_bvi: Int = ab_g[50];
            ab_g[51 + ab_bvi * 4] = ab_n[ab_g[706] * 10 + 2];
            ab_g[51 + ab_bvi * 4 + 1] = ab_n[ab_g[706] * 10 + 3];
            ab_g[51 + ab_bvi * 4 + 2] = 0;
            ab_g[50] = ab_bvi + 1;
            do print("    %v" + int_to_string(ab_bvi) + " = alloca i64");
            ab_g[38] = ll_tmp(ab_g);
            do print("    %t" + int_to_string(ab_g[38]) + " = getelementptr i64, i64* %t" + int_to_string(ab_g[701]) + ", i64 " + int_to_string(ab_bi + 1));
            ab_g[39] = ll_tmp(ab_g);
            do print("    %t" + int_to_string(ab_g[39]) + " = load i64, i64* %t" + int_to_string(ab_g[38]));
            do print("    store i64 %t" + int_to_string(ab_g[39]) + ", i64* %v" + int_to_string(ab_bvi));
            ab_g[706] = ab_n[ab_g[706] * 10 + 6];
        };
        // Body
        ab_g[31] = ab_g[706];
        ab_g[710 + ab_ai] = ll_expr(ab_g, ab_n, ab_s);
        do print("    br label %am" + int_to_string(ab_g[703]) + "_j" + int_to_string(ab_ai));
        do print("am" + int_to_string(ab_g[703]) + "_j" + int_to_string(ab_ai) + ":");
        do print("    br label %am" + int_to_string(ab_g[703]) + "_end");
        ab_g[705] = ab_n[ab_an * 10 + 6];
    };
}

// LLVM: ADT match — emit phi + end label
fn ll_amphi(ap_g: Array<Int>, ap_n: Array<Int>, ap_s: Array<Int>) [IO] -> Int {
    do print("am" + int_to_string(ap_g[703]) + "_end:");
    ap_g[38] = ll_tmp(ap_g);
    do print_raw("    %t" + int_to_string(ap_g[38]) + " = phi i64 ");
    for ap_pi in range(0, ap_g[704]) {
        match ap_pi > 0 { true -> do print_raw(", "), false -> { } };
        do print_raw("[%t" + int_to_string(ap_g[710 + ap_pi]) + ", %am" + int_to_string(ap_g[703]) + "_j" + int_to_string(ap_pi) + "]");
    };
    do print("");
    ap_g[38]
}

// LLVM: ADT match — entry point
fn ll_amatch(la_g: Array<Int>, la_n: Array<Int>, la_s: Array<Int>) [IO] -> Int {
    let la_ni: Int = la_g[31];
    la_g[700] = la_ni; // match node
    la_g[704] = la_n[la_ni * 10 + 4]; // arm count
    la_g[703] = la_g[34]; la_g[34] = la_g[34] + 1; // match ID
    // Evaluate discriminant
    la_g[31] = la_n[la_ni * 10 + 8];
    la_g[35] = ll_expr(la_g, la_n, la_s);
    // Cast to i64* and load tag
    la_g[701] = ll_tmp(la_g);
    do print("    %t" + int_to_string(la_g[701]) + " = inttoptr i64 %t" + int_to_string(la_g[35]) + " to i64*");
    la_g[702] = ll_tmp(la_g);
    do print("    %t" + int_to_string(la_g[702]) + " = load i64, i64* %t" + int_to_string(la_g[701]));
    // Comparison chain
    do ll_amcmp(la_g, la_n, la_s);
    // Arm bodies
    do ll_ambod(la_g, la_n, la_s);
    // Phi
    ll_amphi(la_g, la_n, la_s)
}

// LLVM: match expression — detects ADT arms and dispatches
fn ll_match(lm_g: Array<Int>, lm_n: Array<Int>, lm_s: Array<Int>) [IO] -> Int {
    let lm_ni: Int = lm_g[31];
    let lm_fa: Int = lm_n[lm_ni * 10 + 5]; // first arm
    match lm_n[lm_fa * 10] == 25 { true -> { lm_g[31] = lm_ni; ll_amatch(lm_g, lm_n, lm_s) },
    false -> {
    // Store match state in depth-indexed g[] slots (immune to stack clobber)
    // g[4050+depth] = arm count, g[4060+depth] = match ID
    lm_g[4199] = lm_g[4199] + 1; // increment depth FIRST
    lm_g[4020 + lm_g[4199] - 1] = lm_n[lm_ni * 10 + 4]; // arm count
    lm_g[4060 + lm_g[4199] - 1] = lm_g[34]; lm_g[34] = lm_g[34] + 1; // match ID
    let lm_disc: Int = lm_n[lm_ni * 10 + 8];
    lm_g[31] = lm_disc;
    // Store discriminant temp — use g[4179] as scratch to avoid aryset clobber on computed index
    lm_g[4100 + lm_g[4199] - 1] = ll_expr(lm_g, lm_n, lm_s); // depth-indexed disc scratch
    lm_g[4140 + lm_g[4199] - 1] = lm_g[4100 + lm_g[4199] - 1];
    // Interleaved emission: comparison → arm body → join, for each arm
    // Discriminant at g[4140+depth] dominates all blocks (defined before any branching)
    lm_g[4160 + lm_g[4199] * 2] = lm_n[lm_ni * 10 + 5]; // first arm node
    for lm_ai in range(0, lm_g[4020 + lm_g[4199] - 1]) {
        lm_g[4160 + lm_g[4199] * 2 + 1] = lm_g[4160 + lm_g[4199] * 2]; // current arm
        lm_g[4700 + lm_g[4199] - 1] = lm_n[lm_g[4160 + lm_g[4199] * 2 + 1] * 10 + 1]; // sub_type
        lm_g[4720 + lm_g[4199] - 1] = lm_n[lm_g[4160 + lm_g[4199] * 2 + 1] * 10 + 8]; // pattern
        // Emit comparison
        match lm_g[4700 + lm_g[4199] - 1] == 1 {
            true -> do print("    br label %m" + int_to_string(lm_g[4060 + lm_g[4199] - 1]) + "_b" + int_to_string(lm_ai)),
            false -> {
                match lm_n[lm_g[4160 + lm_g[4199] * 2 + 1] * 10] == 26 {
                    true -> {
                        lm_g[4192] = ll_tmp(lm_g);
                        do print("    %t" + int_to_string(lm_g[4192]) + " = inttoptr i64 %t" + int_to_string(lm_g[4140 + lm_g[4199] - 1]) + " to i8*");
                        lm_g[4191] = lm_n[lm_g[4160 + lm_g[4199] * 2 + 1] * 10 + 8];
                        lm_g[4190] = lm_n[lm_g[4160 + lm_g[4199] * 2 + 1] * 10 + 3] + 1;
                        lm_g[4189] = ll_tmp(lm_g);
                        do print("    %t" + int_to_string(lm_g[4189]) + " = getelementptr [" + int_to_string(lm_g[4190]) + " x i8], [" + int_to_string(lm_g[4190]) + " x i8]* @_s" + int_to_string(lm_g[4191]) + ", i64 0, i64 0");
                        lm_g[4188] = ll_tmp(lm_g);
                        do print("    %t" + int_to_string(lm_g[4188]) + " = call i32 @strcmp(i8* %t" + int_to_string(lm_g[4192]) + ", i8* %t" + int_to_string(lm_g[4189]) + ")");
                        lm_g[4193] = ll_tmp(lm_g);
                        do print("    %t" + int_to_string(lm_g[4193]) + " = icmp eq i32 %t" + int_to_string(lm_g[4188]) + ", 0");
                    },
                    false -> {
                        lm_g[4193] = ll_tmp(lm_g);
                        lm_g[40] = lm_n[lm_g[4160 + lm_g[4199] * 2 + 1] * 10 + 2];
                        lm_g[41] = lm_n[lm_g[4160 + lm_g[4199] * 2 + 1] * 10 + 3];
                        lm_g[4194] = match lm_g[41] > 0 { true -> str2int(lm_g, lm_s), false -> lm_g[4720 + lm_g[4199] - 1] };
                        match lm_n[lm_g[4160 + lm_g[4199] * 2 + 1] * 10 + 9] == 1 { true -> { lm_g[4194] = 0 - lm_g[4194]; }, false -> { } };
                        do print("    %t" + int_to_string(lm_g[4193]) + " = icmp eq i64 %t" + int_to_string(lm_g[4140 + lm_g[4199] - 1]) + ", " + int_to_string(lm_g[4194]));
                    },
                };
                match lm_ai + 1 < lm_g[4020 + lm_g[4199] - 1] {
                    true -> do print("    br i1 %t" + int_to_string(lm_g[4193]) + ", label %m" + int_to_string(lm_g[4060 + lm_g[4199] - 1]) + "_b" + int_to_string(lm_ai) + ", label %m" + int_to_string(lm_g[4060 + lm_g[4199] - 1]) + "_c" + int_to_string(lm_ai + 1)),
                    false -> do print("    br i1 %t" + int_to_string(lm_g[4193]) + ", label %m" + int_to_string(lm_g[4060 + lm_g[4199] - 1]) + "_b" + int_to_string(lm_ai) + ", label %m" + int_to_string(lm_g[4060 + lm_g[4199] - 1]) + "_b" + int_to_string(lm_ai)),
                };
            },
        };
        // Emit arm body immediately after comparison
        do print("m" + int_to_string(lm_g[4060 + lm_g[4199] - 1]) + "_b" + int_to_string(lm_ai) + ":");
        lm_g[31] = lm_n[lm_g[4160 + lm_g[4199] * 2 + 1] * 10 + 5];
        lm_g[4019] = ll_expr(lm_g, lm_n, lm_s); // FIXED slot — safe from aryset clobber
        lm_g[4200 + (lm_g[4199] - 1) * 32 + lm_ai] = lm_g[4019];
        match lm_g[4200 + (lm_g[4199] - 1) * 32 + lm_ai] == 0 { true -> {
            lm_g[4200 + (lm_g[4199] - 1) * 32 + lm_ai] = ll_tmp(lm_g);
            do print("    %t" + int_to_string(lm_g[4200 + (lm_g[4199] - 1) * 32 + lm_ai]) + " = add i64 0, 0");
        }, false -> { } };
        // Join block
        do print("    br label %m" + int_to_string(lm_g[4060 + lm_g[4199] - 1]) + "_j" + int_to_string(lm_ai));
        do print("m" + int_to_string(lm_g[4060 + lm_g[4199] - 1]) + "_j" + int_to_string(lm_ai) + ":");
        do print("    br label %m" + int_to_string(lm_g[4060 + lm_g[4199] - 1]) + "_end");
        // Continuation label for next arm's comparison
        match lm_ai + 1 < lm_g[4020 + lm_g[4199] - 1] {
            true -> match lm_g[4700 + lm_g[4199] - 1] == 1 { true -> { }, false -> do print("m" + int_to_string(lm_g[4060 + lm_g[4199] - 1]) + "_c" + int_to_string(lm_ai + 1) + ":") },
            false -> { },
        };
        lm_g[4160 + lm_g[4199] * 2] = lm_n[lm_g[4160 + lm_g[4199] * 2 + 1] * 10 + 6];
    };
    do print("m" + int_to_string(lm_g[4060 + lm_g[4199] - 1]) + "_end:");
    lm_g[4193] = ll_tmp(lm_g);
    do print_raw("    %t" + int_to_string(lm_g[4193]) + " = phi i64 ");
    for lm_pi in range(0, lm_g[4020 + lm_g[4199] - 1]) {
        match lm_pi > 0 { true -> do print_raw(", "), false -> { } };
        do print_raw("[%t" + int_to_string(lm_g[4200 + (lm_g[4199] - 1) * 32 + lm_pi]) + ", %m" + int_to_string(lm_g[4060 + lm_g[4199] - 1]) + "_j" + int_to_string(lm_pi) + "]");
    };
    do print("");
    lm_g[4199] = lm_g[4199] - 1; // restore depth
    lm_g[4193]
    } }
}

// Emit LLVM IR for a BLOCK expression — iterates children, returns last result.
// Separate function to isolate local variables from recursive ll_expr calls.
// ll_block_expr: evaluate block children, return last result.
// Uses depth-indexed g[] slots to handle recursive block nesting.
// g[4080+depth*2] = child cursor, g[4080+depth*2+1] = last result
// ll_block_expr: evaluate block children, return last result.
// Uses g[4097] as fixed scratch for fn call result (safe from aryset clobber).
// Child cursor and result stored depth-indexed at g[4080+depth*2].
fn ll_block_expr(be_g: Array<Int>, be_n: Array<Int>, be_s: Array<Int>) [IO] -> Int {
    be_g[4099] = be_g[4099] + 1;
    be_g[4015] = be_g[31]; // block node index from g[31] (no 4th param — 3-param limit)
    be_g[4080 + (be_g[4099] - 1) * 2] = be_n[be_g[4015] * 10 + 5];
    be_g[4080 + (be_g[4099] - 1) * 2 + 1] = 0;
    for _be_i in range(0, be_n[be_g[4015] * 10 + 4]) {
        be_g[31] = be_g[4080 + (be_g[4099] - 1) * 2]; // set g[31] to current child
        // Pre-compute next sibling into depth-indexed slot BEFORE ll_expr call
        be_g[4800 + be_g[4099] - 1] = be_n[be_g[4080 + (be_g[4099] - 1) * 2] * 10 + 6];
        be_g[4097] = ll_expr(be_g, be_n, be_s); // evaluate child (may recurse)
        be_g[4080 + (be_g[4099] - 1) * 2 + 1] = be_g[4097]; // store result
        be_g[4080 + (be_g[4099] - 1) * 2] = be_g[4800 + be_g[4099] - 1]; // advance cursor
    };
    be_g[4099] = be_g[4099] - 1;
    be_g[4080 + be_g[4099] * 2 + 1]
}

// Emit LLVM IR for an expression. Dispatches by node type.
// ll_expr_complex — dispatch for compound expression types (CALL, MATCH, FOR, ARRAY, etc.)
fn ll_expr2(l2_g: Array<Int>, l2_n: Array<Int>, l2_s: Array<Int>) [IO] -> Int {
    let l2_ni: Int = l2_g[31];
    let l2_nt: Int = l2_n[l2_ni * 10];
    match l2_nt == 14 { true -> { l2_g[40] = l2_n[l2_ni * 10 + 2]; l2_g[41] = l2_n[l2_ni * 10 + 3]; let l2_bi: Int = chk_bi(l2_g, l2_s); match l2_bi > 0 { true -> { l2_g[140] = l2_bi; l2_g[31] = l2_ni; ll_builtin(l2_g, l2_n, l2_s) }, false -> { l2_g[31] = l2_ni; ll_call(l2_g, l2_n, l2_s) } } },
    false -> match l2_nt == 16 { true -> ll_match(l2_g, l2_n, l2_s),
    false -> match l2_nt == 15 { true -> { l2_g[31] = l2_n[l2_ni * 10 + 5]; ll_expr(l2_g, l2_n, l2_s) },
    false -> match l2_nt == 6 { true -> { l2_g[31] = l2_n[l2_ni * 10 + 5]; ll_expr(l2_g, l2_n, l2_s) },
    false -> match l2_nt == 5 { true -> { l2_g[31] = l2_n[l2_ni * 10 + 5]; ll_expr(l2_g, l2_n, l2_s) },
    false -> match l2_nt == 3 { true -> { l2_g[31] = l2_ni; ll_block_expr(l2_g, l2_n, l2_s) },
    false -> match l2_nt == 4 { true -> { l2_g[31] = l2_ni; do ll_stmt(l2_g, l2_n, l2_s); let l2_lt: Int = ll_tmp(l2_g); do print("    %t" + int_to_string(l2_lt) + " = add i64 0, 0"); l2_lt },
    false -> match l2_nt == 19 { true -> ll_arynew(l2_g, l2_n, l2_s),
    false -> match l2_nt == 20 { true -> ll_aryget(l2_g, l2_n, l2_s),
    false -> match l2_nt == 18 { true -> { do ll_for(l2_g, l2_n, l2_s); let l2_ft: Int = ll_tmp(l2_g); do print("    %t" + int_to_string(l2_ft) + " = add i64 0, 0"); l2_ft },
    false -> match l2_nt == 21 { true -> { do ll_aryset(l2_g, l2_n, l2_s); let l2_st: Int = ll_tmp(l2_g); do print("    %t" + int_to_string(l2_st) + " = add i64 0, 0"); l2_st },
    false -> match l2_nt == 24 { true -> ll_vnew(l2_g, l2_n, l2_s),
    false -> { let l2_t2: Int = ll_tmp(l2_g); do print("    %t" + int_to_string(l2_t2) + " = add i64 0, 0 ; unknown " + int_to_string(l2_nt)); l2_t2 }
    } } } } } } } } } } } }
}

// ll_expr — dispatch on node type. Simple literals handled here, complex types in ll_expr2.
fn ll_expr(le_g: Array<Int>, le_n: Array<Int>, le_s: Array<Int>) [IO] -> Int {
    let le_ni: Int = le_g[31];
    let le_nt: Int = le_n[le_ni * 10];
    match le_nt == 7 { true -> { let le_t: Int = ll_tmp(le_g); le_g[40] = le_n[le_ni * 10 + 2]; le_g[41] = le_n[le_ni * 10 + 3];
        match le_n[le_ni * 10 + 7] == 7 { true -> {
            do print_raw("    %t" + int_to_string(le_t) + " = fadd double 0.0, ");
            for _lfi in range(0, le_g[41]) { do print_byte(le_s[le_g[40] + _lfi]); };
            do print(""); le_g[761] = 7;
        }, false -> { do print("    %t" + int_to_string(le_t) + " = add i64 0, " + int_to_string(str2int(le_g, le_s))); le_g[761] = 0; } }; le_t },
    false -> match le_nt == 8 { true -> { le_g[35]=le_n[le_ni*10+8]; le_g[36]=le_n[le_ni*10+3]+1; le_g[37]=ll_tmp(le_g); do print("    %t"+int_to_string(le_g[37])+" = getelementptr ["+int_to_string(le_g[36])+" x i8], ["+int_to_string(le_g[36])+" x i8]* @_s"+int_to_string(le_g[35])+", i64 0, i64 0"); le_g[38]=ll_tmp(le_g); do print("    %t"+int_to_string(le_g[38])+" = ptrtoint i8* %t"+int_to_string(le_g[37])+" to i64"); le_g[761]=2; le_g[38] },
    false -> match le_nt == 9 { true -> { let le_bt: Int = ll_tmp(le_g); do print("    %t" + int_to_string(le_bt) + " = add i64 0, " + int_to_string(le_n[le_ni * 10 + 8])); le_bt },
    false -> match le_nt == 11 { true -> ll_binop(le_g, le_n, le_s),
    false -> match le_nt == 10 { true -> ll_ident(le_g, le_n, le_s),
    false -> ll_expr2(le_g, le_n, le_s)
    } } } } }
}


// Emit LLVM IR for a statement node
fn ll_stmt(ls_g: Array<Int>, ls_n: Array<Int>, ls_s: Array<Int>) [IO] -> Unit {
    let ls_ni: Int = ls_g[31];
    let ls_nt: Int = ls_n[ls_ni * 10];
    // LET (type 4)
    match ls_nt == 4 {
        true -> {
            let ls_vi: Int = ls_g[50];
            ls_g[51 + ls_vi * 4] = ls_n[ls_ni * 10 + 2];
            ls_g[51 + ls_vi * 4 + 1] = ls_n[ls_ni * 10 + 3];
            ls_g[51 + ls_vi * 4 + 2] = 0; // local var (not param)
            ls_g[51 + ls_vi * 4 + 3] = ls_n[ls_ni * 10 + 7]; // store type_info
            ls_g[50] = ls_vi + 1;
            let ls_is_f: Int = ls_n[ls_ni * 10 + 7];
            match ls_is_f == 7 { true -> do print("    %v" + int_to_string(ls_vi) + " = alloca double"),
            false -> do print("    %v" + int_to_string(ls_vi) + " = alloca i64") };
            ls_g[31] = ls_n[ls_ni * 10 + 5];
            let ls_vt: Int = ll_expr(ls_g, ls_n, ls_s);
            match ls_is_f == 7 { true -> do print("    store double %t" + int_to_string(ls_vt) + ", double* %v" + int_to_string(ls_vi)),
            false -> do print("    store i64 %t" + int_to_string(ls_vt) + ", i64* %v" + int_to_string(ls_vi)) };
        },
        false -> match ls_nt == 5 {
            // EXPR_STMT (type 5) — evaluate child, discard result
            true -> {
                ls_g[31] = ls_n[ls_ni * 10 + 5];
                let _ls_t: Int = ll_expr(ls_g, ls_n, ls_s);
            },
            false -> match ls_nt == 6 {
                // RETURN_EXPR (type 6) — evaluate child, emit ret
                true -> {
                    ls_g[31] = ls_n[ls_ni * 10 + 5];
                    let ls_rt: Int = ll_expr(ls_g, ls_n, ls_s);
                    match ls_g[4120] == 7 { true -> do print("    ret double %t" + int_to_string(ls_rt)),
                    false -> do print("    ret i64 %t" + int_to_string(ls_rt)) };
                    ls_g[33] = 1; // mark has return
                },
                false -> match ls_nt == 15 {
                    true -> { ls_g[31] = ls_n[ls_ni * 10 + 5]; let _ls_t2: Int = ll_expr(ls_g, ls_n, ls_s); },
                    false -> match ls_nt == 18 {
                        // FOR (type 18)
                        true -> { ls_g[31] = ls_ni; do ll_for(ls_g, ls_n, ls_s); },
                        false -> match ls_nt == 21 {
                            // ARRAY_SET (type 21)
                            true -> { ls_g[31] = ls_ni; do ll_aryset(ls_g, ls_n, ls_s); },
                            false -> { ls_g[31] = ls_ni; let _ls_t3: Int = ll_expr(ls_g, ls_n, ls_s); },
                        },
                    },
                },
            },
        },
    };
}

// Emit LLVM IR for a block of statements
fn ll_block(lb_g: Array<Int>, lb_n: Array<Int>, lb_s: Array<Int>) [IO] -> Unit {
    let lb_ni: Int = lb_g[31];
    let lb_cc: Int = lb_n[lb_ni * 10 + 4]; // child count
    let lb_ci: Array<Int> = Array(1); lb_ci[0] = lb_n[lb_ni * 10 + 5];
    for _lb_i in range(0, lb_cc) {
        lb_g[31] = lb_ci[0];
        do ll_stmt(lb_g, lb_n, lb_s);
        lb_ci[0] = lb_n[lb_ci[0] * 10 + 6]; // next sibling
    };
}

// Emit one function
fn ll_fn(lf_g: Array<Int>, lf_n: Array<Int>, lf_s: Array<Int>) [IO] -> Unit {
    let lf_ni: Int = lf_g[31];
    let lf_name_off: Int = lf_n[lf_ni * 10 + 2];
    let lf_name_len: Int = lf_n[lf_ni * 10 + 3];
    let lf_pc: Int = lf_n[lf_ni * 10 + 4]; // param count (NOT including body)
    let lf_body: Int = lf_n[lf_ni * 10 + 8]; // extra = body block index
    // Reset variable table
    lf_g[50] = 0;
    lf_g[32] = 0; // reset SSA counter
    lf_g[33] = 0; // reset has_unreachable flag
    lf_g[4199] = 0; // reset match depth
    lf_g[4099] = 0; // reset block depth
    // g[4120] set below directly from node
    lf_g[34] = 0; // reset match label counter
    // Emit function header
    // Return type: double for Float, i64 for everything else
    lf_g[4120] = lf_n[lf_ni * 10 + 7]; // return type in g[4120] — survives nested calls
    match lf_g[4120] == 7 { true -> do print_raw("define double @fn_"), false -> do print_raw("define i64 @fn_") };
    for lf_i in range(0, lf_name_len) { do print_byte(lf_s[lf_name_off + lf_i]); };
    do print_raw("(");
    // Emit params
    let lf_pn: Array<Int> = Array(1); lf_pn[0] = lf_n[lf_ni * 10 + 5];
    for lf_j in range(0, lf_pc) {
        match lf_j > 0 { true -> do print_raw(", "), false -> { } };
        let lf_pty: Int = lf_n[lf_pn[0] * 10 + 7]; // param type_info
        match lf_pty == 7 { true -> do print_raw("double %p_"), false -> do print_raw("i64 %p_") };
        let lf_poff: Int = lf_n[lf_pn[0] * 10 + 2];
        let lf_plen: Int = lf_n[lf_pn[0] * 10 + 3];
        for lf_k in range(0, lf_plen) { do print_byte(lf_s[lf_poff + lf_k]); };
        // Register param as variable (slot 2 = 1 marks it as param)
        lf_g[51 + lf_g[50] * 4] = lf_poff;
        lf_g[51 + lf_g[50] * 4 + 1] = lf_plen;
        lf_g[51 + lf_g[50] * 4 + 2] = 1;
        lf_g[51 + lf_g[50] * 4 + 3] = lf_pty; // store type_info for Float detection
        lf_g[50] = lf_g[50] + 1;
        lf_pn[0] = lf_n[lf_pn[0] * 10 + 6]; // next sibling
    };
    do print(") {");
    do print("entry:");
    // Emit body from extra field
    lf_g[31] = lf_body;
    do ll_block(lf_g, lf_n, lf_s);
    // ZeroOnDrop: zero sensitive variables before function return (LLVM)
    for lf_zi in range(0, lf_g[50]) {
        match lf_g[51 + lf_zi * 4 + 3] / 16 == 3 { true -> {
            do print("    store i64 0, i64* %v" + int_to_string(lf_zi));
        }, false -> { } };
    };
    // Always emit ret (even if some branches hit unreachable, the phi needs it)
    match lf_g[4120] == 7 { true -> do print("    ret double 0.0"), false -> do print("    ret i64 0") };
    do print("}");
    do print("");
}

// cg_emit_llvm — LLVM IR backend entry point
fn cg_emit_llvm(el_gs: Array<Int>, el_gn: Array<Int>, el_gb: Array<Int>) [IO] -> Unit {
    // Header — target triple based on gs[916]: 0=linux, 1=macos-x86, 2=macos-arm, 3=windows, 4=wasm
    do print("; Loon compiler output — LLVM IR");
    match el_gs[916] == 4 { true -> {
        do print("target triple = \"wasm32-wasi\"");
        do print("target datalayout = \"e-m:e-p:32:32-p10:8:8-p20:8:8-i64:64-n32:64-S128-ni:1:10:20\"");
    }, false -> {
        match el_gs[916] == 1 { true -> do print("target triple = \"x86_64-apple-macosx12.0\""),
        false -> match el_gs[916] == 2 { true -> do print("target triple = \"arm64-apple-macosx12.0\""),
        false -> match el_gs[916] == 3 { true -> do print("target triple = \"x86_64-pc-windows-msvc\""),
        false -> do print("target triple = \"x86_64-pc-linux-gnu\"") } } };
    } };
    do print("");
    // External declarations — WASI vs native
    match el_gs[916] == 4 { true -> {
        do print("declare i32 @fd_write(i32, i32, i32, i32) #0");
        do print("declare void @proc_exit(i32) #1");
        do print("attributes #0 = { \"wasm-import-module\"=\"wasi_snapshot_preview1\" \"wasm-import-name\"=\"fd_write\" }");
        do print("attributes #1 = { \"wasm-import-module\"=\"wasi_snapshot_preview1\" \"wasm-import-name\"=\"proc_exit\" }");
        do print("declare i8* @_loon_i64_to_str(i64)");
        do print("declare void @_loon_print_byte(i64)");
        do print("declare i8* @_loon_read_file(i64)");
        do print("declare i8* @_loon_get_arg(i64)");
    }, false -> {
        do print("declare void @exit(i32) noreturn");
        do print("declare i64 @write(i32, i8*, i64)");
        do print("declare i8* @malloc(i64)");
        do print("declare i32 @sprintf(i8*, i8*, ...)");
        do print("declare i64 @strlen(i8*)");
        do print("declare i8* @_loon_i64_to_str(i64)");
        do print("declare void @_loon_print_byte(i64)");
        do print("declare i8* @_loon_read_file(i64)");
        do print("declare i8* @_loon_get_arg(i64)");
        do print("declare i32 @strcmp(i8*, i8*)");
        do print("declare void @llvm.memcpy.p0.p0.i64(i8* nocapture, i8* nocapture readonly, i64, i1)");
    } };
    do print("");
    // String literals — walk nodes for STR_LIT (8) and STR_MATCH_ARM (26)
    el_gs[29] = 0;
    for el_si in range(0, el_gs[12]) {
        let el_is_str: Int = match el_gn[el_si * 10] == 8 { true -> 1, false -> match el_gn[el_si * 10] == 26 { true -> 1, false -> 0 } };
        match el_is_str == 1 {
            true -> {
                let el_off: Int = el_gn[el_si * 10 + 2];
                let el_len: Int = el_gn[el_si * 10 + 3];
                do print_raw("@_s" + int_to_string(el_gs[29]) + " = private unnamed_addr constant [" + int_to_string(el_len + 1) + " x i8] c\"");
                for el_sj in range(0, el_len) {
                    let el_ch: Int = el_gb[el_off + el_sj];
                    // Printable ASCII except backslash and quote
                    match el_ch >= 32 {
                        true -> match el_ch == 34 { true -> do print_raw("\\22"), false -> match el_ch == 92 { true -> do print_raw("\\5C"), false -> do print_byte(el_ch) } },
                        false -> match el_ch == 10 { true -> do print_raw("\\0A"), false -> match el_ch == 9 { true -> do print_raw("\\09"), false -> do print_raw("\\00") } },
                    };
                };
                do print("\\00\"");
                el_gn[el_si * 10 + 8] = el_gs[29]; // store string index
                el_gs[29] = el_gs[29] + 1;
            },
            false -> { },
        };
    };
    // Newline constant for print
    do print("@_nl = private unnamed_addr constant [1 x i8] c\"\\0A\"");
    do print("@_fmt_float = private unnamed_addr constant [3 x i8] c\"%g\\00\"");
    do print("@_fmt_int = private unnamed_addr constant [4 x i8] c\"%ld\\00\"");
    do print("@_bounds_msg = private constant [34 x i8] c\"error: array index out of bounds\\0A\\00\"");
    // Bounds panic function
    do print("define void @__loon_bounds_panic(i64 %idx, i64 %len) noreturn {");
    do print("entry:");
    do print("    %msg = getelementptr [34 x i8], [34 x i8]* @_bounds_msg, i64 0, i64 0");
    match el_gs[916] == 4 {
        true -> do print("    call void @proc_exit(i32 1)"),
        false -> {
            do print("    call i64 @write(i32 2, i8* %msg, i64 32)");
            do print("    call void @exit(i32 1)");
        },
    };
    do print("    unreachable");
    do print("}");
    match el_gs[916] == 4 { true -> {
        do print("@_wasi_iov = global [2 x i32] zeroinitializer");
        do print("@_wasi_nw = global i32 0");
        // Bump allocator for WASM (no libc malloc)
        // Bump allocator for WASM (no libc)
        do print("@_bump_ptr = global i32 65536");
        do print("define i8* @malloc(i64 %size) {");
        do print("  %sz32 = trunc i64 %size to i32");
        do print("  %cur = load i32, i32* @_bump_ptr");
        do print("  %next = add i32 %cur, %sz32");
        do print("  store i32 %next, i32* @_bump_ptr");
        do print("  %ptr = inttoptr i32 %cur to i8*");
        do print("  ret i8* %ptr");
        do print("}");
        // strlen for WASM
        do print("define i64 @strlen(i8* %s) {");
        do print("entry:");
        do print("  br label %loop");
        do print("loop:");
        do print("  %i = phi i64 [0, %entry], [%i1, %loop]");
        do print("  %p = getelementptr i8, i8* %s, i64 %i");
        do print("  %c = load i8, i8* %p");
        do print("  %i1 = add i64 %i, 1");
        do print("  %done = icmp eq i8 %c, 0");
        do print("  br i1 %done, label %end, label %loop");
        do print("end:");
        do print("  ret i64 %i");
        do print("}");
        // sprintf stub — just for int_to_string, format %ld
        do print("define i32 @sprintf(i8* %buf, i8* %fmt, ...) {");
        do print("  ret i32 0");
        do print("}");
        // Emit _loon_write wrapper for WASI fd_write
        do print("define i64 @write(i32 %fd, i8* %buf, i64 %len) {");
        do print("  %ptr32 = ptrtoint i8* %buf to i32");
        do print("  store i32 %ptr32, i32* getelementptr ([2 x i32], [2 x i32]* @_wasi_iov, i32 0, i32 0)");
        do print("  %len32 = trunc i64 %len to i32");
        do print("  store i32 %len32, i32* getelementptr ([2 x i32], [2 x i32]* @_wasi_iov, i32 0, i32 1)");
        do print("  %iov = ptrtoint [2 x i32]* @_wasi_iov to i32");
        do print("  %nw = ptrtoint i32* @_wasi_nw to i32");
        do print("  %r = call i32 @fd_write(i32 %fd, i32 %iov, i32 1, i32 %nw)");
        do print("  %r64 = zext i32 %r to i64");
        do print("  ret i64 %r64");
        do print("}");
    }, false -> { } };
    do print("");
    // Functions — walk nodes for FN_DECL (1)
    for el_fi in range(0, el_gs[12]) {
        match el_gn[el_fi * 10] == 1 {
            true -> {
                el_gs[31] = el_fi;
                do ll_fn(el_gs, el_gn, el_gb);
            },
            false -> { },
        };
    };
    // Entry point — _start for WASM, main for native
    match el_gs[916] == 4 { true -> {
        do print("define void @_start() {");
        do print("entry:");
        do print("    call i64 @fn_main()");
        do print("    ret void");
        do print("}");
    }, false -> {
        do print("define i32 @main() {");
        do print("entry:");
        do print("    call i64 @fn_main()");
        do print("    ret i32 0");
        do print("}");
    } };
}

// Parse --target flag. Returns 1 for llvm, 0 for nasm.
// If --target is present, sets flags[0]=target, flags[1]=source_arg_offset
fn ptarg(pt_flags: Array<Int>) [IO] -> Unit {
    let pt_a1: String = get_arg(1);
    let pt_len: Int = string_length(pt_a1);
    match pt_len == 8 {
        true -> {
            // --target X: check X starts with 'l' for llvm
            let pt_a2: String = get_arg(2);
            match string_char_at(pt_a2, 0) == 108 { true -> { pt_flags[0] = 1; }, false -> { } };
            pt_flags[1] = 2;
        },
        false -> { },
    };
}

// Main — gs[910]=json, gs[915]=target(0=nasm,1=llvm), gs[916]=arch(0=linux,1=macos-x86,2=macos-arm,3=windows)
fn main() [IO] -> Unit {
    // Parse --target flag first
    let arg1: String = get_arg(1);
    let a1len: Int = string_length(arg1);
    let mf: Array<Int> = Array(2); mf[0] = 0; mf[1] = 0;
    // mf[0] = target (0=nasm, 1=llvm), mf[1] = arch (0=linux, 1=macos-x86, 2=macos-arm, 3=windows)
    match a1len == 8 { true -> { let a2t: String = get_arg(2); match string_char_at(a2t, 0) == 108 { true -> { mf[0] = 1; }, false -> { } }; }, false -> { } };
    // If --target present, check arg3 for --arch (6 chars, char[2]='a'=97)
    // Usage: loon --target llvm [--arch macos|macos-arm|windows] file.loon
    match a1len == 8 { true -> {
        let a3t: String = get_arg(3);
        let a3len: Int = string_length(a3t);
        match a3len == 6 { true -> match string_char_at(a3t, 2) == 97 { true -> {
            // --arch found (6 chars, 3rd char 'a'). Read arch name from arg4.
            let a4t: String = get_arg(4);
            let a4len: Int = string_length(a4t);
            // macos=5 chars starting with 'm', macos-arm=9, windows=7
            match a4len == 5 { true -> match string_char_at(a4t, 0) == 109 { true -> { mf[1] = 1; }, false -> { } }, false -> { } };
            match a4len == 9 { true -> { mf[1] = 2; }, false -> { } };
            match a4len == 7 { true -> { mf[1] = 3; }, false -> { } };
            match a4len == 4 { true -> match string_char_at(a4t, 0) == 119 { true -> { mf[1] = 4; }, false -> { } }, false -> { } };
        }, false -> { } }, false -> { } };
    }, false -> { } };
    // Source file position: --target llvm --arch X file = arg5; --target llvm file = arg3; file = arg1
    let source: String = match a1len == 8 {
        true -> match mf[1] > 0 { true -> read_file(get_arg(5)), false -> read_file(get_arg(3)) },
        false -> match a1len == 6 { true -> read_file(get_arg(2)), false -> read_file(arg1) },
    };
    let slen: Int = string_length(source);
    let gs: Array<Int> = Array(8192);
    let gb: Array<Int> = Array(524288);
    let gt: Array<Int> = Array(300000);
    let gn: Array<Int> = Array(700000);
    gs[910] = match a1len == 6 { true -> 1, false -> 0 };
    gs[915] = mf[0];
    gs[916] = mf[1];
    for ci in range(0, slen) { gb[ci] = string_char_at(source, ci); };
    gs[0] = slen;
    do lex_all(gs, gt, gb);
    gs[46] = 0 - 1; gs[121] = 0 - 1; gs[153] = 0 - 1; gs[256] = 0 - 1; gs[900] = 0;
    for sci in range(0, gs[5]) { gn[200000 + sci] = gb[sci]; };
    do pp_parse(gs, gt, gn);
    for sci2 in range(0, gs[5]) { gb[sci2] = gn[200000 + sci2]; };
    do tc_check(gs, gn, gb);
    match gs[915] == 1 {
        true -> do cg_emit_llvm(gs, gn, gb),
        false -> do cg_emit(gs, gn, gb),
    };
    do exit(0);
}

